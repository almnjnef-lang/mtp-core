cat << 'EOF' > /root/million_visitors_tuning.py
import os, subprocess

print("🚀 جاري تحويل السيرفر إلى وحش يستوعب الملايين...")

# 1. فك القيود عن نظام التشغيل (Linux Kernel Tuning)
sysctl_conf = "/etc/sysctl.conf"
kernel_tuning = """
# Mnjnef Massive Scale Tuning
fs.file-max = 2097152
net.core.somaxconn = 65535
net.ipv4.tcp_tw_reuse = 1
net.ipv4.ip_local_port_range = 1024 65535
net.ipv4.tcp_max_syn_backlog = 65535
"""
with open(sysctl_conf, 'r') as f:
    if "Mnjnef Massive Scale Tuning" not in f.read():
        with open(sysctl_conf, 'a') as append_f:
            append_f.write(kernel_tuning)
subprocess.run(["sysctl", "-p"], capture_output=True)
print("✅ 1. تم فك قيود نواة لينكس (Kernel) للسماح بـ 2 مليون اتصال.")

# 2. رفع حدود الأمان للملفات المفتوحة
limits_conf = "/etc/security/limits.conf"
limits_tuning = """
* soft nofile 1048576
* hard nofile 1048576
root soft nofile 1048576
root hard nofile 1048576
"""
with open(limits_conf, 'r') as f:
    if "1048576" not in f.read():
        with open(limits_conf, 'a') as append_f:
            append_f.write(limits_tuning)
print("✅ 2. تم رفع حدود الأمان للحد الأقصى (1,048,576 ملف).")

# 3. إعادة برمجة Nginx بالكامل للسرعة القصوى
nginx_conf = "/etc/nginx/nginx.conf"
ultra_nginx = """user www-data;
worker_processes auto;
worker_rlimit_nofile 1048576;
pid /run/nginx.pid;
include /etc/nginx/modules-enabled/*.conf;

events {
    worker_connections 65535;
    multi_accept on;
    use epoll;
}

http {
    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout 15;
    types_hash_max_size 2048;
    server_tokens off;
    client_max_body_size 50M;

    # Mnjnef Military Grade Security
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Open File Cache (يقلل الضغط على الهارد ديسك ويضاعف السرعة)
    open_file_cache max=200000 inactive=20s;
    open_file_cache_valid 30s;
    open_file_cache_min_uses 2;
    open_file_cache_errors on;

    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    access_log off; # إيقاف التسجيل لتوفير طاقة السيرفر
    error_log /var/log/nginx/error.log crit; # تسجيل الأخطاء القاتلة فقط

    # ضغط الملفات الخارق (Gzip)
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml application/json application/javascript application/rss+xml application/atom+xml image/svg+xml;

    include /etc/nginx/conf.d/*.conf;
    include /etc/nginx/sites-enabled/*;
}
"""
with open(nginx_conf, 'w') as f:
    f.write(ultra_nginx)
subprocess.run(["systemctl", "restart", "nginx"])
print("✅ 3. تم ترقية Nginx وتركيب أنظمة (الكاش المتقدم، ضغط Gzip، وتفعيل Epoll).")
print("🎉 اكتملت المهمة! السيرفر الآن وحش تقني جاهز لمواجهة العالم.")
EOF

python3 /root/million_visitors_tuning.py
