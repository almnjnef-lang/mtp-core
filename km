import QtQuick
import QtQuick.Controls
import QtQuick.Layouts

Item {
    id: root
    width: contactRow.implicitWidth
    height: contactRow.implicitHeight

    property color accentColor: "#1f6feb"
    property color textColor: "#6f7fa0"
    property color backgroundColor: "#0a1428"
    property color surfaceColor: "#1e3257"

    Row {
        id: contactRow
        spacing: 6
        anchors.centerIn: parent

        Image {
            width: 18
            height: 18
            anchors.verticalCenter: parent.verticalCenter
            smooth: true
            antialiasing: true
            source: "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%236f7fa0' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><path d='M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2'/><circle cx='12' cy='7' r='4'/><path d='M4 11V9a8 8 0 0 1 16 0v2'/><rect x='2' y='9' width='4' height='5' rx='1'/><rect x='18' y='9' width='4' height='5' rx='1'/><path d='M19 13v2a3 3 0 0 1-3 3h-2'/><circle cx='14' cy='18' r='1' fill='%236f7fa0'/></svg>"
        }

        Text {
            text: qsTr("Contact Us")
            color: root.textColor
            font.pixelSize: 12
            anchors.verticalCenter: parent.verticalCenter
        }
    }

    MouseArea {
        anchors.fill: parent
        cursorShape: Qt.PointingHandCursor
        hoverEnabled: true
        onEntered: root.opacity = 0.7
        onExited: root.opacity = 1.0
        onClicked: supportPopup.open()
    }

    Popup {
        id: supportPopup
        width: 450
        height: 520
        x: (parent.width - width) / 2 - 200
        y: -400
        modal: true
        focus: true
        closePolicy: Popup.CloseOnEscape | Popup.CloseOnPressOutside

        background: Rectangle {
            color: root.backgroundColor
            radius: 12
            border.color: root.surfaceColor
            border.width: 1
        }

        Column {
            anchors.fill: parent
            anchors.margins: 24
            spacing: 20

            Row {
                width: parent.width
                Text {
                    text: qsTr("Mnjnef Support")
                    color: "#ffffff"
                    font.pixelSize: 22
                    font.bold: true
                    width: parent.width - closeButton.width
                }
                Rectangle {
                    id: closeButton
                    width: 24
                    height: 24
                    color: "transparent"
                    Text { anchors.centerIn: parent; text: "✕"; color: root.textColor; font.pixelSize: 16 }
                    MouseArea {
                        anchors.fill: parent
                        cursorShape: Qt.PointingHandCursor
                        onClicked: supportPopup.close()
                    }
                }
            }

            Rectangle { width: parent.width; height: 1; color: root.surfaceColor }

            Text { text: qsTr("How can we help you today?"); color: root.textColor; font.pixelSize: 14 }

            Rectangle {
                width: parent.width; height: 48; color: "#111827"; radius: 8; border.color: root.surfaceColor
                TextInput {
                    id: subjectField; anchors.fill: parent; anchors.margins: 12; color: "#ffffff"; font.pixelSize: 14; verticalAlignment: TextInput.AlignVCenter
                    Text { text: qsTr("Subject"); color: "#4b5563"; font.pixelSize: 14; anchors.verticalCenter: parent.verticalCenter; visible: !subjectField.text && !subjectField.activeFocus }
                }
            }

            Rectangle {
                width: parent.width; height: 180; color: "#111827"; radius: 8; border.color: root.surfaceColor
                TextEdit {
                    id: messageArea; anchors.fill: parent; anchors.margins: 12; color: "#ffffff"; font.pixelSize: 14; wrapMode: TextEdit.WordWrap
                    Text { text: qsTr("Describe your issue..."); color: "#4b5563"; font.pixelSize: 14; visible: !messageArea.text && !messageArea.activeFocus }
                }
            }

            Rectangle {
                id: sendBtn; width: parent.width; height: 48; radius: 8; color: root.accentColor
                Text { anchors.centerIn: parent; text: qsTr("Send Message"); color: "#ffffff"; font.pixelSize: 15; font.bold: true }
                MouseArea {
                    anchors.fill: parent; cursorShape: Qt.PointingHandCursor
                    onClicked: { subjectField.text = ""; messageArea.text = ""; supportPopup.close() }
                }
            }
        }
    }
}
