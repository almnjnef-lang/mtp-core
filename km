# 💾 4. ADVANCED DATABASE MANAGER
# ==============================================================================
@dataclass
class ArticleRecord:
    url: str
    title: str
    category: str
    seo_tags: str
    image_source: str

class DatabaseManager:
    def __init__(self, db_path: str):
        self.db_path = db_path
        self._init_db()
        
    def _get_connection(self) -> sqlite3.Connection:
        return sqlite3.connect(self.db_path, timeout=30)
        
    def _init_db(self) -> None:
        try:
            with self._get_connection() as conn:
                cursor = conn.cursor()
                cursor.execute("""
                    CREATE TABLE IF NOT EXISTS pure_articles (
                        id INTEGER PRIMARY KEY AUTOINCREMENT,
                        original_url TEXT UNIQUE NOT NULL,
                        published_title TEXT NOT NULL,
                        category TEXT NOT NULL,
                        seo_tags TEXT,
                        image_source TEXT,
                        published_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                    )
                """)
                cursor.execute("CREATE INDEX IF NOT EXISTS idx_pure_url ON pure_articles(original_url)")
                cursor.execute("CREATE INDEX IF NOT EXISTS idx_pure_cat ON pure_articles(category)")
                conn.commit()
            logger.debug("Database initialized.")
        except sqlite3.Error as e:
            logger.critical(f"DB Init failed: {e}")
            sys.exit(1)

    def is_processed(self, url: str) -> bool:
        try:
            with self._get_connection() as conn:
                cursor = conn.cursor()
                cursor.execute("SELECT 1 FROM pure_articles WHERE original_url = ?", (url,))
                return cursor.fetchone() is not None
        except sqlite3.Error:
            return False

    def save_record(self, record: ArticleRecord) -> bool:
        try:
            with self._get_connection() as conn:
                cursor = conn.cursor()
                cursor.execute(
                    """INSERT INTO pure_articles 
                       (original_url, published_title, category, seo_tags, image_source) 
                       VALUES (?, ?, ?, ?, ?)""",
                    (record.url, record.title, record.category, record.seo_tags, record.image_source)
                )
                conn.commit()
            return True
        except sqlite3.IntegrityError:
            return False
        except sqlite3.Error as e:
            logger.error(f"DB Write Error: {e}")
            return False

