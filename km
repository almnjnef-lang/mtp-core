cat << 'EOF' > /root/allow_translation.py
import os, glob, subprocess

print("🌍 جاري إعادة تفعيل خيار الترجمة للزوار...")

configs = glob.glob('/root/**/config.toml', recursive=True) + glob.glob('/root/**/hugo.toml', recursive=True) + glob.glob('/var/www/**/config.toml', recursive=True) + glob.glob('/var/www/**/hugo.toml', recursive=True)
if configs:
    conf = configs[0]
    site_dir = os.path.dirname(conf)
    head_file = os.path.join(site_dir, 'layouts', 'partials', 'extend_head.html')
    
    if os.path.exists(head_file):
        with open(head_file, 'r', encoding='utf-8') as f:
            content = f.read()
        
        # مسح كود منع الترجمة
        content = content.replace('<meta name="google" content="notranslate">\n', '')
        content = content.replace('<meta name="google" content="notranslate">', '')
        
        with open(head_file, 'w', encoding='utf-8') as f:
            f.write(content)
        print("✅ تم إلغاء حظر الترجمة! متصفحات الزوار ستعرض لهم خيار الترجمة الآن براحة تامة.")
        
    # البناء والتحديث
    subprocess.run(["hugo", "--gc", "--minify"], cwd=site_dir, capture_output=True)
    for dest in ['/var/www/html', '/var/www/mnjnef', '/var/www/mnjnef.com']:
        if os.path.exists(dest):
            subprocess.run(f"cp -r {os.path.join(site_dir, 'public')}/* {dest}/ 2>/dev/null", shell=True)
    print("⚙️ تم تحديث الواجهة للمستخدمين بنجاح.")

print("🎉 الموقع الآن إنجليزي فخم، ويدعم الترجمة الذكية للجميع!")
EOF

python3 /root/allow_translation.py
