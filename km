cat << 'EOF' > /root/time_machine.py
import re

print("⏳ [آلة الزمن] جاري محو أخطاء الماضي وتنظيف السيرفر من دوامة الأطباء...")
path = "/root/mnjnef_factory.py"
with open(path, "r", encoding="utf-8") as f:
    code = f.read()

# مسح القمامة البرمجية والدوامة اللانهائية التي تسببت باختناق السيرفر
code = re.sub(r'^[ \t]*except Exception:\s*\n', '', code, flags=re.MULTILINE)
code = re.sub(r'^[ \t]*pass #.*?\n', '', code, flags=re.MULTILINE)
code = re.sub(r'^[ \t]*# [☢️🔪🩹].*?\n', '', code, flags=re.MULTILINE)
code = re.sub(r'^[ \t]*# 🔪 مسح آلي:.*?\n', '', code, flags=re.MULTILINE)

# الخدعة الهندسية: تحويل try اليتيمة إلى if True للحفاظ على وزن السيرفر بدون أخطاء
code = re.sub(r'([ \t]*)try:\s*\n([ \t]*import urllib\.parse)', r'\1if True:\n\2', code)

with open(path, "w", encoding="utf-8") as f:
    f.write(code)
print("✅ [آلة الزمن] السيرفر عاد نقياً، سليماً، وجاهزاً للعمل 100%.")
EOF

python3 /root/time_machine.py

echo "🥷 جاري إطلاق قوات النشر الخاصة (3 روبوتات معاً)..."
