import QtQuick
import QtQuick.Controls
import QtQuick.Layouts

Item {
    id: mnjnefTicketTrackerRoot
    anchors.fill: parent
    clip: true

    // ==========================================
    // THEME & STYLING (PROFESSIONAL GRAYSCALE)
    // ==========================================
    QtObject {
        id: modernTheme
        property color bgApp: "#09090B"
        property color bgCard: "#18181B"
        property color bgElevated: "#27272A"
        property color bgInput: "#121214"
        
        property color borderSubtle: "#27272A"
        property color borderFocus: "#3F3F46"
        
        property color textPrimary: "#FAFAFA"
        property color textSecondary: "#A1A1AA"
        property color textMuted: "#52525B"
        
        property color accent: "#FFFFFF"
        property color stateActive: "#10B981" // Green for active status
        
        property string fontMain: "Segoe UI"
        property string fontMono: "Consolas"
    }

    Rectangle {
        anchors.fill: parent
        color: modernTheme.bgApp
    }

    // ==========================================
    // TOP NAVIGATION BAR (WITH BACK BUTTON)
    // ==========================================
    Rectangle {
        id: topNavBar
        width: parent.width
        height: 70
        color: modernTheme.bgApp
        border.color: modernTheme.borderSubtle
        border.width: 1
        z: 10

        RowLayout {
            anchors.fill: parent
            anchors.leftMargin: 30
            anchors.rightMargin: 30
            spacing: 20

            // Back Button
            Rectangle {
                Layout.preferredWidth: 40
                Layout.preferredHeight: 40
                radius: 8
                color: backMouse.containsMouse ? modernTheme.bgElevated : modernTheme.bgCard
                border.color: modernTheme.borderSubtle
                border.width: 1
                
                Behavior on color { ColorAnimation { duration: 150 } }

                Text {
                    anchors.centerIn: parent
                    text: "◀"
                    color: modernTheme.textPrimary
                    font.pixelSize: 14
                }

                MouseArea {
                    id: backMouse
                    anchors.fill: parent
                    hoverEnabled: true
                    cursorShape: Qt.PointingHandCursor
                    onClicked: {
                        if (StackView.view) {
                            StackView.view.pop();
                        }
                    }
                }
            }

            Text {
                text: qsTr("Ticket Tracking")
                color: modernTheme.textPrimary
                font.pixelSize: 18
                font.bold: true
                font.family: modernTheme.fontMain
            }
            
            Item { Layout.fillWidth: true }
        }
    }

    // ==========================================
    // MAIN CONTENT
    // ==========================================
    Flickable {
        anchors.top: topNavBar.bottom
        anchors.bottom: parent.bottom
        anchors.left: parent.left
        anchors.right: parent.right
        contentWidth: width
        contentHeight: contentLayout.implicitHeight + 60
        clip: true
        boundsBehavior: Flickable.StopAtBounds

        ColumnLayout {
            id: contentLayout
            width: Math.min(parent.width - 60, 1000)
            anchors.horizontalCenter: parent.horizontalCenter
            anchors.top: parent.top
            anchors.topMargin: 30
            spacing: 24

            // 1. TICKET HEADER INFO
            Rectangle {
                Layout.fillWidth: true
                Layout.preferredHeight: 100
                radius: 12
                color: modernTheme.bgCard
                border.color: modernTheme.borderSubtle
                border.width: 1

                RowLayout {
                    anchors.fill: parent
                    anchors.margins: 20
                    spacing: 20

                    Rectangle {
                        Layout.preferredWidth: 56
                        Layout.preferredHeight: 56
                        radius: 12
                        color: modernTheme.bgElevated
                        border.color: modernTheme.borderFocus
                        border.width: 1
                        
                        Text {
                            anchors.centerIn: parent
                            text: "📡"
                            font.pixelSize: 24
                        }
                    }

                    ColumnLayout {
                        Layout.fillWidth: true
                        spacing: 4
                        
                        Text {
                            text: qsTr("TRACKING TERMINAL")
                            color: modernTheme.textMuted
                            font.pixelSize: 11
                            font.bold: true
                            font.family: modernTheme.fontMono
                        }
                        
                        Text {
                            text: "TKT-849201" // Static ID waiting for real backend data
                            color: modernTheme.textPrimary
                            font.pixelSize: 22
                            font.bold: true
                            font.family: modernTheme.fontMain
                        }
                    }
                    
                    // Status Badge
                    Rectangle {
                        Layout.preferredWidth: 100
                        Layout.preferredHeight: 32
                        radius: 16
                        color: "transparent"
                        border.color: modernTheme.stateActive
                        border.width: 1
                        
                        RowLayout {
                            anchors.centerIn: parent
                            spacing: 8
                            
                            Rectangle {
                                width: 8
                                height: 8
                                radius: 4
                                color: modernTheme.stateActive
                            }
                            
                            Text {
                                text: qsTr("ACTIVE")
                                color: modernTheme.stateActive
                                font.pixelSize: 12
                                font.bold: true
                                font.family: modernTheme.fontMono
                            }
                        }
                    }
                }
            }

            // 2. METADATA & TIMELINE SPLIT
            RowLayout {
                Layout.fillWidth: true
                spacing: 24
                Layout.alignment: Qt.AlignTop

                // Left Column: Metadata
                Rectangle {
                    Layout.preferredWidth: 350
                    Layout.preferredHeight: 250
                    radius: 12
                    color: modernTheme.bgCard
                    border.color: modernTheme.borderSubtle
                    border.width: 1
                    Layout.alignment: Qt.AlignTop

                    ColumnLayout {
                        anchors.fill: parent
                        anchors.margins: 20
                        spacing: 16
                        
                        Text {
                            text: qsTr("PAYLOAD METADATA")
                            color: modernTheme.textPrimary
                            font.pixelSize: 14
                            font.bold: true
                            font.family: modernTheme.fontMain
                        }
                        
                        Rectangle {
                            Layout.fillWidth: true
                            Layout.preferredHeight: 1
                            color: modernTheme.borderSubtle
                        }
                        
                        GridLayout {
                            Layout.fillWidth: true
                            columns: 2
                            rowSpacing: 16
                            columnSpacing: 16
                            
                            // Static metadata awaiting C++ model
                            MetadataItem { label: "Category"; value: "Technical Issue" }
                            MetadataItem { label: "Priority"; value: "HIGH" }
                            MetadataItem { label: "Environment"; value: "Win64 / DX12" }
                            MetadataItem { label: "Session ID"; value: "MNJ-88A9B2" }
                        }
                    }
                }

                // Right Column: Timeline
                Rectangle {
                    Layout.fillWidth: true
                    Layout.preferredHeight: 350
                    radius: 12
                    color: modernTheme.bgCard
                    border.color: modernTheme.borderSubtle
                    border.width: 1
                    Layout.alignment: Qt.AlignTop

                    ColumnLayout {
                        anchors.fill: parent
                        anchors.margins: 20
                        spacing: 24

                        Text {
                            text: qsTr("RESOLUTION PROTOCOL SEQUENCE")
                            color: modernTheme.textPrimary
                            font.pixelSize: 14
                            font.bold: true
                            font.family: modernTheme.fontMain
                        }

                        // Static Timeline waiting for backend integration
                        ColumnLayout {
                            Layout.fillWidth: true
                            spacing: 0
                            
                            TimelineItem { isCompleted: true; isCurrent: false; title: "Ticket Submitted"; desc: "Secure transmission complete"; time: "10:42 AM"; showLine: true }
                            TimelineItem { isCompleted: true; isCurrent: false; title: "Heuristic Scan"; desc: "Payload sanitized & verified"; time: "10:43 AM"; showLine: true }
                            TimelineItem { isCompleted: false; isCurrent: true; title: "Agent Assigned"; desc: "Routing to specialized operative"; time: "10:45 AM"; showLine: true }
                            TimelineItem { isCompleted: false; isCurrent: false; title: "Resolution"; desc: "Awaiting final diagnostics"; time: "--:--"; showLine: false }
                        }
                        
                        Item { Layout.fillHeight: true }
                    }
                }
            }
        }
    }

    // ==========================================
    // HELPER COMPONENTS
    // ==========================================
    component MetadataItem: ColumnLayout {
        property string label: ""
        property string value: ""
        spacing: 4
        
        Text {
            text: parent.label
            color: modernTheme.textSecondary
            font.pixelSize: 12
            font.family: modernTheme.fontMain
        }
        Text {
            text: parent.value
            color: modernTheme.textPrimary
            font.pixelSize: 14
            font.bold: true
            font.family: modernTheme.fontMono
        }
    }

    component TimelineItem: Item {
        property bool isCompleted: false
        property bool isCurrent: false
        property string title: ""
        property string desc: ""
        property string time: ""
        property bool showLine: true
        
        Layout.fillWidth: true
        Layout.preferredHeight: 60
        
        Rectangle {
            width: 2
            height: parent.height
            color: isCompleted ? modernTheme.accent : modernTheme.borderSubtle
            x: 11
            y: 24
            visible: showLine
        }
        
        RowLayout {
            anchors.fill: parent
            spacing: 20
            
            Rectangle {
                Layout.preferredWidth: 24
                Layout.preferredHeight: 24
                radius: 12
                Layout.alignment: Qt.AlignTop
                color: isCompleted || isCurrent ? modernTheme.accent : "transparent"
                border.color: isCompleted || isCurrent ? modernTheme.accent : modernTheme.borderFocus
                border.width: 2
                
                Text {
                    anchors.centerIn: parent
                    text: isCompleted ? "✓" : ""
                    color: modernTheme.bgApp
                    font.pixelSize: 12
                    font.bold: true
                    visible: isCompleted
                }
                
                Rectangle {
                    anchors.centerIn: parent
                    width: 8
                    height: 8
                    radius: 4
                    color: modernTheme.bgApp
                    visible: isCurrent
                }
            }
            
            ColumnLayout {
                Layout.fillWidth: true
                spacing: 2
                
                Text {
                    text: parent.parent.title
                    color: parent.parent.isCurrent || parent.parent.isCompleted ? modernTheme.textPrimary : modernTheme.textSecondary
                    font.pixelSize: 15
                    font.bold: true
                    font.family: modernTheme.fontMain
                }
                Text {
                    text: parent.parent.desc
                    color: modernTheme.textMuted
                    font.pixelSize: 13
                    font.family: modernTheme.fontMain
                }
            }
            
            Text {
                text: parent.time
                color: modernTheme.textMuted
                font.pixelSize: 12
                font.family: modernTheme.fontMono
                Layout.alignment: Qt.AlignTop
                Layout.topMargin: 4
            }
        }
    }
}
