import os
import time
import random
import requests
import re
from datetime import datetime
import feedparser
from newspaper import Article

# ضع مفتاحك السري هنا بين علامتي التنصيص
MISTRAL_API_KEY = "ضع_مفتاحك_السري_هنا"

RSS_URL = "http://feeds.bbci.co.uk/news/world/rss.xml" 
OUTPUT_DIR = "content/posts"

if not os.path.exists(OUTPUT_DIR):
    os.makedirs(OUTPUT_DIR)

print("🚀 بدء تشغيل مصنع Mnjnef الإخباري بذكاء التمويه...")

def generate_article(original_text):
    url = "https://api.mistral.ai/v1/chat/completions"
    headers = {
        "Content-Type": "application/json",
        "Authorization": f"Bearer {MISTRAL_API_KEY}"
    }
    
    prompt = f"Act as a senior journalist and editor-in-chief for a premium global news agency. Rewrite the following text into a highly professional, engaging, and comprehensive news article strictly in English. \nRules:\n1. Do NOT copy-paste the original text.\n2. Completely rephrase using a sophisticated journalistic tone.\n3. Create an engaging headline.\n4. Break the article into readable paragraphs with structural subheadings.\n\nOriginal Text: {original_text}"
    
    data = {
        "model": "open-mistral-nemo", 
        "messages": [{"role": "user", "content": prompt}],
        "temperature": 0.7
    }
    
    response = requests.post(url, headers=headers, json=data)
    if response.status_code == 200:
        return response.json()['choices'][0]['message']['content']
    return None

while True:
    try:
        feed = feedparser.parse(RSS_URL)
        latest_entry = feed.entries[0]
        title = latest_entry.title
        link = latest_entry.link
        
        safe_title = re.sub(r'[^a-z0-9]+', '-', title.lower()).strip('-')
        file_path = os.path.join(OUTPUT_DIR, f"{safe_title}.md")
        
        if not os.path.exists(file_path):
            print(f"\n-> 📰 جاري صياغة خبر جديد: {title}")
            
            article = Article(link)
            article.download()
            article.parse()
            full_text = article.text if len(article.text) > 100 else latest_entry.description
            
            new_content = generate_article(full_text)
            
            if new_content:
                hugo_date = datetime.now().astimezone().isoformat()
                clean_title = title.replace('"', "'")
                final_file = f"---\ntitle: \"{clean_title}\"\ndate: {hugo_date}\ndraft: false\n---\n\n{new_content}\n"
                
                with open(file_path, "w", encoding="utf-8") as f:
                    f.write(final_file)
                
                print(f"✅ تم نشر المقال بنجاح وحفظه في السيرفر!")
        else:
            print("⏳ لا يوجد خبر جديد في المصدر حالياً.")
            
    except Exception as e:
        print(f"⚠️ خطأ مؤقت: {e}")
        
    wait_time = random.randint(120, 300)
    print(f"💤 التمويه الذكي: الانتظار لمدة {wait_time} ثانية قبل الخبر القادم...\n")
    time.sleep(wait_time)
