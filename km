        return (
            f"You are the Pulitzer-winning Editor-in-Chief for 'Mnjnef', an elite global news network. "
            f"Rewrite this {cat_name} report into a completely original, engaging, and comprehensive article in English.\n\n"
            "STRICT RULES:\n"
            "1. FIRST LINE MUST BE EXACTLY: 'TITLE: [Your Compelling Headline]'\n"
            "2. Below the title, output the full article body.\n"
            "3. DO NOT copy the original text. Paraphrase entirely using an authoritative, objective tone.\n"
            "4. Organize with professional Markdown subheadings (##).\n"
            "5. NO conversational filler (e.g., 'Here is the article'). ONLY the title and body.\n\n"
            f"--- ORIGINAL TEXT ---\n{text}\n--- END ORIGINAL TEXT ---"
        )

    def rewrite_content(self, category: str, text: str) -> Optional[Dict[str, str]]:
        prompt = self._craft_prompt(category, text)
        payload = {
            "model": MnjnefConfig.MODEL,
            "messages": [{"role": "user", "content": prompt}],
            "temperature": MnjnefConfig.AI_TEMPERATURE,
            "max_tokens": MnjnefConfig.MAX_AI_TOKENS
        }

        for attempt in range(MnjnefConfig.MAX_RETRIES):
            try:
                resp = requests.post(MnjnefConfig.API_URL, headers=self.headers, json=payload, timeout=120)
                if resp.status_code == 200:
                    raw_content = resp.json()['choices'][0]['message']['content'].strip()
                    return self._parse_ai_response(raw_content)
                elif resp.status_code == 429:
                    delay = MnjnefConfig.BASE_RETRY_DELAY * (attempt + 2) * 3
                    logger.warning(f"Rate limited (429). Cooling AI Core for {delay}s...")
                    time.sleep(delay)
                    continue
                else:
                    logger.error(f"AI API Error {resp.status_code}: {resp.text}")
            except requests.exceptions.RequestException as e:
                logger.error(f"Network error to AI Core: {e}")
            
            sleep_time = MnjnefConfig.BASE_RETRY_DELAY * (2 ** attempt)
            time.sleep(sleep_time)
            
        logger.error("AI Generation utterly failed after all retries.")
        return None

    def _parse_ai_response(self, raw_text: str) -> Dict[str, str]:
        lines = raw_text.split('\n')
        title = "Exclusive Mnjnef Global Report"
        body_lines = []
        
        for i, line in enumerate(lines):
            clean_line = line.strip()
            if clean_line.upper().startswith("TITLE:"):
                title = clean_line[6:].replace('"', '').strip()
            elif i == 0 and not clean_line.startswith('#') and len(clean_line) < MnjnefConfig.MAX_TITLE_LENGTH:
                title = clean_line.replace('"', '').strip()
            else:
                body_lines.append(line)
                
        body = '\n'.join(body_lines).strip()
        if title.startswith("#"):
            title = title.replace("#", "").strip()
            
        return {"title": title, "body": body}

