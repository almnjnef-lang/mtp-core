    def shutdown_handler(self, signum, frame):
        logger.info("\n🛑 Core shutdown initiated. Saving states...")
        self.is_running = False

    def validate_environment(self) -> bool:
        if MnjnefConfig.API_KEY == "ضع_مفتاحك_السري_هنا" or not MnjnefConfig.API_KEY:
            logger.critical("MISTRAL API KEY MISSING. Execution halted.")
            return False
        return SystemMonitor.check_disk_space()

    def process_single_cycle(self):
        category, feed_url = FeedDatabase.get_random_source()
        logger.info(f"Target Vector: [{category}]")
        
        try:
            feed = feedparser.parse(feed_url)
            if not feed.entries:
                return

            entry = feed.entries[0]
            link = entry.link
            
            if self.db.is_processed(link):
                logger.debug("Article already exists in Titan Database. Skipping.")
                return

            logger.info(f"Acquiring Raw Intelligence: {entry.title[:50]}...")
            raw_text = self.scraper.extract_text(link, getattr(entry, 'description', ''))
            
            if len(raw_text) < MnjnefConfig.MIN_ARTICLE_LENGTH:
                logger.warning("Data insufficient for synthesis.")
                return

            logger.info("Transmitting to Mistral AI Core...")
            ai_data = self.ai.rewrite_content(category, raw_text)
            
            if not ai_data:
                return

            final_title = ai_data['title']
            final_body = ai_data['body']
            
            logger.info(f"Securing Copyright-Free Visuals for: {category}")
            image_url, img_source = FreeImageBank.fetch_image(category, final_title)
            
            # Generate SEO Tags
            keywords = SEOEngine.extract_keywords(final_title + " " + final_body)
            seo_tags_str = "Mnjnef, Global News, " + category.replace('_', ' ') + ", " + ", ".join(keywords)

            # Build Record
            record = ArticleRecord(
                url=link,
                title=final_title,
                category=category,
                seo_tags=seo_tags_str,
                image_source=img_source
            )
            
            # Save and Deploy
            if self.hugo.write_markdown(record, final_body, image_url):
                self.db.save_record(record)
                self.hugo.build_and_deploy()
                
        except Exception as e:
            logger.error(f"Cycle failure: {str(e)}")
            logger.debug(traceback.format_exc())

    def run_forever(self):
        if not self.validate_environment():
            sys.exit(1)
            
        logger.info("Titan Engine entering perpetual autonomous mode.")
        
        while self.is_running:
            self.process_single_cycle()
            
            if not self.is_running:
                break
                
            sleep_time = random.randint(MnjnefConfig.MIN_WAIT_SECONDS, MnjnefConfig.MAX_WAIT_SECONDS)
            logger.info(f"Tactical Cooling: Engine resting for {sleep_time}s...\n")
            
            for _ in range(sleep_time):
                if not self.is_running:
                    break
                time.sleep(1)

