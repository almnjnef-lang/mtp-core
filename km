cat << 'REPLACE_SCRIPT' > /root/update_translator.py
import os, re

file_path = '/root/titan_seo_engine.py'
if os.path.exists(file_path):
    with open(file_path, 'r', encoding='utf-8') as f:
        content = f.read()

    # الأداة الذكية العائمة مع اللغات العالمية فقط
    new_translator = """
                <!-- Floating Smart Translator -->
                <div id="translator-widget" style="position: fixed; bottom: 20px; right: 20px; z-index: 9999; background: white; padding: 10px; border-radius: 50px; box-shadow: 0 4px 15px rgba(0,0,0,0.15); border: 2px solid #3182ce; transition: all 0.3s; overflow: hidden; max-height: 40px; display: flex; align-items: center; cursor: pointer;" onclick="this.style.maxHeight='200px'; this.style.borderRadius='15px'; this.onclick=null;">
                    <span style="font-size: 24px; margin-right: 10px;">🌐</span>
                    <div id="google_translate_element"></div>
                </div>
                <script type="text/javascript">
                    function googleTranslateElementInit() {{
                        // تحديد اللغات العالمية والمهمة فقط
                        new google.translate.TranslateElement({{pageLanguage: 'en', includedLanguages: 'ar,es,fr,de,ru,zh-CN,hi,pt,ja,tr,it', layout: google.translate.TranslateElement.InlineLayout.SIMPLE}}, 'google_translate_element');
                    }}
                </script>
                <script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
    """

    # استبدال الأداة القديمة بالجديدة في كود المحرك
    content = re.sub(r'<div class="translator">.*?</div>.*?<script.*?</script>', new_translator, content, flags=re.DOTALL)
    
    with open(file_path, 'w', encoding='utf-8') as f:
        f.write(content)
REPLACE_SCRIPT

python3 /root/update_translator.py

