        id: supTheme
        // Brighter dark theme for maximum readability
        property color bgPrimary: "#0B132B" // Brightened deep blue background
        property color bgPanel: "#131C31"   // Distinct panel color
        property color bgElevated: "#1A2642"// Hover state color
        property color bgInput: "#0A0F1C"   // Dark inset color
        
