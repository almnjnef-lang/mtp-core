# 1. إيقاف المحرك
systemctl stop mnjnef_direct

# 2. حذف كل المقالات القديمة المعطوبة ذات التصميم السيء
rm -rf /var/www/html/articles/*
rm -rf /var/www/mnjnef.com/articles/*

# 3. تصفير واجهة الموقع (حذف الروابط القديمة)
echo "[]" > /var/www/html/recent.json
cp /var/www/html/recent.json /var/www/mnjnef.com/recent.json

# 4. تفريغ كاش السيرفر وإعادة تشغيل المحرك ليبدأ بنشر مقال جديد بالتصميم الفخم
systemctl restart nginx
systemctl restart mnjnef_direct

echo "✅ تم تنظيف السيرفر من المقالات القديمة بنجاح! جاري نشر أول مقال بالتصميم الجديد..."
