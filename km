# 1. إيقاف المحرك مؤقتاً
systemctl stop mnjnef_titan 2>/dev/null

# 2. بناء وتشغيل أداة الإصلاح الذكية
cat << 'EOF' > /root/fix_key.py
import urllib.request, json, sys, os, re

print("==================================================")
print("🔑 أداة الإصلاح الذكية لمفتاح الذكاء الاصطناعي")
print("==================================================")

# طلب المفتاح وتنظيفه من المسافات المخفية تلقائياً
key = input("👉 الصق مفتاح Gemini الخاص بك هنا ثم اضغط Enter: ").strip()

if not key or len(key) < 20:
    print("❌ المفتاح قصير جداً أو فارغ. يرجى التأكد من نسخه بالكامل.")
    sys.exit(1)

print("⏳ جاري فحص المفتاح مع سيرفرات جوجل...")
try:
    url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={key}"
    data = json.dumps({"contents": [{"parts": [{"text": "Hello"}]}]}).encode('utf-8')
    req = urllib.request.Request(url, data=data, headers={'Content-Type': 'application/json'})
    urllib.request.urlopen(req)
    print("✅ المفتاح سليم 100% وتم قبوله من جوجل!")
    
    # حقن المفتاح في المحرك التيتاني
    if os.path.exists('/root/titan_core.py'):
        with open('/root/titan_core.py', 'r') as f:
            content = f.read()
        content = re.sub(r'API_KEY\s*=\s*"[^"]*"', f'API_KEY = "{key}"', content)
        with open('/root/titan_core.py', 'w') as f:
            f.write(content)
        print("✅ تم زرع المفتاح النظيف في المحرك بنجاح.")
    else:
        print("❌ لم يتم العثور على المحرك التيتاني! يرجى تنفيذ كود التأسيس السابق أولاً.")
        sys.exit(1)
        
except Exception as e:
    print(f"❌ جوجل ترفض المفتاح! السبب: {e}")
    print("💡 يرجى التأكد من نسخ المفتاح الصحيح والفعّال من Google AI Studio.")
    sys.exit(1)
EOF

python3 /root/fix_key.py

# 3. إذا نجح الفحص، يتم إطلاق الإمبراطورية فوراً
if [ $? -eq 0 ]; then
    echo "🚀 جاري تشغيل المحرك التيتاني..."
    systemctl start mnjnef_titan
    echo "✅ المحرك يعمل الآن! جاري عرض البث المباشر (اضغط Ctrl+C للخروج من البث لاحقاً):"
    journalctl -u mnjnef_titan -f
fi
