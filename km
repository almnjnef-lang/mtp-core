import hashlib
import hmac
import time

# ==========================================
# ALMNJNEF ECONOMY SHIELD - MIDDLEWARE
# ==========================================
# This file intercepts all financial requests 
# to validate, decrypt, and sanitize data 
# before reaching the economy_core.py

SECRET_KEY = b"almnjnef_super_secret_key_2026"

def generate_secure_token(player_id):
    """Generates a time-based secure token for valid transactions."""
    timestamp = str(int(time.time())).encode('utf-8')
    message = player_id.encode('utf-8') + timestamp
    signature = hmac.new(SECRET_KEY, message, hashlib.sha256).hexdigest()
    return f"{signature}.{timestamp.decode('utf-8')}"

def validate_transaction_request(player_id, provided_token):
    """Validates if the incoming financial request is genuine and not replayed."""
    try:
        signature, timestamp_str = provided_token.split('.')
        request_time = int(timestamp_str)
        current_time = int(time.time())
        
        # Check if token is expired (e.g., older than 30 seconds -> Replay Attack)
        if current_time - request_time > 30:
            print(f"[SECURITY ALERT] Expired token from {player_id}. Possible replay attack blocked.")
            return False
            
        # Verify the signature
        expected_message = player_id.encode('utf-8') + timestamp_str.encode('utf-8')
        expected_signature = hmac.new(SECRET_KEY, expected_message, hashlib.sha256).hexdigest()
        
        if hmac.compare_digest(expected_signature, signature):
            print(f"[SHIELD PASSED] Verified secure transaction for {player_id}.")
            return True
        else:
            print(f"[SECURITY ALERT] Invalid signature from {player_id}. Transaction rejected.")
            return False
            
    except Exception as e:
        print(f"[SECURITY ERROR] Malformed token format: {e}")
        return False

