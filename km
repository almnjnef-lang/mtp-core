class KnowledgeExtractor:
    """
    Interfaces via Safe Fail-Safe Overlays with Verified Academic Baseline Repositories.
    Retrieves Extensive Descriptive Lexical Context Arrays as Seeds for Generation Layers.
    """
    @staticmethod
    def hunt_academic_data(topic_query):
        try:
            search_url = f"https://en.wikipedia.org/w/api.php?action=query&list=search&srsearch={quote(topic_query)}&utf8=&format=json"
            req = NetworkStealthShield.get_secure_request(search_url)
            with urlopen(req, timeout=15) as response:
                raw_data = json.loads(response.read().decode('utf-8'))
            
            search_results = raw_data.get('query', {}).get('search', [])
            if not search_results:
                return None, ""
            
            target_title = search_results[0]['title']
            
            content_url = f"https://en.wikipedia.org/w/api.php?action=query&prop=extracts&exlimit=1&titles={quote(target_title)}&explaintext=1&format=json"
            req_content = NetworkStealthShield.get_secure_request(content_url)
            with urlopen(req_content, timeout=15) as res_content:
                content_data = json.loads(res_content.read().decode('utf-8'))
            
            pages_map = content_data.get('query', {}).get('pages', {})
            if not pages_map:
                return target_title, ""
            
            page_id = list(pages_map.keys())[0]
            extract_text = pages_map[page_id].get('extract', '')
            return target_title, extract_text
            
        except Exception as network_error:
            logging.warning(f"⚠️ [EXTRACTION INTERRUPT] Content retrieval failed for context: {network_error}")
            return None, ""

