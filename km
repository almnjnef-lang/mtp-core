        with open(f"{d}{url}", "w") as f: f.write(f"<html><head><meta http-equiv='refresh' content='0; url=/'></head><body>Redirecting...</body></html>")
save_db(db_init)
build_homepage()

# حلقة 20 ثانية
while True:
    generate_article()
    time.sleep(20.0)
EOF

