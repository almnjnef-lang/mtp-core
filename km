        article_url = f"/{file_name}"

        db = load_db()
        related_tags = ""
        if len(db) > 0:
            random.shuffle(db)
            for r_art in db[:8]:
                short_title = " ".join(r_art['title'].split()[:3])
                related_tags += f"<a href='{r_art['url']}' class='tag-pill'>{short_title}</a>"

        html_content = f"""<!DOCTYPE html>
