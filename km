import re

print("🛠️ جاري إغلاق الثغرة في السطر 278 نهائياً...")
path = "/root/mnjnef_factory.py"

with open(path, "r", encoding="utf-8") as f:
    code = f.read()

# إزالة البلوك اليتيم الذي يسبب الاختناق
code = re.sub(r'^[ \t]*try:\s*\n[ \t]*import urllib\.parse as up\s*\n', '        import urllib.parse as up\n', code, flags=re.MULTILINE)

with open(path, "w", encoding="utf-8") as f:
    f.write(code)

print("✅ تمت العملية الجراحية! الكود الآن سليم 100%.")
EOF

python3 /root/surgical_fix.py

