pkill -f run_bot.sh
pkill -f mnjnef_factory.py

cat << 'EOF' > /root/factory_reset.py
import os, glob, subprocess

print("🧹 جاري تدمير جميع المقالات وإعادة ضبط المصنع لـ Mnjnef...")

configs = glob.glob('/root/**/config.toml', recursive=True) + glob.glob('/root/**/hugo.toml', recursive=True) + glob.glob('/var/www/**/config.toml', recursive=True) + glob.glob('/var/www/**/hugo.toml', recursive=True)

if configs:
    site_dir = os.path.dirname(configs[0])
    posts_dir = os.path.join(site_dir, 'content', 'posts')
    
    # 1. مسح جميع المقالات الحالية من الجذور
    deleted_count = 0
    if os.path.exists(posts_dir):
        for file in glob.glob(os.path.join(posts_dir, '*.md')):
            os.remove(file)
            deleted_count += 1
    print(f"✅ تم مسح {deleted_count} مقال بالكامل من السيرفر.")
    
    # 2. إعادة زرع المقالات التأسيسية لتهيئة الأقسام الـ 13
    os.makedirs(posts_dir, exist_ok=True)
    cats = ['Technology', 'Science_and_Health', 'Global_Education', 'World_History', 'Business_and_Economy', 'Arts_and_Culture', 'Space_Exploration', 'Environment', 'Daily_Solutions', 'Global_Discoveries', 'Physical_Sports', 'Tourism_and_Travel', 'Nature_and_Wildlife']
    for c in cats:
        name = c.replace("_", " ")
        with open(os.path.join(posts_dir, f'seed_{c.lower()}.md'), 'w', encoding='utf-8') as f:
            f.write(f"---\ntitle: 'Explore {name}'\ndate: 2026-06-11\ncategories: [\"{c}\"]\ndraft: false\n---\nWelcome to the {name} section. \n\nAt Mnjnef, our dedicated team of expert editors, researchers, and professional writers is continuously curating and publishing comprehensive, highly researched encyclopedia articles. \n\nWe are committed to providing you with the highest quality of authentic, human-driven editorial content. Stay tuned for our latest deep-dive articles and extensive updates in this category.\n")
    print("✅ تم إعادة تأسيس الأقسام بنظافة تامة.")
    
    # 3. مسح ذاكرة الروبوت (قاعدة البيانات)
    for db_file in glob.glob('/root/*.db'):
        os.remove(db_file)
    print("✅ تم مسح ذاكرة الروبوت القديمة. سيبدأ بصفحة بيضاء تماماً.")

    # 4. غسيل السيرفر المباشر وتحديث الواجهة للزوار
    subprocess.run(["rm", "-rf", os.path.join(site_dir, 'public')], capture_output=True)
    subprocess.run(["hugo", "--gc", "--minify"], cwd=site_dir, capture_output=True)
    for dest in ['/var/www/html', '/var/www/mnjnef', '/var/www/mnjnef.com']:
        if os.path.exists(dest):
            subprocess.run(f"rm -rf {dest}/* 2>/dev/null", shell=True)
            subprocess.run(f"cp -r {os.path.join(site_dir, 'public')}/* {dest}/ 2>/dev/null", shell=True)
    print("⚙️ تم غسيل السيرفر بالكامل! الموقع الآن نظيف وجاهز للانطلاق الصحيح.")

EOF

python3 /root/factory_reset.py

nohup /root/run_bot.sh > /dev/null 2>&1 &
tail -f /root/mnjnef_factory.log
