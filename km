pkill -f run_bot.sh
pkill -f the_king_commander.sh
pkill -f mnjnef_factory.py

cat << 'EOF' > /root/fix_try_except.py
import re

print("🛠️ جاري الكي الجراحي لسطر الخطأ 278...")
path = "/root/mnjnef_factory.py"

with open(path, "r", encoding="utf-8") as f:
    code = f.read()

# البحث عن كلمة try اليتيمة التي تسبق import urllib وتغليفها بشكل صحيح
code = re.sub(r'([ \t]*)try:\s*\n([ \t]*)import urllib\.parse as up', r'\1try:\n\2import urllib.parse as up\n\1except Exception:\n\2pass', code)

with open(path, "w", encoding="utf-8") as f:
    f.write(code)

print("✅ تم إغلاق الثغرة البرمجية بنجاح!")
EOF

python3 /root/fix_try_except.py

