class MnjnefConfig:
    API_KEY: str = "ضع_مفتاحك_السري_هنا"
    
    API_URL: str = "https://api.mistral.ai/v1/chat/completions"
    MODEL: str = "open-mistral-nemo"
    AI_TEMPERATURE: float = 0.50  # تقليل الحرارة لضمان ترابط منطقي عالي جداً للمقال
    MAX_AI_TOKENS: int = 3500
    
