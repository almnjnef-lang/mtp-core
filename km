import time
import hmac
import hashlib
import os

# ==========================================
# ALMNJNEF UNIFIED AUTH & TOKEN WARDEN
# ==========================================
# This microservice handles secure session token 
# generation and validation to prevent Session Hijacking.

class TokenWarden:
    def __init__(self, token_expiry_seconds=900):
        # Default expiry is 900 seconds (15 minutes)
        self.expiry_time = token_expiry_seconds
        # In a real production environment, this secret must be hidden in an environment variable (.env)
        self.server_secret = b"almnjnef_core_engine_secret_2026_xyz"
        self.active_sessions = {}

    def generate_session_token(self, username):
        """Generates a secure, time-limited token for a verified user."""
        timestamp = int(time.time())
        # Add random salt to make every token unique even for the same user
        salt = os.urandom(8).hex()
        
        # Build the payload
        payload = f"{username}:{timestamp}:{salt}"
        
        # Create a cryptographic signature
        signature = hmac.new(
            self.server_secret, 
            payload.encode('utf-8'), 
            hashlib.sha256
        ).hexdigest()
        
        # Combine payload and signature to form the final token
        final_token = f"{payload}:{signature}"
        
        # Store in active memory
        self.active_sessions[username] = final_token
        print(f"[AUTH WARDEN] Generated new secure token for user: {username}")
        return final_token

    def validate_token(self, username, client_token):
        """Validates if the provided token is authentic, belongs to the user, and is not expired."""
        try:
            # Check if user actually has an active session
            if username not in self.active_sessions or self.active_sessions[username] != client_token:
                print(f"[AUTH ALERT] Token mismatch or no active session for {username}!")
                return False

            parts = client_token.split(':')
            if len(parts) != 4:
                return False
                
            token_user, token_time_str, token_salt, token_signature = parts
            token_time = int(token_time_str)
            current_time = int(time.time())

            # 1. Check Expiry
            if current_time - token_time > self.expiry_time:
                print(f"[AUTH ALERT] Expired token used by {username}. Forcing re-login.")
                del self.active_sessions[username]
                return False

            # 2. Verify Cryptographic Signature (Anti-Tamper)
            expected_payload = f"{token_user}:{token_time_str}:{token_salt}"
            expected_signature = hmac.new(
                self.server_secret, 
                expected_payload.encode('utf-8'), 
                hashlib.sha256
            ).hexdigest()

            if hmac.compare_digest(expected_signature, token_signature):
                return True
            else:
                print(f"[AUTH ALERT] Forged token signature detected from {username}!")
                return False

        except Exception as e:
            print(f"[AUTH ERROR] Token processing failed: {e}")
            return False

