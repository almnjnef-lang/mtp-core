import sqlite3
import hashlib
import os

class AlmnjnefDatabase:
    def __init__(self, db_name='almnjnef_master.db'):
        self.conn = sqlite3.connect(db_name)
        self.cursor = self.conn.cursor()
        self.setup_tables()

    def setup_tables(self):
        # تحديث الجدول ليتحمل الحجم الكبير لكلمات المرور المشفرة
        self.cursor.execute('''
        CREATE TABLE IF NOT EXISTS secure_players (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            username TEXT UNIQUE NOT NULL,
            password_hash BLOB NOT NULL,
            salt BLOB NOT NULL,
            almnjnef_coins INTEGER DEFAULT 0
        )
        ''')
        self.conn.commit()

    def hash_password(self, password, salt=None):
        # إنشاء "ملح" عشوائي إذا كان هذا تسجيلاً جديداً
        if salt is None:
            salt = os.urandom(16)
        # استخدام خوارزمية pbkdf2_hmac الاحترافية بـ 100 ألف دورة تشفير
        pwd_hash = hashlib.pbkdf2_hmac('sha256', password.encode('utf-8'), salt, 100000)
        return pwd_hash, salt

    def register_player(self, username, password):
        try:
            pwd_hash, salt = self.hash_password(password)
            self.cursor.execute('''
            INSERT INTO secure_players (username, password_hash, salt, almnjnef_coins) 
            VALUES (?, ?, ?, ?)
            ''', (username, pwd_hash, salt, 500)) # منح 500 عملة كهدية ترحيبية
            self.conn.commit()
            return True, f"Player '{username}' registered securely!"
        except sqlite3.IntegrityError:
            return False, f"Username '{username}' is already taken."

    def verify_login(self, username, password):
        self.cursor.execute('SELECT password_hash, salt FROM secure_players WHERE username = ?', (username,))
        record = self.cursor.fetchone()
        
        if record is None:
            return False, "Login Failed: Username not found."
            
        stored_hash, salt = record
        # تشفير الكلمة المدخلة بنفس الملح القديم ومقارنتها
        input_hash, _ = self.hash_password(password, salt)
        
        if input_hash == stored_hash:
            return True, "Login Successful! Welcome to Almnjnef."
        else:
            return False, "Login Failed: Incorrect password."

# --- اختبار نظام التشفير ---
db = AlmnjnefDatabase()

print("--- Registering New Player ---")
success, msg = db.register_player("ProGamer2026", "MySecretPassword123!")
