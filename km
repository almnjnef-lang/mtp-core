# 🧠 MISTRAL AI ENGINE (TEXT REWRITING)
# ==============================================================================
class AIEngine:
    """Handles communication with Mistral AI with robust error handling."""
    
    def __init__(self, api_key: str):
        self.api_key = api_key
        self.headers = {
            "Content-Type": "application/json",
            "Authorization": f"Bearer {self.api_key}"
        }

    def _craft_prompt(self, category: str, text: str) -> str:
        """Constructs a strict, highly professional journalism prompt."""
        return (
            f"Act as an elite, Pulitzer-winning Editor-in-Chief for the premium global news network 'Mnjnef'. "
            f"Your objective is to rewrite the following {category.replace('_', ' ')} news report into a completely original, "
            f"highly engaging, and comprehensive article in fluent English.\n\n"
            "STRICT MANDATORY RULES:\n"
            "1. Output exactly one compelling headline at the very top, prefixed with 'TITLE: '.\n"
            "2. Under the title, output the full article body.\n"
            "3. Do NOT copy original sentences. Rephrase everything using a sophisticated journalistic tone.\n"
            "4. Organize the text logically with professional Markdown subheadings (##).\n"
            "5. NO introductory conversational filler (e.g., 'Here is the article'). NO concluding remarks.\n"
            "6. Output ONLY the title line and the article text.\n\n"
            f"--- ORIGINAL TEXT ---\n{text}\n--- END ORIGINAL TEXT ---"
        )

    def rewrite_content(self, category: str, text: str) -> Optional[Dict[str, str]]:
        """Sends data to AI and parses the headline and body."""
        prompt = self._craft_prompt(category, text)
        payload = {
            "model": MnjnefConfig.MODEL,
            "messages": [{"role": "user", "content": prompt}],
            "temperature": MnjnefConfig.AI_TEMPERATURE,
            "max_tokens": MnjnefConfig.MAX_AI_TOKENS
        }

        for attempt in range(MnjnefConfig.MAX_RETRIES):
            try:
                logger.debug(f"AI Request Attempt {attempt + 1}/{MnjnefConfig.MAX_RETRIES}")
                response = requests.post(MnjnefConfig.API_URL, headers=self.headers, json=payload, timeout=90)
                
                if response.status_code == 200:
                    raw_content = response.json()['choices'][0]['message']['content'].strip()
                    return self._parse_ai_response(raw_content)
                elif response.status_code == 429:
                    logger.warning("Rate limit exceeded (429). Backing off heavily.")
                    time.sleep(MnjnefConfig.BASE_RETRY_DELAY * (attempt + 2) * 2)
                else:
                    logger.error(f"AI API Error {response.status_code}: {response.text}")
                    
            except requests.exceptions.RequestException as e:
                logger.error(f"Network error communicating with AI: {e}")
            
            if attempt < MnjnefConfig.MAX_RETRIES - 1:
                sleep_time = MnjnefConfig.BASE_RETRY_DELAY * (2 ** attempt)
                logger.info(f"Retrying AI request in {sleep_time} seconds...")
                time.sleep(sleep_time)
                
        logger.error("AI Generation completely failed after all retries.")
        return None

    def _parse_ai_response(self, raw_text: str) -> Dict[str, str]:
        """Separates the AI-generated TITLE from the BODY text."""
        lines = raw_text.split('\n')
        title = "Mnjnef Exclusive Report"
        body_lines = []
        
        for i, line in enumerate(lines):
            if line.upper().startswith("TITLE:"):
                title = line[6:].replace('"', '').strip()
            elif i == 0 and len(line) < 150 and not line.startswith('#'):
                title = line.replace('"', '').strip()
            else:
                body_lines.append(line)
                
        body = '\n'.join(body_lines).strip()
        
        # Fallback cleanup if title extraction missed
        if title.startswith("#"):
            title = title.replace("#", "").strip()
            
        return {"title": title, "body": body}

