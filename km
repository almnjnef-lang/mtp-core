import socket

HOST = '127.0.0.1'
PORT = 7777

USERNAME = "Founder"
PASSWORD = "Core2026"

client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
print(f"Connecting to Almnjnef Server as '{USERNAME}'...")

try:
    client.connect((HOST, PORT))
    login_packet = f"{USERNAME},{PASSWORD}"
    client.sendall(login_packet.encode('utf-8'))
    response = client.recv(1024).decode('utf-8')
    status, message = response.split('|')

    if status == "SUCCESS":
        print(f"\n[SERVER ACCEPTED] -> {message}")
    else:
        print(f"\n[SERVER REJECTED] -> {message}")
except ConnectionRefusedError:
    print("Server is offline.")
finally:
    client.close()
