name: Auto News Bot
on:
  schedule:
    - cron: '*/5 * * * *'
  workflow_dispatch:

permissions:
  contents: write

jobs:
  update_news:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      
      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'
          
      - name: Install Dependencies
        run: |
          python -m pip install --upgrade pip
          pip install feedparser newspaper3k lxml_html_clean google-generativeai
          
      - name: Run AI Journalist Scraper
        env:
          GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}
        run: python auto_news.py
        
      - name: Commit and Push
        run: |
          git config --global user.name "Mnjnef Bot"
          git config --global user.email "bot@mnjnef.com"
          git add content/posts/
          git commit -m "Auto-published AI-rewritten expert articles" || echo "No new articles"
          git push
