        .logo {{ font-size: 1.5em; font-weight: 800; color: #1e3a8a; text-decoration: none; letter-spacing: -0.5px; }}
        .home-btn {{ background: #f3f4f6; color: #4b5563; padding: 8px 16px; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 0.9em; border: 1px solid #e5e7eb; transition: 0.2s; }}
