        'wouldn', 'you', 'your', 'yours', 'yourself', 'yourselves', 'will', 'also', 'said', 'new', 'one'
    }

    @classmethod
    def compile_seo_matrix(cls, title: str, narrative_body: str) -> Tuple[str, str]:
        """Extracts key phrases and creates a brief site description snippet."""
        
        # 1. Keyword Extraction
        # Tokenize words, convert to lowercase, filter out non-alphabetic and stop words
        compiled_lexicon = re.findall(r'\b[a-zA-Z]{4,}\b', narrative_body.lower())
        statistical_map = {}
        
        for singular_term in compiled_lexicon:
            if singular_term not in cls.ENGLISH_STOP_WORDS:
                statistical_map[singular_term] = statistical_map.get(singular_term, 0) + 1
                
        # Sort by frequency and take top 8
        ordered_terms = sorted(statistical_map.items(), key=lambda node: node[1], reverse=True)
        top_keywords = [node[0] for node in ordered_terms[:8]]
        
        # Fallback keywords if extraction fails
        if not top_keywords:
            top_keywords = ["mnjnef", "news", "technology", "analysis", "global", "report"]
            
        keywords_csv = ", ".join(top_keywords)
        
        # 2. Meta Description Generation
        # Remove markdown headers and formatting, take first 155 characters
        clean_abstract = re.sub(r'#+', '', narrative_body)
        clean_abstract = re.sub(r'\*+', '', clean_abstract)
        clean_abstract = clean_abstract.replace('\n', ' ').strip()
        
        meta_description = clean_abstract[:155] + "..." if len(clean_abstract) > 155 else clean_abstract
        
        return keywords_csv, meta_description


