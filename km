                        font.pixelSize: 13
                        font.bold: true
                        font.family: supTheme.fontMono
                        font.letterSpacing: 1.0
                    }

                    Rectangle {
                        Layout.fillWidth: true
                        Layout.preferredHeight: serverNodesModel.count * 80
                        radius: 12
                        color: supTheme.bgPanel
                        border.color: supTheme.borderDefault
                        border.width: 1
                        clip: true

                        ListView {
                            anchors.fill: parent
                            model: serverNodesModel
                            interactive: false
                            
                            delegate: Rectangle {
                                width: ListView.view.width
                                height: 80
                                color: "transparent"
                                
                                Rectangle {
                                    width: parent.width - 32
                                    height: 1
                                    anchors.bottom: parent.bottom
                                    anchors.horizontalCenter: parent.horizontalCenter
                                    color: supTheme.borderDefault
                                    visible: index < serverNodesModel.count - 1
                                }

                                ColumnLayout {
                                    anchors.fill: parent
                                    anchors.margins: 16
                                    spacing: 8
                                    
                                    RowLayout {
                                        Layout.fillWidth: true
                                        
                                        Text { 
                                            text: node; 
                                            color: status === "MAINTENANCE" ? supTheme.textMuted : supTheme.textHeader; 
                                            font.pixelSize: 14; 
                                            font.bold: true; 
                                            font.family: supTheme.fontMono 
                                        }
                                        
                                        Item { Layout.fillWidth: true }
                                        
                                        Text { 
                                            text: status; 
                                            color: {
                                                if (status === "OPTIMAL") return supTheme.stateSuccess;
                                                if (status === "STABLE") return supTheme.accentCore;
                                                if (status === "MAINTENANCE") return supTheme.textMuted;
                                                return supTheme.stateWarning;
                                            }
                                            font.pixelSize: 11; 
                                            font.bold: true; 
                                            font.family: supTheme.fontMono 
                                        }
                                    }
                                    
                                    Rectangle {
                                        Layout.fillWidth: true
                                        Layout.preferredHeight: 8
                                        radius: 4
                                        color: supTheme.bgInput
                                        clip: true
                                        
                                        Rectangle {
                                            width: (load / 100) * parent.width
                                            height: parent.height
                                            radius: 4
                                            color: {
                                                if (load === 0) return "transparent";
                                                if (load < 50) return supTheme.stateSuccess;
                                                if (load < 80) return supTheme.accentCore;
                                                return supTheme.stateWarning;
                                            }
                                            Behavior on width { NumberAnimation { duration: 300 } }
                                        }
                                    }
                                    
                                    RowLayout {
                                        Layout.fillWidth: true
                                        Text { text: qsTr("Load: ") + load + "%"; color: supTheme.textMuted; font.pixelSize: 11; font.family: supTheme.fontMono }
                                        Item { Layout.fillWidth: true }
                                        Text { text: ping === 999 ? "ERR" : ping + "ms"; color: supTheme.textMuted; font.pixelSize: 11; font.family: supTheme.fontMono }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ==========================================
    // LOGIC CONTROLLERS & TIMERS
    // ==========================================
    QtObject {
        id: sysController
        
        function updateClock() {
            let d = new Date();
            let h = d.getHours().toString().padStart(2, '0');
            let m = d.getMinutes().toString().padStart(2, '0');
            let s = d.getSeconds().toString().padStart(2, '0');
            supportMainRoot.currentTimeString = h + ":" + m + ":" + s;
        }
        
        function simulateTelemetry() {
            for (let i = 0; i < serverNodesModel.count; i++) {
                let nodeStatus = serverNodesModel.get(i).status;
                if (nodeStatus !== "MAINTENANCE") {
                    let currentLoad = serverNodesModel.get(i).load;
                    let loadChange = Math.floor((Math.random() * 8) - 4);
                    let finalLoad = currentLoad + loadChange;
                    if (finalLoad > 99) finalLoad = 99;
                    if (finalLoad < 10) finalLoad = 10;
                    serverNodesModel.setProperty(i, "load", finalLoad);
                    
                    let pingChange = Math.floor((Math.random() * 4) - 2);
                    let currentPing = serverNodesModel.get(i).ping;
                    let finalPing = currentPing + pingChange;
                    if (finalPing < 5) finalPing = 5;
                    serverNodesModel.setProperty(i, "ping", finalPing);
                }
            }
        }
    }

    Timer {
        id: globalClockTimer
        interval: 1000
        repeat: true
        running: true
        onTriggered: sysController.updateClock()
    }
    
    Timer {
        id: telemetryTimer
        interval: 2500
        repeat: true
        running: true
        onTriggered: sysController.simulateTelemetry()
    }
    
    Component.onCompleted: {
        sysController.updateClock();
    }
}
