# 1. تغيير الواجهة الفاضحة فوراً بواجهة احترافية بشرية
cat << 'HTML' > /var/www/html/index.html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Mnjnef Global Encyclopedia</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; text-align: center; padding: 100px 20px; background: #f8f9fa; color: #2d3748; }
        h1 { font-size: 2.8em; color: #1a365d; margin-bottom: 20px; }
        p { font-size: 1.2em; color: #4a5568; line-height: 1.6; max-width: 600px; margin: 0 auto; }
        .loader { border: 4px solid #e2e8f0; border-top: 4px solid #3182ce; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 40px auto; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <h1>Mnjnef Encyclopedia</h1>
    <p>Our editorial team is currently updating the global knowledge database with new academic research. The platform will be fully accessible shortly.</p>
    <div class="loader"></div>
</body>
</html>
HTML

# 2. تعميم الواجهة الاحترافية على كل المجلدات
cp /var/www/html/index.html /var/www/mnjnef.com/index.html
chown -R www-data:www-data /var/www/html /var/www/mnjnef.com

# 3. تنظيف ملفات السيرفر من أي كلمة تفضح الذكاء الاصطناعي
sed -i 's/The AI Engine is currently generating/Our editorial team is currently preparing/g' /root/direct_mistral_engine.py 2>/dev/null
sed -i 's/AI Core/Editorial Board/g' /root/direct_mistral_engine.py 2>/dev/null

# 4. إعادة إطلاق السيرفر بصمت
systemctl restart mnjnef_direct 2>/dev/null

echo "✅ تم مسح الفضيحة! افتح موقعك الآن ستجده احترافياً جداً وخالياً من أي ذكر للذكاء الاصطناعي."
