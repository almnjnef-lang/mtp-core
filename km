# تعديل إعدادات الموقع لفرض اللون الأبيض وإخفاء المصباح
cat << 'EOF' > /root/mnjnef_site/hugo.toml
baseURL = 'https://mnjnef.com/'
languageCode = 'en-us'
title = 'Mnjnef - Global Discoveries'
theme = 'PaperMod'

[params]
hideHugoCredits = true
defaultTheme = "light"
disableThemeToggle = true

[[menu.main]]
identifier = "privacy"
name = "Privacy Policy"
url = "/privacy/"
weight = 10
EOF

# بناء الموقع من جديد ورفعه للواجهة لترى التغيير فوراً
cd /root/mnjnef_site
hugo --minify
rm -rf /var/www/html/*
cp -r public/* /var/www/html/
chmod -R 755 /var/www/html/
