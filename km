    except: return []

def save_db(data):
    # نحتفظ بآخر 150 مقال لتبقى الصفحة الرئيسية سريعة
    for d in DIRS:
        os.makedirs(d, exist_ok=True)
        with open(f"{d}/{DB_NAME}", "w") as f: json.dump(data[:150], f)

