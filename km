                    color: contactTheme.bgPanel
                    radius: 16
                    border.color: contactTheme.borderDefault
                    border.width: 1
                    clip: true

                    // Simulated Map Graphic
                    Item {
                        anchors.fill: parent
                        anchors.margins: 20

                        Text {
                            anchors.top: parent.top
                            anchors.left: parent.left
                            text: qsTr("GLOBAL ROUTING INFRASTRUCTURE")
                            color: contactTheme.textMuted
                            font.pixelSize: 11
                            font.bold: true
                            font.family: contactTheme.fontMono
                            z: 10
                        }

                        Canvas {
                            id: mapCanvas
                            anchors.fill: parent
                            
                            onPaint: {
                                var ctx = getContext("2d");
                                ctx.clearRect(0, 0, width, height);
                                
                                // Draw connections
                                ctx.strokeStyle = contactTheme.borderHighlight;
                                ctx.lineWidth = 1;
                                ctx.globalAlpha = 0.3;
                                
                                var originX = width * 0.65; // DXB
                                var originY = height * 0.45;
                                
                                for(var i=0; i<supportNodesModel.count; i++) {
                                    var node = supportNodesModel.get(i);
                                    if(node.nodeName !== "Dubai (DXB)") {
                                        ctx.beginPath();
                                        ctx.moveTo(originX, originY);
                                        // Curve logic
                                        var endX = width * node.coordsX;
                                        var endY = height * node.coordsY;
                                        ctx.quadraticCurveTo(width*0.5, height*0.2, endX, endY);
                                        ctx.stroke();
                                    }
                                }
                            }
                        }

