# 🔍 SEO & METADATA GENERATOR
# ==============================================================================
class SEOEngine:
    # قائمة كلمات التوقف العربية الشائعة لاستبعادها من الكلمات المفتاحية
    STOP_WORDS = {
        'في', 'من', 'على', 'إلى', 'أن', 'عن', 'مع', 'هذا', 'هذه', 'التي', 'الذي',
        'تم', 'كان', 'كيف', 'هل', 'أو', 'ما', 'لا', 'لقد', 'بعد', 'قبل', 'وقد'
    }
    
    @classmethod
    def generate_metadata(cls, title: str, text: str) -> Tuple[str, str]:
        """يستخرج الكلمات المفتاحية ووصف الميتا لمحركات البحث"""
        # 1. استخراج الكلمات المفتاحية
        words = re.findall(r'\b[\w]{4,}\b', text)
        word_counts = {}
        for w in words:
            if w not in cls.STOP_WORDS and not w.isnumeric():
                word_counts[w] = word_counts.get(w, 0) + 1
        sorted_words = sorted(word_counts.items(), key=lambda x: x[1], reverse=True)
        keywords = ", ".join([w for w, c in sorted_words[:6]])
        
        # 2. استخراج وصف الميتا (أول 150 حرف من المقال)
        clean_text = re.sub(r'#+', '', text).strip()
        clean_text = clean_text.replace('\n', ' ')
        meta_desc = clean_text[:150] + "..." if len(clean_text) > 150 else clean_text
        
        return keywords, meta_desc

# ==============================================================================
# 🏗️ HUGO DEPLOYMENT & MARKDOWN GENERATION
# ==============================================================================
class HugoDeployer:
    def write_markdown(self, category: str, data: Dict[str, str], image_url: str, timestamp_id: int) -> bool:
        title = data['title']
        body = data['body']
        
        # إنشاء اسم ملف نظيف (Slug) للرابط
        safe_title_for_slug = re.sub(r'[^\w\s-]', '', title).strip().lower()
        slug_text = re.sub(r'[-\s]+', '-', safe_title_for_slug)[:50]
        slug = f"{slug_text}-{timestamp_id}" if slug_text else f"post-{timestamp_id}"
        filepath = os.path.join(MnjnefConfig.POSTS_DIR, f"{slug}.md")
        
        hugo_date = datetime.now().astimezone().isoformat()
        clean_cat = category.replace('_', ' ')
        safe_title = title.replace('"', "'")
        
        # توليد SEO
        keywords_str, meta_desc = SEOEngine.generate_metadata(title, body)
        tags_list = ["منجنيف", clean_cat] + [k.strip() for k in keywords_str.split(',') if k.strip()]
        tags_formatted = '", "'.join(tags_list)
        safe_meta_desc = meta_desc.replace('"', "'")
        
        # بناء ترويسة المقال (Frontmatter) الاحترافية
        frontmatter = [
            "---", 
            f"title: \"{safe_title}\"", 
            f"date: {hugo_date}", 
            "draft: false",
            "author: \"افتتاحية Mnjnef\"", 
            f"description: \"{safe_meta_desc}\"",
            f"categories: [\"{clean_cat}\"]", 
            f"tags: [\"{tags_formatted}\"]",
            "cover:", 
            f"  image: \"{image_url}\"", 
            "  relative: false", 
            "---", 
            "", 
            body
        ]
        
        try:
            with open(filepath, "w", encoding="utf-8") as f: 
                f.write("\n".join(frontmatter))
            return True
        except IOError as e: 
            logger.error(f"Markdown Write Error: {e}")
            return False

    def deploy(self):
        """يبني الموقع الثابت عبر Hugo وينقله لمجلد النشر Nginx"""
        cmd = f"cd {MnjnefConfig.BASE_DIR} && hugo --minify > /dev/null 2>&1 && rm -rf {MnjnefConfig.HTML_DIR}* && cp -r public/* {MnjnefConfig.HTML_DIR} && chmod -R 755 {MnjnefConfig.HTML_DIR}"
        exit_code = os.system(cmd)
        if exit_code != 0:
            logger.error("Hugo build or deployment failed!")

# ==============================================================================
# 🏭 THE TITAN ENGINE: ORCHESTRATION & MAIN LOOP
# ==============================================================================
class MnjnefTitanEngine:
    def __init__(self):
        self.db = DatabaseManager(MnjnefConfig.DB_PATH)
        self.ai = MistralAIEngine(MnjnefConfig.API_KEY)
        self.hugo = HugoDeployer()
        self.is_running = True
        
        # التقاط أوامر الإيقاف من السيرفر لإغلاق آمن
        signal.signal(signal.SIGINT, self.shutdown)
        signal.signal(signal.SIGTERM, self.shutdown)

    def shutdown(self, signum, frame): 
        logger.info("\n🛑 Received shutdown signal. Stopping engine safely...")
        self.is_running = False

    def fetch_and_parse_feed(self) -> Optional[Tuple[str, str, str, str]]:
        """اختيار مصدر عشوائي وسحب المحتوى الخام"""
        category = random.choice(list(MNJNEF_SOURCES.keys()))
        feed_url = random.choice(MNJNEF_SOURCES[category])
        
        try:
            feed = feedparser.parse(feed_url)
            if not feed.entries: return None
            
            # أخذ أول خبر في القائمة
            entry = feed.entries[0]
            link = entry.link
            
            if self.db.is_processed(link): 
                return None # تم نشره مسبقاً
            
            logger.info(f"📥 Scraping: {entry.title[:60]}...")
            
            # استخراج النص النظيف للمقال
            art = Article(link, keep_article_html=False)
            art.download()
            art.parse()
            
            # إذا كان النص قصيراً جداً، نحاول أخذ الوصف من RSS
            text = art.text.strip()
            if len(text) < 150: 
                raw_desc = getattr(entry, 'description', '')
                text = BeautifulSoup(raw_desc, "html.parser").get_text().strip()
                
            if len(text) < 100:
                logger.warning("Article text too short. Skipping.")
                return None
                
            return category, link, entry.title, text
            
        except Exception as e:
            # التجاهل الصامت لأخطاء المصادر الميتة
            pass
        return None

    def cycle(self):
        """دورة حياة نشر خبر واحد (سحب -> ذكاء اصطناعي -> صورة -> نشر)"""
        feed_data = self.fetch_and_parse_feed()
        if not feed_data:
            return
            
        category, link, original_title, text = feed_data
        
        # 1. إرسال النص للذكاء الاصطناعي للمعالجة الحازمة
        ai_data = self.ai.process_article(text)
        if not ai_data:
            return
            
        # 2. توليد وتحميل الصورة المطابقة باستخدام الوصف الإنجليزي الدقيق
        timestamp_id = int(time.time())
        img_local_path = ImageEngine.download_image(ai_data['image_prompt'], timestamp_id)
        
        # 3. كتابة المقال ونشره
        if self.hugo.write_markdown(category, ai_data, img_local_path, timestamp_id):
            self.db.save_record(link, ai_data['title'], category)
            self.hugo.deploy()
            logger.info(f"✅ SUCCESSFULLY PUBLISHED: {ai_data['title']}")

    def run(self):
        """التشغيل الأبدي للمصنع"""
        if not MnjnefConfig.API_KEY or MnjnefConfig.API_KEY == "ضع_مفتاحك_السري_هنا": 
            logger.critical("API Key is missing! Engine cannot start.")
            return
            
        logger.info("="*60)
        logger.info("🚀 MNJNEF ULTIMATE ENGINE IS LIVE (V15.0 - Absolute Reality)")
        logger.info("="*60)
        
        while self.is_running:
            self.cycle()
            
            if not self.is_running: 
                break
                
            # فاصل زمني عشوائي صارم للحماية والتمويه
            sleep_duration = random.randint(MnjnefConfig.MIN_WAIT_SECONDS, MnjnefConfig.MAX_WAIT_SECONDS)
            logger.info(f"💤 Shield Active: Waiting {sleep_duration} seconds...")
            
            for _ in range(sleep_duration):
                if not self.is_running: break
                time.sleep(1)

if __name__ == "__main__":
    # إنشاء المجلدات المطلوبة إذا لم تكن موجودة
    os.makedirs(MnjnefConfig.POSTS_DIR, exist_ok=True)
    os.makedirs(MnjnefConfig.IMG_DIR, exist_ok=True)
    
    # إطلاق المحرك
    MnjnefTitanEngine().run()
