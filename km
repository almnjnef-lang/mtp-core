import socket
import almnjnef_core

# استدعاء نواة C++ عالية الأداء
engine = almnjnef_core.AlmnjnefCore()

# إعداد خادم شبكة حقيقي (TCP Socket)
HOST = '127.0.0.1'  # عنوان الشبكة المحلية (سيتغير لاحقاً للـ IP العالمي للمنصة)
PORT = 7777         # المنفذ المخصص لاتصالات المنصة

# تهيئة وبرمجة منفذ الاتصال
server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
server.bind((HOST, PORT))
server.listen(10) # الخادم جاهز لاستقبال 10 اتصالات فعلية متزامنة كبداية

print(f"Almnjnef Dedicated Server is LIVE on {HOST}:{PORT}")
print("Engine Core is active. Listening for real connections...")

try:
    while True:
        # الخادم ينتظر الآن اتصالاً فعلياً من جهاز عميل
        client_socket, client_address = server.accept()
        print(f"[+] Real Connection Established with IP: {client_address[0]}:{client_address[1]}")

        # إرسال حزمة بيانات (Packet) حقيقية للجهاز المتصل
        client_socket.sendall(b"Connected to Almnjnef Core Engine successfully.\n")

        # إنهاء جلسة الاتصال
        client_socket.close()
except KeyboardInterrupt:
    print("\nShutting down Almnjnef Server...")
    server.close()
