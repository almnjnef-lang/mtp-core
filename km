    "Technology": ["Quantum Computing", "Cybersecurity", "Astrophysics"],
    "Business": ["Macroeconomics", "Supply Chain Management", "Investment Strategies"],
    "Science": ["Immunology", "Genetic Engineering", "Oceanography"]
}

def get_seo_fake_date():
    start = datetime(2017, 1, 1); end = datetime(2024, 1, 1)
