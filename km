import QtQuick
import QtQuick.Controls
import QtQuick.Layouts
import QtQuick.Window

ApplicationWindow {
    id: mnjnefRootWindow
    width: 1280
    height: 720
    visible: true
    title: "Mnjnef Platform - Authentication"
    
    // Global background color to prevent white flashes during transitions
    color: "#09090B" 

    // ==========================================
    // GLOBAL THEME (ENTERPRISE GRAYSCALE)
    // ==========================================
    QtObject {
        id: modernTheme
        property color bgApp: "#09090B"
        property color bgCard: "#18181B"
        property color bgInput: "#121214"
        property color bgHover: "#27272A"
        
        property color borderSubtle: "#27272A"
        property color borderFocus: "#3F3F46"
        
        property color textPrimary: "#FAFAFA"
        property color textSecondary: "#A1A1AA"
        property color textMuted: "#52525B"
        
        property color accent: "#FFFFFF"
        property color error: "#EF4444"
        property color success: "#10B981"
        
        property string fontMain: "Segoe UI"
        property string fontMono: "Consolas"
    }

    // ==========================================
    // CENTRAL ROUTING ENGINE (STACKVIEW)
    // ==========================================
    // This is the core engine that holds all pages. By anchoring it to the root,
    // all pushed children will correctly inherit the StackView.view context.
    StackView {
        id: mainRouter
        anchors.fill: parent
        initialItem: loginComponent

        // Smooth transition animations
        pushEnter: Transition {
            PropertyAnimation { property: "opacity"; from: 0.0; to: 1.0; duration: 250 }
            PropertyAnimation { property: "scale"; from: 0.98; to: 1.0; duration: 250; easing.type: Easing.OutQuad }
        }
        pushExit: Transition {
            PropertyAnimation { property: "opacity"; from: 1.0; to: 0.0; duration: 250 }
        }
        popEnter: Transition {
            PropertyAnimation { property: "opacity"; from: 0.0; to: 1.0; duration: 250 }
        }
        popExit: Transition {
            PropertyAnimation { property: "opacity"; from: 1.0; to: 0.0; duration: 250 }
            PropertyAnimation { property: "scale"; from: 1.0; to: 0.98; duration: 250; easing.type: Easing.OutQuad }
        }
    }

    // ==========================================
    // LOGIN COMPONENT (INITIAL SCREEN)
    // ==========================================
    Component {
        id: loginComponent

        Item {
            anchors.fill: parent

            Rectangle {
                anchors.fill: parent
                color: modernTheme.bgApp
            }

            // LOGIN PANEL
            Rectangle {
                id: loginPanel
                width: 440
                height: 560
                anchors.centerIn: parent
                color: modernTheme.bgCard
                radius: 12
                border.color: modernTheme.borderSubtle
                border.width: 1

                ColumnLayout {
                    anchors.fill: parent
                    anchors.margins: 40
                    spacing: 24

                    // HEADER
                    ColumnLayout {
                        Layout.fillWidth: true
                        spacing: 8
                        Layout.alignment: Qt.AlignHCenter

                        Text {
                            text: "MNJNEF"
                            color: modernTheme.textPrimary
                            font.pixelSize: 32
                            font.bold: true
                            font.family: modernTheme.fontMain
                            font.letterSpacing: 4.0
                            Layout.alignment: Qt.AlignHCenter
                        }

                        Text {
                            text: "Secure Authentication Gateway"
                            color: modernTheme.textSecondary
                            font.pixelSize: 13
                            font.family: modernTheme.fontMono
                            Layout.alignment: Qt.AlignHCenter
                        }
                    }

                    // INPUT FIELDS
                    ColumnLayout {
                        Layout.fillWidth: true
                        spacing: 16
                        Layout.topMargin: 20

                        // Username Input
                        Rectangle {
                            Layout.fillWidth: true
                            Layout.preferredHeight: 50
                            radius: 8
                            color: modernTheme.bgInput
                            border.color: usernameInput.activeFocus ? modernTheme.accent : modernTheme.borderSubtle
                            border.width: usernameInput.activeFocus ? 2 : 1
                            
                            Behavior on border.color { ColorAnimation { duration: 150 } }

                            TextInput {
                                id: usernameInput
                                anchors.fill: parent
                                anchors.margins: 16
                                color: modernTheme.textPrimary
                                font.pixelSize: 15
                                font.family: modernTheme.fontMain
                                verticalAlignment: TextInput.AlignVCenter
                                selectByMouse: true
                                
                                Text {
                                    text: "System ID / Username"
                                    color: modernTheme.textMuted
                                    font.pixelSize: 15
                                    font.family: modernTheme.fontMain
                                    visible: !usernameInput.text && !usernameInput.activeFocus
                                    anchors.verticalCenter: parent.verticalCenter
                                }
                            }
                        }

                        // Password Input
                        Rectangle {
                            Layout.fillWidth: true
                            Layout.preferredHeight: 50
                            radius: 8
                            color: modernTheme.bgInput
                            border.color: passwordInput.activeFocus ? modernTheme.accent : modernTheme.borderSubtle
                            border.width: passwordInput.activeFocus ? 2 : 1
                            
                            Behavior on border.color { ColorAnimation { duration: 150 } }

                            RowLayout {
                                anchors.fill: parent
                                anchors.margins: 16
                                spacing: 8

                                TextInput {
                                    id: passwordInput
                                    Layout.fillWidth: true
                                    Layout.fillHeight: true
                                    color: modernTheme.textPrimary
                                    font.pixelSize: 15
                                    font.family: modernTheme.fontMain
                                    verticalAlignment: TextInput.AlignVCenter
                                    echoMode: visibilityIcon.isVisible ? TextInput.Normal : TextInput.Password
                                    selectByMouse: true
                                    
                                    Text {
                                        text: "Access Key / Password"
                                        color: modernTheme.textMuted
                                        font.pixelSize: 15
                                        font.family: modernTheme.fontMain
                                        visible: !passwordInput.text && !passwordInput.activeFocus
                                        anchors.verticalCenter: parent.verticalCenter
                                    }
                                }

                                Text {
                                    id: visibilityIcon
                                    property bool isVisible: false
                                    text: isVisible ? "👁️" : "👁️‍🗨️"
                                    color: modernTheme.textMuted
                                    font.pixelSize: 14
                                    Layout.alignment: Qt.AlignVCenter
                                    
                                    MouseArea {
                                        anchors.fill: parent
                                        anchors.margins: -10
                                        cursorShape: Qt.PointingHandCursor
                                        onClicked: visibilityIcon.isVisible = !visibilityIcon.isVisible
                                    }
                                }
                            }
                        }
                    }

                    // LOGIN BUTTON
                    Rectangle {
                        id: loginBtn
                        Layout.fillWidth: true
                        Layout.preferredHeight: 50
                        Layout.topMargin: 10
                        radius: 8
                        color: {
                            if (authController.isLoggingIn) return modernTheme.borderSubtle;
                            if (loginMouse.containsPress) return modernTheme.textMuted;
                            if (loginMouse.containsMouse) return modernTheme.borderFocus;
                            return modernTheme.accent;
                        }
                        
                        Behavior on color { ColorAnimation { duration: 150 } }

                        Text {
                            anchors.centerIn: parent
                            text: authController.isLoggingIn ? "AUTHENTICATING..." : "INITIALIZE SESSION"
                            color: authController.isLoggingIn ? modernTheme.textPrimary : modernTheme.bgApp
                            font.pixelSize: 14
                            font.bold: true
                            font.family: modernTheme.fontMain
                            font.letterSpacing: 1.0
                        }

                        MouseArea {
                            id: loginMouse
                            anchors.fill: parent
                            hoverEnabled: !authController.isLoggingIn
                            cursorShape: hoverEnabled ? Qt.PointingHandCursor : Qt.ForbiddenCursor
                            onClicked: {
                                if (!authController.isLoggingIn) {
                                    authController.isLoggingIn = true;
                                    authTimer.start();
                                }
                            }
                        }
                    }

                    Item { Layout.fillHeight: true } // Spacer pushes footer down

                    // FOOTER: SUPPORT ROUTING
                    Rectangle {
                        Layout.fillWidth: true
                        Layout.preferredHeight: 1
                        color: modernTheme.borderSubtle
                    }

                    RowLayout {
                        Layout.fillWidth: true
                        Layout.preferredHeight: 30

                        Text {
                            text: "System Integrity Verified"
                            color: modernTheme.textMuted
                            font.pixelSize: 11
                            font.family: modernTheme.fontMono
                        }

                        Item { Layout.fillWidth: true }

                        // Support Routing Button
                        Text {
                            text: "Mnjnef Support"
                            color: supportMouse.containsMouse ? modernTheme.textPrimary : modernTheme.textSecondary
                            font.pixelSize: 13
                            font.bold: true
                            font.family: modernTheme.fontMain
                            
                            Behavior on color { ColorAnimation { duration: 150 } }

                            MouseArea {
                                id: supportMouse
                                anchors.fill: parent
                                anchors.margins: -8
                                hoverEnabled: true
                                cursorShape: Qt.PointingHandCursor
                                onClicked: {
                                    console.log("[ROUTING] Pushing Support_1_Main.qml onto StackView");
                                    mainRouter.push("Support_1_Main.qml");
                                }
                            }
                        }
                    }
                }
            }

            // Fake Auth Timer for UI testing
            QtObject {
                id: authController
                property bool isLoggingIn: false
            }

            Timer {
                id: authTimer
                interval: 1500
                repeat: false
                onTriggered: {
                    authController.isLoggingIn = false;
                    console.log("[AUTH] Simulating successful login.");
                    // Add routing to main platform dashboard here later
                }
            }
        }
    }
}
