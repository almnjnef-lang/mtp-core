class MnjnefTitanEngine:
    """
    Main orchestration loop. Designed to run endlessly (24/7/365).
    Handles state, traps OS signals, executes random delays, and recovers from crashes.
    """
    def __init__(self):
        logger.info("Booting Mnjnef Titan Engine components...")
        self.database = DatabaseEngine(MnjnefConfig.DB_PATH)
        self.cognitive_core = MistralCognitiveCore(MnjnefConfig.MISTRAL_API_KEY)
        self.scraper = InformationScraper()
        self.is_operational = True
        
        # OS Signal Traps for Graceful Shutdown
        signal.signal(signal.SIGINT, self._graceful_shutdown)
        signal.signal(signal.SIGTERM, self._graceful_shutdown)

    def _graceful_shutdown(self, signum, frame):
        logger.warning(f"\n[!] OS Intercept Signal ({signum}) received. Initiating safe shutdown sequence...")
        self.is_operational = False

    def execute_processing_cycle(self) -> bool:
        """
        Executes a single, complete publishing lifecycle: 
        Select -> Scrape -> Analyze/Translate -> Harvest Image -> Compile HTML.
        Returns True if a post was successfully published, False otherwise.
        """
        available_segments = list(MNJNEF_SOURCES.keys())
        if not available_segments:
            logger.error("Configuration Error: No category mappings found in mnjnef_feeds.py.")
            return False
            
        selected_segment = random.choice(available_segments)
        target_feed_array = MNJNEF_SOURCES[selected_segment]
        
        # 1. Scrape RSS Feed Metadata
        scraped_trace = self.scraper.capture_feed_payload(selected_segment, target_feed_array)
        if not scraped_trace:
            return False
            
        target_url, initial_headline, rss_desc = scraped_trace
        
        # 2. Database Anti-Duplication Check
        if self.database.is_url_registered(target_url):
            logger.debug(f"URL already processed, skipping: {target_url}")
            return False
            
        logger.info(f"Target Acquired: [{initial_headline[:50]}] -> {target_url}")
        
        # 3. Deep HTML Content Extraction
        extracted_raw_text = self.scraper.extract_deep_text(target_url, rss_desc)
        if not extracted_raw_text or len(extracted_raw_text) < 300:
            logger.warning("Extracted raw text failed length threshold validation. Discarding target.")
            return False
            
        # 4. Mistral AI Cognitive Translation & Structuring
        journalism_payload = self.cognitive_core.execute_editorial_transformation(selected_segment, extracted_raw_text)
        if not journalism_payload:
            logger.error("Mistral Cognitive Layer returned a null or invalid JSON payload.")
            return False
            
        current_cycle_timestamp = int(time.time())
        
        # 5. Multi-Library Image Harvesting
        local_image_route = ImageProviderManager.harvest_image(
            selected_segment,
            journalism_payload['image_prompt'],
            current_cycle_timestamp
        )
            
        # 6. Hugo Markdown Construction & SEO
        try:
            word_count = HugoProductionDeployer.construct_markdown_post(
                selected_segment,
                journalism_payload,
                local_image_route,
                current_cycle_timestamp
            )
            
            # 7. Commit State to Database & Deploy
            self.database.commit_article_record(target_url, journalism_payload['title'], selected_segment, word_count)
            HugoProductionDeployer.trigger_static_compilation()
            
            logger.info("+" + "-"*78 + "+")
            logger.info(f"| ✅ PUBLISHED: {journalism_payload['title'][:62]:<62} |")
            logger.info(f"| 📝 WORDS: {word_count:<4} | 🏷️ CATEGORY: {selected_segment[:20]:<20} | 🖼️ ASSET: {'YES' if local_image_route else 'NO'} |")
            logger.info("+" + "-"*78 + "+")
            
            return True
            
        except DeploymentSystemError as dse:
            logger.error(f"Deployment sequence failed: {dse}")
            return False

    def launch_engine(self):
        """
        The Main Daemon Loop. 
        Runs endlessly, manages random sleeps, and catches top-level crashes to self-heal.
        """
        logger.info("=" * 85)
        logger.info("🚀 MNJNEF TITAN AUTONOMOUS INDUSTRIAL ENGINE ONLINE (V18.0 - ENGLISH ENFORCEMENT)")
        logger.info("=" * 85)
        
        # Perform DB cleanup on startup
        self.database.cleanup_old_records()
        
        while self.is_operational:
            try:
                # Execute the publishing pipeline
                cycle_executed = self.execute_processing_cycle()
                
                # Check if system was asked to shut down during the cycle
                if not self.is_operational:
                    break
                    
                # Calculate randomized stealth delay (2 to 5 minutes)
                randomized_sleep_duration = random.randint(
                    MnjnefConfig.MIN_WAIT_SECONDS,
                    MnjnefConfig.MAX_WAIT_SECONDS
                )
                
                logger.info(f"💤 Cycle Complete. Entering operational stealth delay: {randomized_sleep_duration} seconds...")
                
                # Interruptable sleep loop
                for _ in range(randomized_sleep_duration):
                    if not self.is_operational:
                        logger.info("Sleep interrupted by shutdown signal.")
                        break
                    time.sleep(1)
                    
            except Exception as critical_crash:
                logger.critical(f"UNHANDLED EXCEPTION IN MAIN LOOP: {critical_crash}", exc_info=True)
                logger.info("Initiating 60-second crash recovery protocol (Self-Healing)...")
                
                # Sleep and recover rather than letting the script die completely
                for _ in range(60):
                    if not self.is_operational: break
                    time.sleep(1)
                    
        logger.info("🛑 Mnjnef Titan Engine has been safely powered down. Goodbye.")


