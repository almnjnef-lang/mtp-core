    def process_single_cycle(self):
        """Executes one complete lifecycle of fetching, generating, and publishing."""
        category, feed_url = FeedDatabase.get_random_source()
        logger.info(f"Targeting Matrix: [{category}] -> {feed_url}")
        
        try:
            feed = feedparser.parse(feed_url)
            if not feed.entries:
                logger.warning("Feed returned zero entries. Source might be down.")
                return

            # Grab the latest article from the feed
            latest_entry = feed.entries[0]
            original_title = latest_entry.title
            link = latest_entry.link
            description = getattr(latest_entry, 'description', '')
            
            # Check Database to prevent duplicates
            if self.db.is_processed(link):
                logger.info(f"Article already exists in Mnjnef Database: {original_title[:50]}...")
                return

            logger.info(f"Extracting Raw Data: {original_title}")
            full_text, image_url = self.scraper.extract_article(link, description)
            
            if len(full_text) < 50:
                logger.warning("Raw data insufficient for AI generation. Aborting cycle.")
                return

            logger.info("Transmitting to Mistral AI Core for rewriting...")
            ai_result = self.ai.rewrite_content(category, full_text)
            
            if not ai_result:
                logger.error("AI Core returned empty response.")
                return

            final_title = ai_result['title']
            final_body = ai_result['body']
            
            logger.info(f"AI Generation Complete. New Title: {final_title}")
            
            # Write to disk
            saved = self.hugo.write_markdown(
                category=category,
                title=final_title,
                body=final_body,
                image_url=image_url
            )
            
            if saved:
                # Update Database
                self.db.mark_processed(link, final_title, category)
                # Deploy
                self.hugo.build_and_deploy()

        except Exception as e:
            logger.error(f"Critical anomaly during processing cycle: {e}")

    def run_forever(self):
        """The infinite loop keeping the Mnjnef Empire alive."""
        if not self.check_system_health():
            sys.exit(1)
            
        logger.info("Mnjnef Engine is online and entering autonomous mode.")
        
        while self.is_running:
            self.process_single_cycle()
            
            if not self.is_running:
                break
                
            # Tactical Standby
            sleep_duration = random.randint(MnjnefConfig.MIN_WAIT_SECONDS, MnjnefConfig.MAX_WAIT_SECONDS)
            logger.info(f"Tactical Standby: Engine cooling down for {sleep_duration} seconds...\n")
            
            # Sleep in chunks to allow immediate response to Ctrl+C
            for _ in range(sleep_duration):
                if not self.is_running:
                    break
                time.sleep(1)

