import QtQuick
import QtQuick.Controls
import QtQuick.Layouts

Item {
    id: mnjnefUiLibrary
    width: 1
    height: 1
    visible: false

    // ==========================================
    // CENTRALIZED SHARED THEME PALETTE
    // ==========================================
    QtObject {
        id: gPalette
        property color primary: "#1f6feb"
        property color primaryHover: "#3b82f6"
        property color primaryPressed: "#1d4ed8"
        property color primaryGlow: "rgba(69, 137, 255, 0.4)"
        
        property color bgSurface: "#0f172a"
        property color bgInput: "#070c14"
        property color bgHover: "#1e293b"
        
        property color textMain: "#ffffff"
        property color textSub: "#94a3b8"
        property color textDark: "#0f172a"
        property color textError: "#f43f5e"
        
        property color borderDefault: "#334155"
        property color borderFocus: "#1f6feb"
        property color borderError: "#ef4444"
        
        property color stateSuccess: "#10b981"
        property color stateWarning: "#f59e0b"
    }

    // ==========================================
    // COMPONENT 1: ULTRA-PREMIUM BUTTON
    // ==========================================
    component MnjnefButton : Rectangle {
        id: btnRoot
        property string text: "Button"
        property bool isSecondary: false
        property bool isLoading: false
        property bool isButtonDisabled: false
        property int customIconType: 0 // 0: None, 1: Arrow, 2: Lock
        
        implicitWidth: 200
        implicitHeight: 50
        radius: 8
        clip: true
        
        color: {
            if (isButtonDisabled) return "#1e293b"
            if (btnMouse.containsPress) return isSecondary ? "#1e293b" : gPalette.primaryPressed
            if (btnMouse.containsMouse) return isSecondary ? "#1e293b" : gPalette.primaryHover
            return isSecondary ? "transparent" : gPalette.primary
        }
        
        border.color: {
            if (isButtonDisabled) return "#334155"
            if (isSecondary) return btnMouse.containsMouse ? gPalette.primaryHover : gPalette.borderDefault
            return "transparent"
        }
        border.width: isSecondary ? 1 : 0
        
        Behavior on color { ColorAnimation { duration: 200; easing.type: Easing.OutQuad } }
        Behavior on border.color { ColorAnimation { duration: 200 } }

        // Glow Layer for Primary Hover State
        Rectangle {
            anchors.fill: parent
            radius: parent.radius
            color: "transparent"
            border.color: gPalette.primaryGlow
            border.width: 3
            opacity: (!btnRoot.isSecondary && btnMouse.containsMouse && !btnRoot.isButtonDisabled) ? 1.0 : 0.0
            Behavior on opacity { NumberAnimation { duration: 250 } }
        }

        RowLayout {
            anchors.centerIn: parent
            spacing: 8
            opacity: btnRoot.isLoading ? 0.0 : 1.0
            Behavior on opacity { NumberAnimation { duration: 150 } }

            Text {
                text: btnRoot.text
                color: btnRoot.isButtonDisabled ? "#475569" : (btnRoot.isSecondary && btnMouse.containsMouse ? gPalette.primaryHover : gPalette.textMain)
                font.pixelSize: 14
                font.bold: true
                font.family: "Segoe UI"
                verticalAlignment: Text.AlignVCenter
                Behavior on color { ColorAnimation { duration: 150 } }
            }

            // Optional Icon Drawing
            Rectangle {
                Layout.preferredWidth: 12
                Layout.preferredHeight: 12
                color: "transparent"
                visible: btnRoot.customIconType > 0
                Layout.alignment: Qt.AlignVCenter

                Rectangle {
                    width: 6
                    height: 6
                    color: "transparent"
                    border.color: gPalette.textMain
                    border.width: 1.5
                    rotation: 45
                    x: 2
                    y: 3
                    visible: btnRoot.customIconType === 1 // Arrow Right
                    
                    Rectangle {
                        width: 6
                        height: 6
                        color: btnRoot.color
                        x: -2
                        y: -2
                    }
                }
            }
        }

        // Embedded GPU Loading Spinner
        Item {
            id: spinnerItem
            width: 22
            height: 22
            anchors.centerIn: parent
            visible: btnRoot.isLoading
            opacity: btnRoot.isLoading ? 1.0 : 0.0
            Behavior on opacity { NumberAnimation { duration: 150 } }

            Rectangle {
                anchors.fill: parent
                radius: 11
                color: "transparent"
                border.color: gPalette.textMain
                border.width: 2.5
                opacity: 0.2
            }

            Rectangle {
                anchors.fill: parent
                radius: 11
                color: "transparent"
                border.color: gPalette.textMain
                border.width: 2.5
                clip: true

                RotationAnimation on rotation {
                    loops: Animation.Infinite
                    from: 0
                    to: 360
                    duration: 800
                    running: btnRoot.isLoading
                }
            }
        }

        MouseArea {
            id: btnMouse
            anchors.fill: parent
            hoverEnabled: !btnRoot.isButtonDisabled && !btnRoot.isLoading
            cursorShape: (btnRoot.isButtonDisabled || btnRoot.isLoading) ? Qt.ForbiddenCursor : Qt.PointingHandCursor
            onClicked: {
                if (!btnRoot.isButtonDisabled && !btnRoot.isLoading) {
                    btnRoot.parent.forceActiveFocus()
                    btnRoot.clicked()
                }
            }
        }
        
        signal clicked()
    }

    // ==========================================
    // COMPONENT 2: SECURE INPUT FIELD
    // ==========================================
    component MnjnefInputField : ColumnLayout {
        id: inputRoot
        property string label: "Input Label"
        property string placeholder: "Type here..."
        property string value: txtInput.text
        property bool isInvalid: false
        property string errorText: "Required field missing"
        property bool isEncrypted: false
        property int maxCharacterLimit: 120

        spacing: 6
        Layout.fillWidth: true

        Text {
            text: inputRoot.label
            color: inputRoot.isInvalid ? gPalette.borderError : gPalette.textSub
            font.pixelSize: 13
            font.bold: true
            font.family: "Segoe UI"
            Behavior on color { ColorAnimation { duration: 150 } }
        }

        Rectangle {
            id: fieldBackground
            Layout.fillWidth: true
            Layout.preferredHeight: 48
            color: gPalette.bgInput
            radius: 8
            border.color: {
                if (inputRoot.isInvalid) return gPalette.borderError
                if (txtInput.activeFocus) return gPalette.borderFocus
                return gPalette.borderDefault
            }
            border.width: (txtInput.activeFocus || inputRoot.isInvalid) ? 2 : 1
            
            Behavior on border.color { ColorAnimation { duration: 150 } }

            TextInput {
                id: txtInput
                anchors.fill: parent
                anchors.leftMargin: 16
                anchors.rightMargin: 40
                color: gPalette.textMain
                font.pixelSize: 14
                font.family: "Segoe UI"
                verticalAlignment: TextInput.AlignVCenter
                echoMode: inputRoot.isEncrypted ? TextInput.Password : TextInput.Normal
                clip: true
                maximumLength: inputRoot.maxCharacterLimit

                Text {
                    text: inputRoot.placeholder
                    color: "#475569"
                    font.pixelSize: 14
                    font.family: "Segoe UI"
                    anchors.verticalCenter: parent.verticalCenter
                    visible: !txtInput.text && !txtInput.activeFocus
                }
                
                onTextChanged: inputRoot.valueChanged(txtInput.text)
            }

            // Inline Clear Text Action Button
            Rectangle {
                width: 18
                height: 18
                radius: 9
                color: "#1e293b"
                anchors.right: parent.right
                anchors.rightMargin: 14
                anchors.verticalCenter: parent.verticalCenter
                visible: txtInput.text.length > 0 && txtInput.activeFocus

                Text {
                    anchors.centerIn: parent
                    text: "×"
                    color: gPalette.textSub
                    font.pixelSize: 12
                    y: -1
                }

                MouseArea {
                    anchors.fill: parent
                    cursorShape: Qt.PointingHandCursor
                    onClicked: {
                        txtInput.text = ""
                        txtInput.forceActiveFocus()
                    }
                }
            }
        }

        Text {
            text: inputRoot.errorText
            color: gPalette.textError
            font.pixelSize: 12
            font.family: "Segoe UI"
            visible: inputRoot.isInvalid
            Layout.topMargin: 2
        }

        signal valueChanged(string newValue)
        
        function forceClear() {
            txtInput.text = ""
        }
        function setFocus() {
            txtInput.forceActiveFocus()
        }
    }

    // ==========================================
    // COMPONENT 3: SECURE TEXT AREA (MULTILINE)
    // ==========================================
    component MnjnefTextArea : ColumnLayout {
        id: areaRoot
        property string label: "Description Label"
        property string placeholder: "Provide comprehensive description details..."
        property string value: editInput.text
        property bool isInvalid: false
        property int maximumLength: 500

        spacing: 6
        Layout.fillWidth: true

        RowLayout {
            Layout.fillWidth: true
            
            Text {
                text: areaRoot.label
                color: areaRoot.isInvalid ? gPalette.borderError : gPalette.textSub
                font.pixelSize: 13
                font.bold: true
                font.family: "Segoe UI"
                Layout.fillWidth: true
            }
            
            Text {
                text: editInput.text.length + " / " + areaRoot.maximumLength
                color: editInput.text.length >= areaRoot.maximumLength ? gPalette.textError : gPalette.textMuted
                font.pixelSize: 11
                font.family: "Consolas"
            }
        }

        Rectangle {
            Layout.fillWidth: true
            Layout.preferredHeight: 140
            color: gPalette.bgInput
            radius: 8
            border.color: {
                if (areaRoot.isInvalid) return gPalette.borderError
                if (editInput.activeFocus) return gPalette.borderFocus
                return gPalette.borderDefault
            }
            border.width: (editInput.activeFocus || areaRoot.isInvalid) ? 2 : 1
            Behavior on border.color { ColorAnimation { duration: 150 } }

            Flickable {
                id: scrollFlick
                anchors.fill: parent
                anchors.margins: 14
                contentWidth: width
                contentHeight: editInput.implicitHeight
                clip: true
                
                TextEdit {
                    id: editInput
                    width: scrollFlick.width
                    color: gPalette.textMain
                    font.pixelSize: 14
                    font.family: "Segoe UI"
                    wrapMode: TextEdit.WordWrap
                    selectByMouse: true
                    
                    onTextChanged: {
                        if (text.length > areaRoot.maximumLength) {
                            text = text.substring(0, areaRoot.maximumLength)
                        }
                        areaRoot.valueChanged(text)
                    }

                    Text {
                        text: areaRoot.placeholder
                        color: "#475569"
                        font.pixelSize: 14
                        font.family: "Segoe UI"
                        width: editInput.width
                        wrapMode: Text.WordWrap
                        visible: !editInput.text && !editInput.activeFocus
                    }
                }
            }
        }

        signal valueChanged(string newValue)
        
        function clear() {
            editInput.text = ""
        }
    }

    // ==========================================
    // COMPONENT 4: CYBERSECURITY CHECKBOX
    // ==========================================
    component MnjnefCheckBox : RowLayout {
        id: checkRoot
        property string description: "Accept terms and system declarations."
        property bool isChecked: false
        property bool isRequiredAlert: false

        spacing: 12
        Layout.fillWidth: true

        Rectangle {
            id: checkboxBox
            Layout.preferredWidth: 22
            Layout.preferredHeight: 22
            radius: 6
            color: checkRoot.isChecked ? gPalette.primary : gPalette.bgInput
            border.color: {
                if (checkRoot.isRequiredAlert && !checkRoot.isChecked) return gPalette.borderError
                if (checkMouse.containsMouse) return gPalette.borderFocus
                return gPalette.borderDefault
            }
            border.width: checkRoot.isChecked ? 0 : 1.5
            Layout.alignment: Qt.AlignTop
            Layout.topMargin: 2
            
            Behavior on color { ColorAnimation { duration: 150 } }
            Behavior on border.color { ColorAnimation { duration: 150 } }

            // Procedural Vector Checkmark
            Item {
                anchors.fill: parent
                visible: checkRoot.isChecked
                scale: checkRoot.isChecked ? 1.0 : 0.0
                Behavior on scale { NumberAnimation { duration: 150; easing.type: Easing.OutBack } }

                Rectangle {
                    width: 2
                    height: 6
                    color: gPalette.textDark
                    rotation: -45
                    x: 6
                    y: 10
                }
                Rectangle {
                    width: 2
                    height: 11
                    color: gPalette.textDark
                    rotation: 45
                    x: 12
                    y: 5
                }
            }
        }

        Text {
            text: checkRoot.description
            color: checkRoot.isChecked ? gPalette.textMain : gPalette.textSub
            font.pixelSize: 13
            font.family: "Segoe UI"
            Layout.fillWidth: true
            wrapMode: Text.WordWrap
            lineHeight: 1.3
            Behavior on color { ColorAnimation { duration: 150 } }
        }

        MouseArea {
            id: checkMouse
            anchors.fill: parent
            hoverEnabled: true
            cursorShape: Qt.PointingHandCursor
            onClicked: {
                checkRoot.isChecked = !checkRoot.isChecked
                checkRoot.toggled(checkRoot.isChecked)
            }
        }

        signal toggled(bool checkedState)
    }

    // ==========================================
    // COMPONENT 5: SYSTEM STATE BADGE
    // ==========================================
    component MnjnefBadge : Rectangle {
        id: badgeRoot
        property string typeState: "SAFE" // SAFE, WARNING, SCANNING
        
        implicitWidth: textLabel.implicitWidth + 16
        implicitHeight: 26
        radius: 6
        
        color: {
            if (typeState === "SAFE") return "rgba(16, 185, 129, 0.15)"
            if (typeState === "WARNING") return "rgba(245, 158, 11, 0.15)"
            return "rgba(139, 92, 246, 0.15)"
        }
        
        border.color: {
            if (typeState === "SAFE") return gPalette.stateSuccess
            if (typeState === "WARNING") return gPalette.stateWarning
            return "#8b5cf6"
        }
        border.width: 1

        Text {
            id: textLabel
            anchors.centerIn: parent
            text: badgeRoot.typeState
            color: parent.border.color
            font.pixelSize: 11
            font.bold: true
            font.family: "Consolas"
        }
    }

    // ==========================================
    // COMPONENT 6: INFINITE HARDWARE SCANNER LINE
    // ==========================================
    component MnjnefLoadingLine : Item {
        id: lineRoot
        property bool isActive: false
        
        Layout.fillWidth: true
        Layout.preferredHeight: 2
        clip: true
        visible: lineRoot.isActive

        Rectangle {
            id: track
            anchors.fill: parent
            color: gPalette.borderDefault
            opacity: 0.2
        }

        Rectangle {
            id: bar
            width: parent.width * 0.4
            height: parent.height
            color: gPalette.primary
            
            SequentialAnimation on x {
                loops: Animation.Infinite
                running: lineRoot.isActive
                
                NumberAnimation {
                    from: -bar.width
                    to: lineRoot.width
                    duration: 1000
                    easing.type: Easing.InOutQuad
                }
            }
        }
    }
}
