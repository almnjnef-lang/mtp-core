                        Layout.fillWidth: true
                        Layout.preferredHeight: 40
                        color: trackTheme.bgElevated
                        
                        RowLayout {
                            anchors.fill: parent
                            anchors.leftMargin: 16
                            anchors.rightMargin: 16
                            
                            Text {
                                text: qsTr("ENCRYPTED COMM LINK")
                                color: trackTheme.textMuted
                                font.pixelSize: 11
                                font.bold: true
                                font.family: trackTheme.fontMono
                            }
                            
                            Item { Layout.fillWidth: true }
                            
