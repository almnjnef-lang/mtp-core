import socket
import json
import time
import random

HOST = '127.0.0.1'
PORT = 7777
USERNAME = "Founder"
PASSWORD = "Core2026"

client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
print(f"Connecting to Almnjnef Server as '{USERNAME}'...")

try:
    client.connect((HOST, PORT))
    
    # التعديل الهندسي: إرسال الاسم والباسوورد كنص عادي كما برمجنا السيرفر
    auth_string = f"{USERNAME},{PASSWORD}"
    client.sendall(auth_string.encode('utf-8'))
    
    # استقبال الرد من السيرفر
    response = client.recv(1024).decode('utf-8')
    
    if response.startswith("SUCCESS"):
        print(f"\n[SERVER ACCEPTED] -> {response}")
        print("[\033[93mCLIENT\033[0m] Starting 3D Movement Simulation...")
        x, y, z = 0.0, 0.0, 100.0
        
        # حلقة المزامنة الحية (Game Loop)
        while True:
            x += random.uniform(-2.0, 2.0)
            y += random.uniform(-2.0, 2.0)
            
            move_packet = {
                "action": "move",
                "player": USERNAME,
                "coords": [x, y, z]
            }
            client.sendall(json.dumps(move_packet).encode('utf-8'))
            
            # استقبال نبضة التأكيد من السيرفر
            sync_response = client.recv(1024).decode('utf-8')
            if sync_response:
                print(f"[SERVER SYNC] Data Received: {sync_response}")
            
            time.sleep(1)
    else:
        print(f"\n[SERVER REJECTED] -> {response}")

except ConnectionRefusedError:
    print("Server is offline. Start master_server.py first.")
except Exception as e:
    print(f"Error occurred: {e}")
finally:
    client.close()
