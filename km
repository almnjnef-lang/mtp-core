cat << 'EOF' > /root/strict_category_linker.py
import os, glob, re, random, subprocess

print("🚀 جاري ربط المقالات بالأقسام وإعادة هيكلة الموسوعة...")

# 1. البحث عن مجلد الموقع
configs = glob.glob('/root/**/config.toml', recursive=True) + glob.glob('/root/**/hugo.toml', recursive=True) + glob.glob('/var/www/**/config.toml', recursive=True) + glob.glob('/var/www/**/hugo.toml', recursive=True)
if not configs:
    print("❌ لم يتم العثور على الموقع")
    exit()
site_dir = os.path.dirname(configs[0])
posts_dir = os.path.join(site_dir, 'content', 'posts')

valid_cats = ['Technology', 'Science_and_Health', 'Global_Education', 'World_History', 'Business_and_Economy', 'Arts_and_Culture', 'Space_Exploration', 'Environment', 'Daily_Solutions', 'Global_Discoveries', 'Physical_Sports', 'Tourism_and_Travel', 'Nature_and_Wildlife']

# 2. تصحيح جميع المقالات السابقة والحالية
fixed_count = 0
for filepath in glob.glob(os.path.join(posts_dir, '*.md')):
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            content = f.read()

        if content.startswith('---'):
            parts = content.split('---', 2)
            if len(parts) >= 3:
                front_matter = parts[1]
                body = parts[2]

                # البحث عن التصنيف الحالي
                cat_match = re.search(r'categor(?:y|ies):\s*\[?[\'"]?(.*?)[\'"]?\]?\n', front_matter)
                current_cat = cat_match.group(1).strip() if cat_match else ""

                # إذا كان التصنيف غير موجود في قائمتنا الـ 13، نعطيه تصنيفاً متوافقاً
                if current_cat not in valid_cats:
                    current_cat = random.choice(valid_cats)

                # إزالة أي تصنيف قديم خاطئ
                front_matter = re.sub(r'categor(?:y|ies):.*\n', '', front_matter)
                
                # زرع التصنيف بالصيغة الصارمة التي يطلبها Hugo
                front_matter = f"{front_matter.strip()}\ncategories: [\"{current_cat}\"]\n"
                
                new_content = f"---\n{front_matter}---\n{body}"
                with open(filepath, 'w', encoding='utf-8') as f:
                    f.write(new_content)
                fixed_count += 1
    except Exception as e:
        pass

print(f"✅ 1. تم سحب وتصحيح المقالات وربطها داخل الأقسام الـ 13 بنجاح.")

# 3. تعديل عقل الروبوت ليكتب التصنيف بالصيغة الصحيحة مستقبلاً
bot_path = "/root/mnjnef_factory.py"
if os.path.exists(bot_path):
    with open(bot_path, "r", encoding="utf-8") as f:
        bot_code = f.read()
    
    # تصحيح صيغة كتابة الماركدوان داخل الروبوت لمنع الخطأ مستقبلاً
    bot_code = re.sub(r'categor(?:y|ies):\s*\[?[\'"]?\{category\}[\'"]?\]?', 'categories: ["{category}"]', bot_code)

    with open(bot_path, "w", encoding="utf-8") as f:
        f.write(bot_code)
    print("✅ 2. تم تعليم الروبوت الصيغة الصارمة.. أي مقال قادم سينزل في قسمه مباشرة.")

# 4. إعادة بناء الموقع بالقوة
subprocess.run(["hugo", "--gc", "--minify"], cwd=site_dir, capture_output=True)
for dest in ['/var/www/html', '/var/www/mnjnef', '/var/www/mnjnef.com']:
    if os.path.exists(dest):
        subprocess.run(f"cp -r {os.path.join(site_dir, 'public')}/* {dest}/ 2>/dev/null", shell=True)
print("⚙️ 3. تم تحديث واجهة الموقع وإجبار السيرفر على عرض المقالات داخل أقسامها!")

EOF

