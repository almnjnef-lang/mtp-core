        property color textBody: "#c9d1d9"
        property color textMuted: "#8b949e"
        
        property color borderDefault: "#30363d"
        property color borderHighlight: "#8b949e"
        
        property color stateSuccess: "#238636"
        property color stateWarning: "#d29922"
        property color stateError: "#f85149"
        property color stateInfo: "#1f6feb"
        
        property string fontMain: "Segoe UI"
        property string fontMono: "Consolas"
    }

    // ==========================================
    // DATA MODELS
    // ==========================================
    ListModel {
        id: timelineModel
        ListElement { stepIndex: 0; title: "Ticket Submitted"; desc: "Secure transmission complete"; timestamp: "10:42 AM" }
