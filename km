# 3. بناء المحرك الحقيقي (المرتبط بقواعد بيانات فعلية)
cat << 'EOF' > /root/mnjnef_real_engine.py
import os, time, random, json, subprocess
from urllib.request import urlopen, Request

print("🚀 [محرك Mnjnef الحقيقي] تم الاتصال بقواعد البيانات العالمية بنجاح...")

def fetch_real_encyclopedia():
    try:
        # جلب مقالات علمية وتاريخية حقيقية وعشوائية من قواعد بيانات مفتوحة
        url = "https://en.wikipedia.org/api/rest_v1/page/random/summary"
        req = Request(url, headers={'User-Agent': 'MnjnefGlobalBot/1.0 (Windows NT 10.0)'})
        response = urlopen(req)
        data = json.loads(response.read().decode('utf-8'))
        
        title = data.get('title', '')
        extract = data.get('extract', '')
        
        # تخطي المقالات القصيرة جداً أو الفارغة
        if not extract or len(extract) < 80:
            return 
            
        categories = ['Science_and_Health', 'World_History', 'Global_Discoveries', 'Technology']
        cat = random.choice(categories)
        
        # تصميم المقال بشكل أنيق واحترافي خالي من أي أكواد
        content = f"""---
title: "{title}"
date: {time.strftime('%Y-%m-%d')}
categories: ["{cat}"]
---

### Overview
{extract}

---
*Curated by Mnjnef Global Encyclopedia*
"""
        
        # تحديد مسار الموقع بذكاء
        site_dirs = ["/var/www/mnjnef.com", "/var/www/html", "/root/mnjnef_site"]
        active_dir = None
        for d in site_dirs:
            if os.path.exists(os.path.join(d, "config.toml")) or os.path.exists(os.path.join(d, "hugo.toml")):
                active_dir = d
                break
                
        if not active_dir:
            return

        post_path = os.path.join(active_dir, 'content', 'posts', f"real_article_{int(time.time())}.md")
        
        # حفظ المقال النظيف
        os.makedirs(os.path.dirname(post_path), exist_ok=True)
        with open(post_path, "w", encoding="utf-8") as f:
            f.write(content)
            
        print(f"📝 تم سحب وصياغة مقال حقيقي عن: {title}")

        # النشر الفوري
        subprocess.run(["hugo", "--gc", "--minify"], cwd=active_dir, capture_output=True)
        subprocess.run(f"cp -r {active_dir}/public/* /var/www/html/ 2>/dev/null", shell=True)
        subprocess.run(f"cp -r {active_dir}/public/* /var/www/mnjnef.com/ 2>/dev/null", shell=True)
        print("✅ [PUBLISHED] تم النشر على الموقع بنجاح!")
        
    except Exception as e:
        # صمت تام في حال فشل سحب مقال معين، سيحاول مرة أخرى دون إزعاج
        pass

# حلقة العمل الدائمة
while True:
    fetch_real_encyclopedia()
    # الانتظار بين 30 إلى 45 ثانية للنشر التالي
    time.sleep(random.randint(30, 45))

EOF

