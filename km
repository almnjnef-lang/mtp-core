cat << 'EOF' > /root/mnjnef_ultimate_engine.py
import os, time, random, json, subprocess
from urllib.request import urlopen, Request
from urllib.parse import quote

print("🚀 [المحرك الإمبراطوري] بدأ العمل بنظام الاقتراحات الحقيقية...")

def fetch_ultimate_article():
    try:
        # 1. جلب عنوان عشوائي
        req = Request("https://en.wikipedia.org/api/rest_v1/page/random/title", headers={'User-Agent': 'MnjnefBot/4.0'})
        res = urlopen(req)
        title = json.loads(res.read().decode())['items'][0]['title']
        
        # 2. جلب المقال الشامل
        full_url = f"https://en.wikipedia.org/w/api.php?action=query&prop=extracts&exlimit=1&titles={quote(title)}&explaintext=1&format=json"
        req_full = Request(full_url, headers={'User-Agent': 'MnjnefBot/4.0'})
        res_full = urlopen(req_full)
        pages = json.loads(res_full.read().decode())['query']['pages']
        extract = list(pages.values())[0].get('extract', '')
        
        # تخطي المقالات القصيرة جداً
        if len(extract) < 1500: return
        
        # 3. نظام الاقتراحات الحقيقي (جلب مقالات مرتبطة علمياً من ويكيبيديا)
        related_url = f"https://en.wikipedia.org/api/rest_v1/page/related/{quote(title)}"
        req_rel = Request(related_url, headers={'User-Agent': 'MnjnefBot/4.0'})
        res_rel = urlopen(req_rel)
        related_data = json.loads(res_rel.read().decode())['pages']
        
        related_markdown = ""
        for item in related_data[:3]: # سحب أفضل 3 مواضيع مرتبطة
            rel_title = item.get('title', '').replace('_', ' ')
            rel_desc = item.get('description', 'Dive deeper into this related topic.')
            related_markdown += f"* **{rel_title}**: {rel_desc}\n"
            
        clean_title = title.replace('_', ' ')
        categories = ['Scientific_Research', 'Historical_Archives', 'Global_Discoveries', 'Advanced_Technology']
        cat = random.choice(categories)
        
        # 4. دمج المقال مع الاقتراحات بتصميم فخم
        content = f"""---
title: "{clean_title}"
date: {time.strftime('%Y-%m-%d')}
categories: ["{cat}"]
---

{extract}

---
### 🔗 Explore Related Topics:
{related_markdown}

*Curated by Mnjnef Global Encyclopedia*
"""
        
        # 5. الحفظ والنشر
        site_dirs = ["/var/www/mnjnef.com", "/var/www/html", "/root/mnjnef_site"]
        active_dir = None
        for d in site_dirs:
            if os.path.exists(os.path.join(d, "config.toml")) or os.path.exists(os.path.join(d, "hugo.toml")):
                active_dir = d
                break
                
        if not active_dir: return

        post_path = os.path.join(active_dir, 'content', 'posts', f"mnjnef_ultimate_{int(time.time())}.md")
        os.makedirs(os.path.dirname(post_path), exist_ok=True)
        
        with open(post_path, "w", encoding="utf-8") as f:
            f.write(content)
            
        print(f"📖 تمت صياغة مقال شامل مع اقتراحاته: {clean_title}")

        subprocess.run(["hugo", "--gc", "--minify"], cwd=active_dir, capture_output=True)
        subprocess.run(f"cp -r {active_dir}/public/* /var/www/html/ 2>/dev/null", shell=True)
        subprocess.run(f"cp -r {active_dir}/public/* /var/www/mnjnef.com/ 2>/dev/null", shell=True)
        
        # إصلاح الصلاحيات لضمان عدم عودة خطأ 520
        subprocess.run("chown -R www-data:www-data /var/www/", shell=True, stderr=subprocess.DEVNULL)
        
        print("✅ [PUBLISHED] المقال متاح الآن بوضوح واحترافية!")
        
    except Exception as e:
        pass # تجاوز صامت للأخطاء

# حلقة العمل (مقال دسم كل 45 ثانية لتخفيف الضغط على السيرفر)
while True:
    fetch_ultimate_article()
    time.sleep(random.randint(35, 50))
EOF

