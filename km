cmake_minimum_required(VERSION 3.16)

project(Mnjnef VERSION 1.0 LANGUAGES CXX)

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_AUTOMOC ON)

# Find Qt6 components including Multimedia for audio support
find_package(Qt6 REQUIRED COMPONENTS Quick Multimedia)

qt_standard_project_setup(REQUIRES 6.5)

# Executable configuration with core C++ files
qt_add_executable(appMnjnef
    main.cpp
    authmanager.h
    authmanager.cpp
)

# QML Module configuration compiling all platform screens securely
qt_add_qml_module(appMnjnef
    URI appMnjnef
    VERSION 1.0
    QML_FILES
        Main.qml
        ContactUs.qml
        Support_1_Main.qml
        Support_2_MasterEngine.qml
        Support_3_UIComponents.qml
        Support_4_SecurityCore.qml
        Support_5_AntiBotCaptcha.qml
        Support_6_Guidelines.qml
        Support_7_OTPAuth.qml
        Support_8_TicketForm.qml
        Support_9_TicketTracker.qml
        Support_10_ResolutionFeedback.qml
        Support_11_TranslationModule.qml
)

# Link runtime libraries including the required Multimedia module
target_link_libraries(appMnjnef PRIVATE
    Qt6::Quick
    Qt6::Multimedia
)
