            logger.info("Attempting Provider 5: Unsplash Source (Open)...")
            url = f"[https://source.unsplash.com/1200x800/](https://source.unsplash.com/1200x800/)?{urllib.parse.quote(clean_category)},technology"
            if cls._download_binary(url, local_target_path):
                logger.info("Success: Asset acquired via Unsplash Source.")
                return f"/images/{filename}"
        except Exception as e:
            logger.debug(f"Provider 5 failed: {e}")

