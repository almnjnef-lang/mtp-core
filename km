        .related-card:hover {{ transform: translateX(5px); box-shadow: 0 4px 6px rgba(0,0,0,0.05); border-color: #93c5fd; }}
        .rel-badge {{ display: inline-block; font-size: 0.8em; color: #1d4ed8; background: #eff6ff; padding: 4px 10px; border-radius: 4px; font-weight: bold; text-transform: uppercase; margin-bottom: 8px; }}
        .related-card h4 {{ margin: 0; font-size: 1.2em; color: #1f2937; }}
        
        footer {{ text-align: center; padding: 40px; color: #9ca3af; margin-top: 50px; font-size: 0.9em; border-top: 1px solid #e5e7eb; }}
        @media(max-width: 600px) {{ h1 {{ font-size: 2.2em; }} header {{ padding: 15px; }} }}
    </style>
</head>
<body>
    <header><a href="/" class="logo">Mnjnef Encyclopedia</a><a href="/" class="home-btn">Library Home</a></header>
    <div class="container">
        <h1>{clean_title}</h1>
        <div class="meta">Published: {seo_date}</div>
        <div class="content">{text}</div>
        {related_html}
    </div>
    <footer>&copy; Mnjnef Encyclopedia. All Rights Reserved.</footer>
</body></html>"""

        for d in DIRS:
