#include <iostream>
#include <sys/socket.h>
#include <netinet/in.h>
#include <unistd.h>

int main() {
    // --- Phase 1: Mnjnef Core Initialization ---
    std::cout << "========================================\n";
    std::cout << "   Mnjnef Global Platform - Core V1.0   \n";
    std::cout << "========================================\n";
    std::cout << "System: High-Performance Linux Server\n";
    std::cout << "Status: Backend Initialized Successfully!\n";
    std::cout << "Waiting for Unreal Engine connections...\n";
    std::cout << "========================================\n";
    
    // --- Phase 2: System Upgrade & Port Allocation ---
    std::cout << "\n[SYSTEM UPGRADE] Initializing Core V2.0...\n";
    
    // 1. Create Connection Socket
    int server_fd = socket(AF_INET, SOCK_STREAM, 0);
    if (server_fd == 0) {
        std::cout << "[ERROR] Failed to create socket!\n";
        return -1;
    }

    // 2. Setup Port 7777 (Standard Unreal Engine Port)
    struct sockaddr_in address;
    address.sin_family = AF_INET;
    address.sin_addr.s_addr = INADDR_ANY;
    address.sin_port = htons(7777); 

    // 3. Bind Socket to the Port
    if (bind(server_fd, (struct sockaddr *)&address, sizeof(address)) < 0) {
        std::cout << "[ERROR] Bind failed! Port might be in use.\n";
        return -1;
    }

    // 4. Start Listening for Incoming Traffic
    if (listen(server_fd, 3) < 0) {
        std::cout << "[ERROR] Listen failed!\n";
        return -1;
    }

    std::cout << "[SUCCESS] Server is ONLINE and Locked on Port 7777.\n";
    std::cout << "[STATUS] Ready for Mnjnef Engine...\n";

    // 5. Infinite Loop to Keep Server Alive
    while(true) {
        sleep(1);
    }

    return 0;
}
