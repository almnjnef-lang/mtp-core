#include "AuthManager.h"
#include <iostream>
#include <string>
#include <regex>
#include <curl/curl.h>

// Validates username based on Mnjnef platform rules
bool AuthManager::ValidateUsername(const std::string& username) {
    if (username.length() < 3 || username.length() > 25) {
        std::cout << "[Error] Username must be between 3 and 25 characters.\n";
        return false;
    }
    std::regex valid_pattern("^[a-zA-Z0-9]+$");
    if (!std::regex_match(username, valid_pattern)) {
        std::cout << "[Error] Invalid characters! Emojis and special symbols are blocked.\n";
        return false;
    }
    std::cout << "[Success] Username is valid.\n";
    return true;
}

// Registers a new user to Supabase
bool AuthManager::RegisterUser(const std::string& email, const std::string& password, const std::string& username) {
    if (!ValidateUsername(username)) return false;

    CURL *curl;
    CURLcode res;
    curl_global_init(CURL_GLOBAL_ALL);
    curl = curl_easy_init();

    if(curl) {
        // ضَع رابط مشروعك هنا (بدون أن تحذف /auth/v1/signup في النهاية)
        std::string supabase_url = "YOUR_PROJECT_URL/auth/v1/signup";
        
        // ضَع مفتاح anon الخاص بك هنا
        std::string api_key = "YOUR_ANON_KEY";

        struct curl_slist *headers = NULL;
        headers = curl_slist_append(headers, ("apikey: " + api_key).c_str());
        headers = curl_slist_append(headers, "Content-Type: application/json");

        std::string json_data = "{\"email\":\"" + email + "\",\"password\":\"" + password + "\",\"data\":{\"username\":\"" + username + "\"}}";

        curl_easy_setopt(curl, CURLOPT_URL, supabase_url.c_str());
        curl_easy_setopt(curl, CURLOPT_HTTPHEADER, headers);
        curl_easy_setopt(curl, CURLOPT_POSTFIELDS, json_data.c_str());

        std::cout << "[SYSTEM] Connecting to Database...\n";
        res = curl_easy_perform(curl);

        if(res != CURLE_OK) {
            std::cout << "\n[Error] Connection failed: " << curl_easy_strerror(res) << "\n";
        } else {
            std::cout << "\n[SUCCESS] Registration request processed globally!\n";
        }

        curl_easy_cleanup(curl);
        curl_slist_free_all(headers);
    }
    curl_global_cleanup();
    return true;
}
