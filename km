import time
from collections import defaultdict

# ==========================================
# ALMNJNEF ACCOUNT DEFENDER (BRUTE-FORCE WARDEN)
# ==========================================
# This microservice protects user accounts from password 
# guessing attacks by locking out suspicious activity.
# CONFIGURATION: 10 consecutive failed attempts allowed.

class AccountDefender:
    def __init__(self, max_failed_attempts=10, lockout_duration_seconds=300):
        # Allow 10 mistakes, then lock the account/IP for 5 minutes (300 seconds)
        self.max_attempts = max_failed_attempts
        self.lockout_duration = lockout_duration_seconds
        
        # Tracks failed attempts: {"username_or_ip": count}
        self.failed_attempts = defaultdict(int)
        
        # Tracks locked targets: {"username_or_ip": unlock_timestamp}
        self.locked_targets = {}

    def process_login_attempt(self, target_id, is_successful):
        """
        Validates a login attempt. Returns True if the user is allowed to try/login,
        and False if they are currently locked out.
        """
        current_time = time.time()

        # 1. Check if the target is currently in the penalty box (Locked)
        if target_id in self.locked_targets:
            if current_time < self.locked_targets[target_id]:
                remaining_time = int(self.locked_targets[target_id] - current_time)
                print(f"[DEFENDER BLOCKED] {target_id} is LOCKED OUT. Try again in {remaining_time} seconds.")
                return False
            else:
                # Penalty time is over, remove the lock and reset attempts
                print(f"[DEFENDER RELEASED] Lock expired for {target_id}. Normal access restored.")
                del self.locked_targets[target_id]
                self.failed_attempts[target_id] = 0

        # 2. Process the login result
        if is_successful:
            # If they logged in successfully, clear their bad record
            self.failed_attempts[target_id] = 0
            return True
        else:
            # If they failed, add a strike
            self.failed_attempts[target_id] += 1
            print(f"[DEFENDER WARNING] Failed attempt {self.failed_attempts[target_id]}/{self.max_attempts} for {target_id}")
            
            # 3. Apply the lock if they hit the maximum allowed failures
            if self.failed_attempts[target_id] >= self.max_attempts:
                self.locked_targets[target_id] = current_time + self.lockout_duration
                print(f"[DEFENDER ALERT] Max attempts reached! {target_id} is now LOCKED for {self.lockout_duration} seconds.")
                return False
                
            return True

