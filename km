# 🖼️ 7. COPYRIGHT-FREE IMAGE ENGINE
# ==============================================================================
class FreeImageBank:
    """Provides 100% free images for various categories."""
    
    @staticmethod
    def fetch_image(category: str, title: str) -> Tuple[str, str]:
        query = category.replace("_", " ").split()[0]
        
        # 1. Pexels (If Key Provided)
        if MnjnefConfig.PEXELS_API_KEY and MnjnefConfig.PEXELS_API_KEY != "ضع_مفتاحك_السري_هنا":
            try:
                url = f"https://api.pexels.com/v1/search?query={query}&per_page=15"
                headers = {"Authorization": MnjnefConfig.PEXELS_API_KEY}
                resp = requests.get(url, headers=headers, timeout=10)
                if resp.status_code == 200:
                    data = resp.json()
                    if data.get('photos'):
                        photo = random.choice(data['photos'])
                        logger.info("Image secured via Pexels.")
                        return photo['src']['large'], "Pexels"
            except Exception as e:
                logger.warning(f"Pexels failed: {e}")

        # 2. Unsplash Source API (Free)
        if MnjnefConfig.UNSPLASH_ACCESS_KEY:
             try:
                u_url = f"https://api.unsplash.com/photos/random?query={query}&client_id={MnjnefConfig.UNSPLASH_ACCESS_KEY}"
                resp = requests.get(u_url, timeout=10)
                if resp.status_code == 200:
                    data = resp.json()
                    return data['urls']['regular'], "Unsplash"
             except Exception:
                 pass
                
        # 3. LoremFlickr Fallback
        safe_query = query.replace(" ", "")
        logger.info("Image secured via LoremFlickr Fallback.")
        return f"https://loremflickr.com/1200/800/{safe_query},news/all", "LoremFlickr"

