class HugoProductionDeployer:
    """Writes Markdown posts and packages assets into Nginx static layouts."""
    
    @staticmethod
    def construct_markdown_post(category: str, data: Dict[str, str], relative_img_path: str, timestamp: int) -> int:
        """Assembles frontmatter attributes and text payloads onto disk layouts."""
        
        # Generate URL-safe slug
        sanitized_slug = re.sub(r'[^\w\s-]', '', data['title']).strip().lower()
        slug_backbone = re.sub(r'[-\s]+', '-', sanitized_slug)[:60]
        filename = f"{slug_backbone}_{timestamp}.md" if slug_backbone else f"mnjnef_post_{timestamp}.md"
        absolute_output_path = os.path.join(MnjnefConfig.POSTS_DIR, filename)
        
        # Escape characters for YAML compliance
        escaped_title = data['title'].replace('"', "'").replace(':', ' -')
        keywords, meta_description = SEOMetadataCompiler.compile_seo_matrix(data['title'], data['body'])
        escaped_meta_desc = meta_description.replace('"', "'").replace('\n', ' ')
        
        clean_category = category.replace('_', ' ').title()
        
        # Formatting Tags array for YAML
        tags_array = ["Mnjnef Exclusive", clean_category] + [tag.strip().title() for tag in keywords.split(',') if tag.strip()]
        formatted_tags = '", "'.join(tags_array)
        
        # Constructing Frontmatter Block
        hugo_frontmatter_block = [
            "---",
            f'title: "{escaped_title}"',
            f'date: "{datetime.now(timezone.utc).isoformat()}"',
            "draft: false",
            'author: "Mnjnef Intelligence Desk"',
            f'description: "{escaped_meta_desc}"',
            f'categories: ["{clean_category}"]',
            f'tags: ["{formatted_tags}"]'
        ]
        
        # Only inject cover image parameter if an image was successfully downloaded
        if relative_img_path:
            hugo_frontmatter_block.extend([
                "cover:",
                f'  image: "{relative_img_path}"',
                "  relative: false"
            ])
            
        hugo_frontmatter_block.extend([
            "---",
            "",
            data['body']
        ])
        
        try:
            with open(absolute_output_path, "w", encoding="utf-8") as markdown_file:
                markdown_file.write("\n".join(hugo_frontmatter_block))
                
            calculated_words = len(data['body'].split())
            return calculated_words
        except IOError as e:
            logger.critical(f"File system serialization failed for: {absolute_output_path}. Error: {e}")
            raise DeploymentSystemError(f"Markdown engine serialization blockage: {e}")

    @staticmethod
    def trigger_static_compilation():
        """Compiles Hugo layouts into static HTML and deploys directly to Nginx."""
        logger.info("Triggering Hugo static site generator compilation...")
        
        deployment_command_chain = (
            f"cd {MnjnefConfig.BASE_DIR} && "
            f"hugo --minify > /dev/null 2>&1 && "
            f"rm -rf {MnjnefConfig.HTML_DEPLOY_DIR}* && "
            f"cp -r public/* {MnjnefConfig.HTML_DEPLOY_DIR} && "
            f"chmod -R 755 {MnjnefConfig.HTML_DEPLOY_DIR}"
        )
        
        execution_status_code = os.system(deployment_command_chain)
        if execution_status_code == 0:
            logger.info("Hugo site compiled and Nginx sync completed successfully.")
        else:
            logger.error(f"Deployment failed with system exit code: {execution_status_code}")


