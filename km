cat << 'EOF' > /root/legion_commander.py
import os, re

print("🛡️ [القيادة العليا] جاري تفعيل جيوش Mnjnef للذكاء الاصطناعي...")

path = "/root/mnjnef_factory.py"
if not os.path.exists(path):
    print("❌ خطأ: ملف المحرك غير موجود!")
    exit()

with open(path, "r", encoding="utf-8") as f:
    lines = f.readlines()

# 1. جيش الأطباء (ترميم التمزق في الكود بذكاء هندسي)
print("👨‍⚕️ [جيش الأطباء] جاري مسح السيرفر وترميم الأكواد الممزقة...")
for _ in range(3): # 3 جولات من الفحص والعلاج
    for i in range(len(lines)):
        line_strip = lines[i].strip()
        indent = len(lines[i]) - len(lines[i].lstrip())
        
        # علاج جراحي: إذا وجدنا try بدون except
        if line_strip == 'try:':
            has_except = False
            for j in range(i+1, min(i+60, len(lines))):
                j_strip = lines[j].strip()
                j_indent = len(lines[j]) - len(lines[j].lstrip())
                if j_strip.startswith('except') and j_indent == indent:
                    has_except = True
                    break
                # إذا رجعنا لسطر غير مسافات انتهى البلوك
                if j_indent < indent and j_strip != '' and not j_strip.startswith('#'):
                    break
            if not has_except:
                lines[i] = lines[i].replace('try:', 'if True: # 👨‍⚕️ Healed Try')
        
        # علاج جراحي: إذا وجدنا except بدون try
        if line_strip.startswith('except') or line_strip.startswith('finally:'):
            has_try = False
            for j in range(i-1, max(-1, i-60), -1):
                j_strip = lines[j].strip()
                j_indent = len(lines[j]) - len(lines[j].lstrip())
                if j_strip == 'try:' and j_indent == indent:
                    has_try = True
                    break
            if not has_try:
                lines[i] = " " * indent + "pass # 👨‍⚕️ Healed Except\n"

# 2. جيش الحراس (درع المحتوى الصارم)
print("💂 [جيش الحراس] جاري تفعيل قوانين النشر العلمي الصارمة...")
code = "".join(lines)

strict_rule = "Instruction: You are an elite Scientific Encyclopedia AI. STRICT RULES: 1. NEVER publish outdated news, rumors, or misleading/fake info. 2. ABSOLUTELY NO hate speech, bias, or harmful content. 3. FOCUS EXCLUSIVELY on generating highly detailed, factual, and timeless scientific, historical, and technological encyclopedia articles. 4. Maintain absolute professional neutrality."
code = re.sub(r'Instruction:.*?(?="|\')', strict_rule, code, flags=re.DOTALL)

# 3. جيش النشر (توقيت 35-70 ثانية)
print("🚀 [جيش النشر] جاري ضبط المحرك للعمل الصاروخي المتزن...")
code = re.sub(r'random\.randint\(\s*\d+\s*,\s*\d+\s*\)', 'random.randint(35, 70)', code)

# تنظيف الشوائب المتبقية
code = code.replace('}"\n', '\n').replace('}"', '')

with open(path, "w", encoding="utf-8") as f:
    f.write(code)

print("✅ تمت تهيئة جميع الجيوش بنجاح! السيرفر جاهز للانطلاق.")
EOF

