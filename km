def setup_logger() -> logging.Logger:
    """Configures industrial-grade logging to both console and file."""
    logger = logging.getLogger("MnjnefTitan")
    logger.setLevel(logging.DEBUG)
    
    formatter = logging.Formatter(
        fmt="%(asctime)s | %(levelname)-8s | %(module)-15s | %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S"
    )
    
    ch = logging.StreamHandler(sys.stdout)
    ch.setLevel(logging.INFO)
    ch.setFormatter(formatter)
    
    try:
        fh = logging.FileHandler(MnjnefConfig.LOG_FILE, encoding='utf-8')
        fh.setLevel(logging.DEBUG)
        fh.setFormatter(formatter)
        logger.addHandler(fh)
    except Exception as e:
        print(f"Warning: Could not set up file logger: {e}")
        
    logger.addHandler(ch)
    return logger

logger = setup_logger()

class SystemMonitor:
    """Monitors basic system health before running cycles."""
    
    @staticmethod
    def check_disk_space(path: str = "/") -> bool:
        """Ensures the server has enough disk space to continue."""
        try:
            statvfs = os.statvfs(path)
            free_bytes = statvfs.f_frsize * statvfs.f_bavail
            free_mb = free_bytes / (1024 * 1024)
            if free_mb < 500:  # Require at least 500MB free
                logger.critical(f"Low disk space! Only {free_mb:.2f} MB left.")
                return False
            return True
        except Exception as e:
            logger.warning(f"Could not check disk space: {e}")
            return True

