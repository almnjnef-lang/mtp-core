        """Verifies environment variables and critical paths."""
        if MnjnefConfig.API_KEY == "ضع_مفتاحك_السري_هنا" or not MnjnefConfig.API_KEY:
            logger.critical("MISTRAL API KEY IS MISSING. Engine halting.")
