# 🕷️ CONTENT SCRAPER (DATA EXTRACTION)
# ==============================================================================
class ContentScraper:
    """Advanced crawler to extract raw text and hero images from URLs."""
    
    @staticmethod
    def slugify(text: str) -> str:
        """Converts text into a safe URL slug."""
        text = text.lower()
        text = re.sub(r'[^a-z0-9]+', '-', text).strip('-')
        return text if text else f"article-{int(time.time())}"

    @staticmethod
    def extract_article(url: str, fallback_summary: str) -> Tuple[str, str]:
        """Uses newspaper3k to extract the main content and top image."""
        full_text = ""
        image_url = ""
        
        try:
            logger.debug(f"Attempting to scrape content from: {url}")
            article = Article(url, keep_article_html=False, browser_user_agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64)")
            article.download()
            article.parse()
            
            extracted_text = article.text.strip()
            if len(extracted_text) > MnjnefConfig.MIN_ARTICLE_LENGTH:
                full_text = extracted_text
            else:
                logger.warning("Extracted text too short, falling back to RSS summary.")
                full_text = fallback_summary
                
            if MnjnefConfig.ENABLE_IMAGE_EXTRACTION and article.top_image:
                image_url = article.top_image
                
        except ArticleException as e:
            logger.error(f"Article Download/Parse Error: {e}")
            full_text = fallback_summary
        except Exception as e:
            logger.error(f"Unexpected Scraping Error: {e}")
            full_text = fallback_summary
            
        # Clean fallback summary if it contains HTML
        if full_text == fallback_summary:
            full_text = re.sub(r'<[^>]+>', '', full_text)
            
        return full_text, image_url

