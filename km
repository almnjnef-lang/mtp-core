import os, time, random, json, re
import urllib.request
from urllib.parse import quote
from datetime import datetime, timedelta

API_KEY = "HKxK4S2UrTBt8ja93wkndgltN1W3UaHD"
DIRS = ["/var/www/html", "/var/www/mnjnef.com"]
CATS = {
    "Education": ["Modern Pedagogy", "Distance Learning", "Special Education", "Cognitive Load"],
    "Psychology": ["Behavioral Economics", "Emotional Intelligence", "Stress Management"],
    "Problem Solving": ["Time Management", "Effective Communication", "Critical Thinking"],
    "Technology": ["Quantum Computing", "Cybersecurity", "Astrophysics"],
    "Business": ["Macroeconomics", "Supply Chain Management", "Investment Strategies"],
    "Environment": ["Climate Change Mitigation", "Renewable Energy", "Oceanography"]
}

def get_seo_fake_date():
    start = datetime(2017, 1, 1); end = datetime(2024, 1, 1)
    return (start + timedelta(days=random.randrange((end - start).days))).strftime('%B %d, %Y')

def load_db():
    try:
        with open("/var/www/html/database.json", "r") as f: return json.load(f)
    except: return []

def save_db(data):
    for d in DIRS:
        with open(f"{d}/database.json", "w") as f: json.dump(data[:100], f)

def build_homepage():
    db = load_db()
    articles_html = ""
    for art in db:
        # تصميم مطابق تماماً للصورة: عنوان، نبذة، ثم التاريخ
        articles_html += f"""
        <a href="{art['url']}" class="card">
            <h2>{art['title']}</h2>
            <p class="snippet">{art.get('snippet', 'Read the full comprehensive educational entry inside...')}...</p>
            <div class="meta">{art['category']} &bull; {art['date']}</div>
        </a>
        """
        
    html = f"""<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mnjnef - Global Discoveries</title>
    <style>
        body {{ font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #f9fafb; margin: 0; color: #111827; }}
        header {{ background: #ffffff; padding: 25px 20px; border-bottom: 1px solid #e5e7eb; display: flex; align-items: center; justify-content: space-between; }}
        header h1 {{ margin: 0; font-size: 1.5em; color: #111827; font-weight: bold; }}
        header .policy {{ font-size: 0.9em; color: #4b5563; text-decoration: none; }}
