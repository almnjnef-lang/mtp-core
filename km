import os
import re
import time
import json
import requests
from datetime import datetime
from email.utils import parsedate_to_datetime
import feedparser
from newspaper import Article

# Get API Key
API_KEY = os.environ.get("GEMINI_API_KEY")

# News source
RSS_URL = "http://feeds.bbci.co.uk/news/world/rss.xml" 
OUTPUT_DIR = "content/posts"

if not os.path.exists(OUTPUT_DIR):
    os.makedirs(OUTPUT_DIR)

feed = feedparser.parse(RSS_URL)

for entry in feed.entries:
    title = entry.title
    link = entry.link
    
    try:
        pubDate = entry.published
        dt = parsedate_to_datetime(pubDate)
        hugo_date = dt.strftime("%Y-%m-%dT%H:%M:%S%z")
    except:
        hugo_date = datetime.now().astimezone().isoformat()

    safe_title = re.sub(r'[^a-z0-9]+', '-', title.lower()).strip('-')
    file_path = os.path.join(OUTPUT_DIR, f"{safe_title}.md")

    if not os.path.exists(file_path):
        try:
            # 1. Scrape Full Original Text
            article = Article(link)
            article.download()
            article.parse()
            full_text = article.text
            top_image = article.top_image
            
            if len(full_text) < 100:
                full_text = entry.description

            # 2. AI Journalist Rewrite (Direct Connection - Bulletproof)
            final_content = full_text
            if API_KEY:
                url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={API_KEY}"
                headers = {'Content-Type': 'application/json'}
                prompt_text = f"Act as a senior international journalist and expert news analyst. Rewrite the following news article to be unique, highly engaging, and authoritative in English. DO NOT copy-paste the original text. Create a catchy new headline, a strong opening paragraph, and well-structured body paragraphs.\n\nOriginal Article:\n{full_text}"
                
                data = {
                    "contents": [{"parts": [{"text": prompt_text}]}]
                }
                
                response = requests.post(url, headers=headers, data=json.dumps(data))
                
                if response.status_code == 200:
                    final_content = response.json()['candidates'][0]['content']['parts'][0]['text']
                    time.sleep(2)
                else:
                    print(f"API Error {response.status_code}: {response.text}")
                    print(f"Skipping {title} due to API error. Will retry later.")
                    continue # Skip saving if Google rejects it

            clean_title = title.replace('"', "'")
            
            # 3. Create the Hugo Post
            content = f"---\n"
            content += f"title: \"{clean_title}\"\n"
            content += f"date: {hugo_date}\n"
            content += f"draft: false\n"
            if top_image:
                content += f"cover:\n  image: \"{top_image}\"\n"
            content += f"---\n\n"
            content += f"{final_content}\n\n"
            content += f"---\n*Original Source: [BBC News]({link})*\n"

            with open(file_path, "w", encoding="utf-8") as f:
                f.write(content)
                
            print(f"Successfully processed and rewritten: {title}")
        except Exception as e:
            print(f"Failed to process {link}: {e}")
