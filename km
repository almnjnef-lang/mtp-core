                {"role": "user", "content": f"Verified Source Material (Process into English Analysis):\n\n{raw_text}"}
            ],
            "temperature": MnjnefConfig.AI_TEMPERATURE,
            "max_tokens": MnjnefConfig.MAX_AI_TOKENS,
            "response_format": {"type": "json_object"}
        }

        for attempt in range(MnjnefConfig.MAX_NETWORK_RETRIES):
            try:
                logger.info(f"Initiating Mistral inference sequence (Attempt {attempt + 1}/{MnjnefConfig.MAX_NETWORK_RETRIES})...")
                response = requests.post(
                    MnjnefConfig.MISTRAL_URL,
                    headers=self.headers,
                    json=payload,
                    timeout=MnjnefConfig.HTTP_TIMEOUT
                )
                
                if response.status_code == 200:
                    raw_payload = response.json()['choices'][0]['message']['content'].strip()
                    
                    # Defensively clean markdown wrappers just in case AI disobeys JSON mode strictly
                    raw_payload = re.sub(r'^```json\s*', '', raw_payload, flags=re.IGNORECASE)
                    raw_payload = re.sub(r'^```\s*', '', raw_payload)
                    raw_payload = re.sub(r'\s*```$', '', raw_payload)
                    
                    try:
                        parsed_json = json.loads(raw_payload)
                        required_keys = ['seo_headline', 'visual_ai_prompt', 'journalism_body']
                        
                        if all(k in parsed_json for k in required_keys):
                            logger.info("JSON Payload validated successfully.")
                            
                            # Validate output length to ensure it's not a stub
                            if len(str(parsed_json['journalism_body']).split()) < 100:
