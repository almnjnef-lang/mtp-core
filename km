cat << 'EOF' > /root/mnjnef_full_engine.py
import os, time, random, json, subprocess
from urllib.request import urlopen, Request
from urllib.error import URLError

print("🚀 [محرك Mnjnef الشامل] بدأ سحب المقالات العلمية الطويلة مع الاقتراحات...")

def fetch_full_article():
    try:
        # جلب عنوان عشوائي أولاً
        random_url = "https://en.wikipedia.org/api/rest_v1/page/random/title"
        req = Request(random_url, headers={'User-Agent': 'MnjnefBot/2.0'})
        response = urlopen(req)
        title_data = json.loads(response.read().decode('utf-8'))
        title = title_data.get('items', [{}])[0].get('title', '')
        
        if not title: return

        # جلب المقال الشامل بالكامل (وليس الملخص) بناءً على العنوان
        full_url = f"https://en.wikipedia.org/w/api.php?action=query&prop=extracts&exlimit=1&titles={title}&explaintext=1&format=json"
        req_full = Request(full_url, headers={'User-Agent': 'MnjnefBot/2.0'})
        res_full = urlopen(req_full)
        full_data = json.loads(res_full.read().decode('utf-8'))
        
        pages = full_data.get('query', {}).get('pages', {})
        page_id = list(pages.keys())[0]
        extract = pages[page_id].get('extract', '')
        
        # تخطي المقالات القصيرة جداً لضمان الجودة
        if len(extract) < 1000:
            return
            
        categories = ['Science_and_Health', 'World_History', 'Global_Discoveries', 'Technology']
        cat = random.choice(categories)
        clean_title = title.replace('_', ' ')
        
        # توليد 3 اقتراحات مشابهة (وهمية حالياً لربطها لاحقاً بمقالاتك، لكنها تبدو احترافية)
        related_topics = [
            f"The History of {clean_title.split()[0]}",
            f"Scientific Impacts of {clean_title[-5:]}",
            "Explore more in Global Discoveries"
        ]
        
        # تصميم المقال الطويل مع قسم الاقتراحات
        content = f"""---
title: "{clean_title}"
date: {time.strftime('%Y-%m-%d')}
categories: ["{cat}"]
---

{extract}

---
### 📚 Explore Related Topics:
* [{related_topics[0]}](/)
* [{related_topics[1]}](/)
* [{related_topics[2]}](/)

*Curated by Mnjnef Global Encyclopedia*
"""
        
        # تحديد مسار الموقع بذكاء
        site_dirs = ["/var/www/mnjnef.com", "/var/www/html", "/root/mnjnef_site"]
        active_dir = None
        for d in site_dirs:
            if os.path.exists(os.path.join(d, "config.toml")) or os.path.exists(os.path.join(d, "hugo.toml")):
                active_dir = d
                break
                
        if not active_dir: return

        post_path = os.path.join(active_dir, 'content', 'posts', f"full_article_{int(time.time())}.md")
        
        # حفظ المقال الطويل
        os.makedirs(os.path.dirname(post_path), exist_ok=True)
        with open(post_path, "w", encoding="utf-8") as f:
            f.write(content)
            
        print(f"📖 تم سحب وصياغة مقال شامل عن: {clean_title}")

        # النشر الفوري
        subprocess.run(["hugo", "--gc", "--minify"], cwd=active_dir, capture_output=True)
        subprocess.run(f"cp -r {active_dir}/public/* /var/www/html/ 2>/dev/null", shell=True)
        subprocess.run(f"cp -r {active_dir}/public/* /var/www/mnjnef.com/ 2>/dev/null", shell=True)
        print("✅ [PUBLISHED] المقال الطويل متاح الآن على الموقع!")
        
    except Exception as e:
        pass # تجاوز الأخطاء بهدوء

# حلقة العمل (مقال طويل كل 40 ثانية)
while True:
    fetch_full_article()
    time.sleep(random.randint(30, 45))

EOF

