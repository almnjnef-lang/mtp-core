# 🏗️ HUGO & NGINX AUTOMATION (DEPLOYMENT)
# ==============================================================================
class HugoDeployer:
    """Handles Markdown creation, Hugo building, and Nginx synchronization."""
    
    def __init__(self):
        if not os.path.exists(MnjnefConfig.POSTS_DIR):
            try:
                os.makedirs(MnjnefConfig.POSTS_DIR)
                logger.info(f"Created posts directory: {MnjnefConfig.POSTS_DIR}")
            except OSError as e:
                logger.critical(f"Cannot create directory {MnjnefConfig.POSTS_DIR}: {e}")
                sys.exit(1)

    def write_markdown(self, category: str, title: str, body: str, image_url: str) -> bool:
        """Constructs the Hugo-compatible Markdown file with YAML Frontmatter."""
        slug = ContentScraper.slugify(title)
        filepath = os.path.join(MnjnefConfig.POSTS_DIR, f"{slug}.md")
        
        if os.path.exists(filepath):
            # Append timestamp to avoid overwriting different articles with same slug
            filepath = os.path.join(MnjnefConfig.POSTS_DIR, f"{slug}-{int(time.time())}.md")

        hugo_date = datetime.now().astimezone().isoformat()
        safe_title = title.replace('"', "'")
        clean_cat = category.replace('_', ' ')
        
        frontmatter = [
            "---",
            f"title: \"{safe_title}\"",
            f"date: {hugo_date}",
            "draft: false",
            f"author: \"Mnjnef Engine\"",
            f"categories: [\"{clean_cat}\"]",
            f"tags: [\"Mnjnef\", \"Global News\", \"{clean_cat}\"]"
        ]
        
        if image_url:
            frontmatter.extend([
                "cover:",
                f"  image: \"{image_url}\"",
                "  alt: \"Mnjnef Cover Image\"",
                "  relative: false"
            ])
            
        frontmatter.extend(["---", "", body])
        
        try:
            with open(filepath, "w", encoding="utf-8") as f:
                f.write("\n".join(frontmatter))
            logger.info(f"Markdown successfully written: {filepath}")
            return True
        except IOError as e:
            logger.error(f"Failed to write Markdown file: {e}")
            return False

    def build_and_deploy(self) -> None:
        """Executes system commands to compile Hugo and move to Nginx."""
        if not MnjnefConfig.AUTO_DEPLOY:
            logger.info("Auto-deploy is disabled. Skipping build.")
            return
            
        logger.info("Initiating Hugo Site Build & Nginx Deployment...")
        try:
            # Command chain: cd -> build -> clean nginx -> copy -> permissions
            cmd = (
                f"cd {MnjnefConfig.BASE_DIR} && "
                f"hugo --minify > /dev/null 2>&1 && "
                f"rm -rf {MnjnefConfig.HTML_DIR}* && "
                f"cp -r public/* {MnjnefConfig.HTML_DIR} && "
                f"chmod -R 755 {MnjnefConfig.HTML_DIR}"
            )
            exit_code = os.system(cmd)
            
            if exit_code == 0:
                logger.info("✅ Mnjnef Empire successfully deployed to live server.")
            else:
                logger.error(f"Deployment failed with system exit code: {exit_code}")
        except Exception as e:
            logger.error(f"Critical error during deployment: {e}")

