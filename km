# 🏭 11. THE PURE ENGINE (MAIN CONTROLLER)
# ==============================================================================
class MnjnefPureEngine:
    def __init__(self):
        self._print_banner()
        self.db = DatabaseManager(MnjnefConfig.DB_PATH)
        self.scraper = ContentScraper()
        self.ai = AIEngine(MnjnefConfig.API_KEY)
        self.hugo = HugoDeployer()
        self.is_running = True
        
        signal.signal(signal.SIGINT, self.shutdown_handler)
        signal.signal(signal.SIGTERM, self.shutdown_handler)
        
        total_feeds = FeedDatabase.get_total_feeds()
        logger.info(f"Mnjnef Pure Engine Initialized: {total_feeds} Non-Political Sources.")

    def _print_banner(self):
        banner = """
        ==================================================
           MNJNEF PURE EDITION V5.0 - NON-POLITICAL
           TECH | SCIENCE | NATURE | CULTURE | SPORTS
        ==================================================
        """
        print(banner)

    def shutdown_handler(self, signum, frame):
        logger.info("\n🛑 Core shutdown initiated. Saving states...")
        self.is_running = False

    def validate_environment(self) -> bool:
        if MnjnefConfig.API_KEY == "ضع_مفتاحك_السري_هنا" or not MnjnefConfig.API_KEY:
            logger.critical("MISTRAL API KEY MISSING.")
            return False
        return True

    def process_single_cycle(self):
        category, feed_url = FeedDatabase.get_random_source()
        logger.info(f"Targeting: [{category}]")
        
        try:
            feed = feedparser.parse(feed_url)
            if not feed.entries: return
            entry = feed.entries[0]
            link = entry.link
            
            if self.db.is_processed(link): return

            logger.info(f"Acquiring Raw Data: {entry.title[:50]}...")
            raw_text = self.scraper.extract_text(link, getattr(entry, 'description', ''))
            
            if len(raw_text) < MnjnefConfig.MIN_ARTICLE_LENGTH: return

            logger.info("Transmitting to Mistral AI Core...")
            ai_data = self.ai.rewrite_content(category, raw_text)
            
            if not ai_data: return

            final_title = ai_data['title']
            final_body = ai_data['body']
            
            image_url, img_source = FreeImageBank.fetch_image(category, final_title)
            keywords = SEOEngine.extract_keywords(final_title + " " + final_body)
            seo_tags_str = "Mnjnef, " + category.replace('_', ' ') + ", " + ", ".join(keywords)

            record = ArticleRecord(url=link, title=final_title, category=category, seo_tags=seo_tags_str, image_source=img_source)
            
            if self.hugo.write_markdown(record, final_body, image_url):
                self.db.save_record(record)
                self.hugo.build_and_deploy()
                
        except Exception as e:
            logger.error(f"Cycle failure: {str(e)}")

    def run_forever(self):
        if not self.validate_environment(): sys.exit(1)
        logger.info("Mnjnef Pure Engine entering perpetual mode.")
        
        while self.is_running:
            self.process_single_cycle()
            if not self.is_running: break
            
            # STRICT REQUIREMENT: Random wait between 120 and 300 seconds (2 to 5 mins)
            sleep_time = random.randint(MnjnefConfig.MIN_WAIT_SECONDS, MnjnefConfig.MAX_WAIT_SECONDS)
            logger.info(f"Cooling Engine for {sleep_time}s...\n")
            
            for _ in range(sleep_time):
                if not self.is_running: break
                time.sleep(1)

