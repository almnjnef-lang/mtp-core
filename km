class ImageProviderManager:
    """
    Highly resilient media acquisition system.
    Searches across 7 different AI and Stock Photo APIs.
    Downloads the binary asset locally to guarantee zero hotlinking breakage.
    """
    
    @staticmethod
    def _download_binary(url: str, filepath: str, headers: Optional[Dict[str, str]] = None) -> bool:
        """Helper to stream and save images to local disk."""
        try:
            resp = requests.get(url, headers=headers, stream=True, timeout=20)
            if resp.status_code == 200:
                # Check Content-Type to ensure it's actually an image
                content_type = resp.headers.get('Content-Type', '')
                if 'image' not in content_type and 'octet-stream' not in content_type:
                    logger.warning(f"Invalid Content-Type received: {content_type}")
                    return False
                    
                with open(filepath, 'wb') as f:
                    for chunk in resp.iter_content(chunk_size=8192):
                        if chunk: f.write(chunk)
                        
                # Verify file size > 5KB to prevent saving 1x1 tracking pixels
                if os.path.getsize(filepath) > 5120:
                    return True
                else:
                    os.remove(filepath)
        except Exception as e:
            logger.debug(f"Binary stream failed for {url}: {e}")
        return False

    @classmethod
    def harvest_image(cls, category: str, custom_ai_prompt: str, timestamp_id: int) -> str:
        """Executes a cascading fallback sequence through multiple providers."""
        os.makedirs(MnjnefConfig.STATIC_IMG_DIR, exist_ok=True)
        filename = f"mnjnef_asset_{timestamp_id}.jpg"
        local_target_path = os.path.join(MnjnefConfig.STATIC_IMG_DIR, filename)
        
        clean_en_prompt = custom_ai_prompt.strip().replace('\n', ' ')
        clean_category = category.replace("_", " ").split()[0].lower()
        
        logger.info("Engaging Multi-Library Image Acquisition Pipeline...")

        # ---------------------------------------------------------
        # PROVIDER 1: Pollinations AI (Text-to-Image Generation)
        # ---------------------------------------------------------
        if clean_en_prompt:
            try:
                logger.info("Attempting Provider 1: Pollinations AI Generation...")
                encoded_prompt = urllib.parse.quote(clean_en_prompt)
                seed_matrix = random.randint(100000, 9999999)
                gen_url = f"[https://image.pollinations.ai/prompt/](https://image.pollinations.ai/prompt/){encoded_prompt}?width=1200&height=800&nologo=true&seed={seed_matrix}"
                if cls._download_binary(gen_url, local_target_path):
                    logger.info("Success: Asset generated via Pollinations AI.")
                    return f"/images/{filename}"
            except Exception as e:
                logger.debug(f"Provider 1 failed: {e}")

        # ---------------------------------------------------------
        # PROVIDER 2: Pexels API (Requires Key)
        # ---------------------------------------------------------
        if MnjnefConfig.PEXELS_API_KEY:
            try:
                logger.info("Attempting Provider 2: Pexels Stock API...")
                url = f"[https://api.pexels.com/v1/search?query=](https://api.pexels.com/v1/search?query=){urllib.parse.quote(clean_category)}&per_page=15"
                headers = {"Authorization": MnjnefConfig.PEXELS_API_KEY}
                res = requests.get(url, headers=headers, timeout=15)
                if res.status_code == 200 and res.json().get('photos'):
                    photo_url = random.choice(res.json()['photos'])['src']['large']
                    if cls._download_binary(photo_url, local_target_path):
                        logger.info("Success: Asset acquired via Pexels.")
                        return f"/images/{filename}"
            except Exception as e:
                logger.debug(f"Provider 2 failed: {e}")

        # ---------------------------------------------------------
        # PROVIDER 3: Unsplash API (Requires Key)
        # ---------------------------------------------------------
        if MnjnefConfig.UNSPLASH_ACCESS_KEY:
            try:
                logger.info("Attempting Provider 3: Unsplash Developer API...")
                url = f"[https://api.unsplash.com/photos/random?query=](https://api.unsplash.com/photos/random?query=){urllib.parse.quote(clean_category)}&orientation=landscape"
                headers = {"Authorization": f"Client-ID {MnjnefConfig.UNSPLASH_ACCESS_KEY}"}
                res = requests.get(url, headers=headers, timeout=15)
                if res.status_code == 200:
                    photo_url = res.json()['urls']['regular']
                    if cls._download_binary(photo_url, local_target_path, headers):
                        logger.info("Success: Asset acquired via Unsplash.")
                        return f"/images/{filename}"
            except Exception as e:
                logger.debug(f"Provider 3 failed: {e}")

        # ---------------------------------------------------------
        # PROVIDER 4: Pixabay API (Requires Key)
        # ---------------------------------------------------------
        if MnjnefConfig.PIXABAY_API_KEY:
            try:
                logger.info("Attempting Provider 4: Pixabay API...")
