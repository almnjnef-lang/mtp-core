# 🕷️ 9. RAW CONTENT SCRAPER
# ==============================================================================
class ContentScraper:
    """Advanced crawler to extract raw text safely."""
    
    @staticmethod
    def extract_text(url: str, fallback_summary: str) -> str:
        try:
            article = Article(url, keep_article_html=False, fetch_images=False)
            article.download()
            article.parse()
            text = article.text.strip()
            
            if len(text) > MnjnefConfig.MIN_ARTICLE_LENGTH:
                return text
                
            logger.warning("Scraped text too short, falling back to RSS summary.")
        except ArticleException as e:
            logger.error(f"Article parse error: {e}")
        except Exception as e:
            logger.error(f"Scraper unexpected error: {e}")
            
        # Clean fallback summary
        clean_fallback = re.sub(r'<[^>]+>', '', fallback_summary).strip()
        return clean_fallback

