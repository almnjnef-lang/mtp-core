                    }

                    MouseArea {
                        id: transMouse
                        anchors.fill: parent
                        hoverEnabled: true
                        cursorShape: Qt.PointingHandCursor
                        onClicked: {
                            if (StackView.view) {
                                StackView.view.push("Support_11_TranslationModule.qml");
                            }
