class DatabaseEngine:
    """
    Manages operational persistence, state validation, and anti-duplication guards.
    Implements multi-column indexing, vacuuming, and connection pooling.
    """
    def __init__(self, db_path: str):
        self.db_path = db_path
        self._orchestrate_lifecycle()
        
    def _connect(self) -> sqlite3.Connection:
        try:
            return sqlite3.connect(self.db_path, timeout=60.0, isolation_level=None)
        except sqlite3.Error as e:
            logger.critical(f"SQLite Connection Failure: {e}")
            raise DatabaseError(f"Database allocation failed: {e}")
            
    def _orchestrate_lifecycle(self):
        """Creates tables, injects performance indices, and optimizes DB."""
        try:
            with self._connect() as conn:
                cursor = conn.cursor()
                cursor.execute("PRAGMA journal_mode=WAL;") # Write-Ahead Logging for concurrency
                cursor.execute("PRAGMA synchronous=NORMAL;")
                
                cursor.execute("""
                    CREATE TABLE IF NOT EXISTS pure_articles (
                        id INTEGER PRIMARY KEY AUTOINCREMENT,
                        original_url TEXT UNIQUE NOT NULL,
                        published_title TEXT NOT NULL,
                        category TEXT NOT NULL,
                        word_count INTEGER NOT NULL,
                        language_origin TEXT DEFAULT 'unknown',
                        harvest_timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                    )
                """)
                cursor.execute("CREATE INDEX IF NOT EXISTS idx_original_url ON pure_articles (original_url)")
                cursor.execute("CREATE INDEX IF NOT EXISTS idx_harvest_time ON pure_articles (harvest_timestamp)")
                logger.info("Database matrix verified and PRAGMA settings optimized.")
        except sqlite3.Error as e:
            raise DatabaseError(f"Schema compilation failed: {e}")
            
    def is_url_registered(self, url: str) -> bool:
        """Guards against duplicate publication loops across runs."""
        try:
            with self._connect() as conn:
                cursor = conn.cursor()
                cursor.execute("SELECT 1 FROM pure_articles WHERE original_url = ? LIMIT 1", (url,))
                return cursor.fetchone() is not None
        except sqlite3.Error as e:
            logger.error(f"Index checking error for URL {url}: {e}")
            return False
            
    def commit_article_record(self, url: str, title: str, category: str, words: int):
        """Persists metadata once processing completes successfully."""
        try:
            with self._connect() as conn:
                cursor = conn.cursor()
                cursor.execute(
                    """
                    INSERT INTO pure_articles (original_url, published_title, category, word_count)
                    VALUES (?, ?, ?, ?)
                    """, 
                    (url, title, category, words)
                )
                logger.info(f"State block committed: '{title[:50]}...'")
        except sqlite3.IntegrityError:
            logger.warning(f"Collision trace: URL already in registry: {url}")
        except sqlite3.Error as e:
            logger.error(f"Disk write failure during state transition: {e}")

    def cleanup_old_records(self, days_old: int = 90):
        """Optional maintenance: Remove records older than X days to keep DB fast."""
        try:
            with self._connect() as conn:
                cursor = conn.cursor()
                cursor.execute("DELETE FROM pure_articles WHERE harvest_timestamp <= date('now', '-? days')", (days_old,))
                cursor.execute("VACUUM;")
        except sqlite3.Error as e:
            logger.error(f"Maintenance vacuum failed: {e}")


