# 💾 DATABASE MANAGEMENT (ANTI-DUPLICATION)
# ==============================================================================
class DatabaseManager:
    def __init__(self, db_path: str):
        self.db_path = db_path
        self._init_db()
        
    def _get_connection(self): 
        return sqlite3.connect(self.db_path, timeout=30)
        
    def _init_db(self):
        try:
            with self._get_connection() as conn:
                conn.cursor().execute("""
                    CREATE TABLE IF NOT EXISTS pure_articles (
                        id INTEGER PRIMARY KEY AUTOINCREMENT, 
                        original_url TEXT UNIQUE NOT NULL,
                        published_title TEXT NOT NULL, 
                        category TEXT NOT NULL,
                        published_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                    )
                """)
                conn.commit()
        except sqlite3.Error as e:
            logger.error(f"Database Initialization Error: {e}")
            
    def is_processed(self, url: str) -> bool:
        try:
            with self._get_connection() as conn:
                result = conn.cursor().execute(
                    "SELECT 1 FROM pure_articles WHERE original_url = ?", (url,)
                ).fetchone()
                return result is not None
        except sqlite3.Error as e:
            logger.error(f"Database Read Error: {e}")
            return False
            
    def save_record(self, url: str, title: str, category: str):
        try:
            with self._get_connection() as conn:
                conn.cursor().execute(
                    "INSERT INTO pure_articles (original_url, published_title, category) VALUES (?, ?, ?)", 
                    (url, title, category)
                )
                conn.commit()
        except sqlite3.IntegrityError:
            pass # الخبر موجود مسبقاً
        except sqlite3.Error as e:
            logger.error(f"Database Write Error: {e}")

# ==============================================================================
# 🖼️ HYPER-ACCURATE IMAGE ACQUISITION ENGINE
# ==============================================================================
class ImageEngine:
    @staticmethod
    def download_image(ai_image_prompt: str, timestamp_id: int) -> str:
        """
        يقوم بتحميل صورة مطابقة 100% للخبر بناءً على الوصف الدقيق الذي كتبه الذكاء الاصطناعي.
        """
        os.makedirs(MnjnefConfig.IMG_DIR, exist_ok=True)
        img_name = f"cover_{timestamp_id}.jpg"
        img_path = os.path.join(MnjnefConfig.IMG_DIR, img_name)
        
        # تنظيف الوصف وتهيئته للرسم
        clean_prompt = ai_image_prompt.strip().replace('\n', ' ')
        if not clean_prompt:
            clean_prompt = "Abstract highly professional modern technology background"
            
        logger.info(f"🎨 Drawing image based on prompt: {clean_prompt[:50]}...")
        
        encoded_prompt = urllib.parse.quote(clean_prompt)
        seed = random.randint(1, 9999999)
        # استخدام Pollinations AI المفتوح لرسم وتوليد الصورة بدقة عالية
        url = f"https://image.pollinations.ai/prompt/{encoded_prompt}?width=1200&height=800&nologo=true&seed={seed}"

        # المحاولة الأولى: تحميل الصورة المولدة بالذكاء الاصطناعي (أعلى دقة وترابط)
        try:
            resp = requests.get(url, timeout=MnjnefConfig.REQUEST_TIMEOUT)
            if resp.status_code == 200 and len(resp.content) > 10000: # التأكد أن الملف ليس فارغاً
                with open(img_path, 'wb') as f:
                    f.write(resp.content)
                logger.info("🖼️ Contextual AI image downloaded successfully.")
                return f"/images/{img_name}"
        except Exception as e:
            logger.warning(f"AI Image generation failed: {e}. Falling back to safe generic.")
        
        # المحاولة الثانية (الطوارئ): صورة مجانية بديلة من Picsum لضمان عدم توقف الموقع
        try:
            fallback_url = f"https://picsum.photos/seed/{timestamp_id}/1200/800"
            resp = requests.get(fallback_url, timeout=30)
            if resp.status_code == 200:
                with open(img_path, 'wb') as f:
                    f.write(resp.content)
                return f"/images/{img_name}"
        except Exception as e:
            logger.error(f"Total image failure: {e}")
            
        return "" # في أسوأ الحالات يعمل المقال بدون صورة ولا ينكسر الموقع

# ==============================================================================
# 🧠 ARTIFICIAL INTELLIGENCE CORE (REALITY ENFORCER)
# ==============================================================================
class MistralAIEngine:
    def __init__(self, api_key: str):
        self.api_key = api_key
        self.headers = {
            "Content-Type": "application/json", 
            "Authorization": f"Bearer {self.api_key}"
        }

    def process_article(self, text: str) -> Optional[Dict[str, str]]:
        """
        عقل النظام: يقرأ الخبر، يمنع الكذب، يترجمه، يصيغه، ويستنتج وصفاً دقيقاً للصورة.
        """
        prompt = (
            "أنت صحفي استقصائي ورئيس تحرير في منصة 'Mnjnef'. تم تكليفك بصياغة هذا النص بدقة متناهية.\n\n"
            "⚠️ تعليمات صارمة جداً (الالتزام بها إجباري):\n"
            "1. الواقعية المطلقة: ممنوع منعاً باتاً اختلاق، أو تأليف، أو إضافة أي معلومة غير موجودة في النص الأصلي. انقل الحقائق فقط.\n"
            "2. لا للسياسة: إذا كان النص يحتوي على سياسة، تجاهله تماماً.\n"
            "3. الصياغة: اكتب مقالاً احترافياً باللغة العربية، مترابطاً منطقياً، واستخدم عناوين فرعية (##).\n\n"
            "يجب أن يكون مخرجك (Output) مقسماً بالضبط إلى هذه الأقسام الثلاثة مع الأقواس المربعة، بدون أي كلام زائد:\n\n"
            "[TITLE]\n"
            "ضع هنا عنواناً جذاباً وحقيقياً للمقال باللغة العربية.\n\n"
            "[IMAGE_PROMPT]\n"
            "Write here a highly descriptive, realistic, 1-sentence prompt IN ENGLISH that perfectly describes the exact subject of this article. This will be used by an AI image generator to draw the cover image. Do not include text or logos in the prompt.\n\n"
            "[CONTENT]\n"
            "ضع هنا المقال الكامل باللغة العربية مع العناوين الفرعية.\n"
        )
        
        payload = {
            "model": MnjnefConfig.MODEL, 
            "messages": [
                {"role": "system", "content": prompt}, 
                {"role": "user", "content": f"النص الأصلي:\n{text}"}
            ], 
            "temperature": MnjnefConfig.AI_TEMPERATURE, 
            "max_tokens": MnjnefConfig.MAX_AI_TOKENS
        }
        
        for attempt in range(MnjnefConfig.MAX_RETRIES):
            try:
                logger.info(f"🧠 AI Processing (Attempt {attempt + 1})...")
                resp = requests.post(MnjnefConfig.API_URL, headers=self.headers, json=payload, timeout=120)
                
                if resp.status_code == 200:
                    raw_text = resp.json()['choices'][0]['message']['content'].strip()
                    return self._parse_ai_output(raw_text)
                
                elif resp.status_code == 429: 
                    logger.warning("API Rate Limit. Sleeping for 20s...")
                    time.sleep(20)
                else:
                    logger.error(f"API Error {resp.status_code}: {resp.text}")
                    
            except requests.exceptions.RequestException as e:
                logger.warning(f"Network error during AI request: {e}")
                
            time.sleep(5)
        return None

    def _parse_ai_output(self, raw_text: str) -> Optional[Dict[str, str]]:
        """
        محلل ذكي لاستخراج العنوان، وصف الصورة الإنجليزي، والمقال العربي بدقة.
        """
        try:
            # استخدام التعابير القياسية (Regex) لفصل الأقسام بدقة
            title_match = re.search(r'\[TITLE\](.*?)\[IMAGE_PROMPT\]', raw_text, re.DOTALL | re.IGNORECASE)
            image_match = re.search(r'\[IMAGE_PROMPT\](.*?)\[CONTENT\]', raw_text, re.DOTALL | re.IGNORECASE)
            content_match = re.search(r'\[CONTENT\](.*)', raw_text, re.DOTALL | re.IGNORECASE)

            if title_match and image_match and content_match:
                title = title_match.group(1).strip()
                image_prompt = image_match.group(1).strip()
                content = content_match.group(1).strip()
                
                # تنظيف إضافي للعنوان في حال أضاف الذكاء الاصطناعي نجوم أو هوامش
                title = title.replace('"', '').replace('*', '').replace('[', '').replace(']', '').strip()
                
                return {
                    "title": title,
                    "image_prompt": image_prompt,
                    "body": content
                }
            else:
                logger.error("AI output format mismatched the strict template.")
                return None
        except Exception as e:
            logger.error(f"Parsing AI output failed: {e}")
            return None

