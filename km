                                    model: 3
                                    Rectangle {
                                        width: 4
                                        height: 4
                                        radius: 2
                                        color: trackTheme.accentCore
                                        
                                        SequentialAnimation on y {
                                            loops: Animation.Infinite
                                            running: mnjnefTicketTrackerRoot.isAgentTyping
                                            NumberAnimation { from: 0; to: -4; duration: 300; easing.type: Easing.OutQuad; target: parent }
                                            NumberAnimation { from: -4; to: 0; duration: 300; easing.type: Easing.InQuad; target: parent }
                                        }
                                        
                                        Component.onCompleted: {
                                            yAnimations[index].start()
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Input Area
                    Rectangle {
                        Layout.fillWidth: true
                        Layout.preferredHeight: 80
                        color: trackTheme.bgElevated
                        
                        Rectangle {
                            width: parent.width
                            height: 1
                            anchors.top: parent.top
                            color: trackTheme.borderDefault
                        }

                        RowLayout {
                            anchors.fill: parent
                            anchors.margins: 16
                            spacing: 12

                            Rectangle {
                                Layout.fillWidth: true
                                Layout.fillHeight: true
                                color: trackTheme.bgInput
                                radius: 8
                                border.color: chatInput.activeFocus ? trackTheme.accentCore : trackTheme.borderDefault
                                border.width: 1
                                
                                Behavior on border.color { ColorAnimation { duration: 150 } }

                                TextInput {
                                    id: chatInput
                                    anchors.fill: parent
                                    anchors.margins: 12
                                    color: trackTheme.textHeader
                                    font.pixelSize: 14
                                    font.family: trackTheme.fontMain
                                    verticalAlignment: TextInput.AlignVCenter
                                    selectByMouse: true
                                    clip: true
                                    
                                    Keys.onReturnPressed: chatController.sendMessage()
                                    Keys.onEnterPressed: chatController.sendMessage()

                                    Text {
                                        text: qsTr("Transmit secure message...")
                                        color: trackTheme.textMuted
                                        font.pixelSize: 14
                                        font.family: trackTheme.fontMain
                                        visible: !chatInput.text && !chatInput.activeFocus
                                        anchors.verticalCenter: parent.verticalCenter
                                    }
                                }
                            }

                            Rectangle {
                                Layout.preferredWidth: 48
                                Layout.fillHeight: true
                                radius: 8
                                color: chatInput.text.length > 0 ? trackTheme.accentCore : trackTheme.bgPanel
                                border.color: trackTheme.borderDefault
                                border.width: chatInput.text.length > 0 ? 0 : 1
                                
                                Behavior on color { ColorAnimation { duration: 150 } }

                                Text {
                                    anchors.centerIn: parent
                                    text: "➤"
                                    color: chatInput.text.length > 0 ? "#ffffff" : trackTheme.textMuted
                                    font.pixelSize: 18
                                }

                                MouseArea {
                                    anchors.fill: parent
                                    cursorShape: chatInput.text.length > 0 ? Qt.PointingHandCursor : Qt.ForbiddenCursor
                                    onClicked: {
                                        if (chatInput.text.length > 0) {
                                            chatController.sendMessage()
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ==========================================
    // CONTROLLER LOGIC & SIMULATION
    // ==========================================
    QtObject {
        id: chatController
        
        function sendMessage() {
            let msg = chatInput.text.trim();
            if (msg === "") return;
            
            let d = new Date();
            let timeStr = d.getHours().toString().padStart(2, '0') + ":" + d.getMinutes().toString().padStart(2, '0');
            
            chatModel.append({
                "senderType": "USER",
                "senderName": "You",
                "message": msg,
                "timestamp": timeStr
            });
            
            chatInput.text = "";
            chatInput.forceActiveFocus();
            
            // Simulate Agent Reply Process
            mnjnefTicketTrackerRoot.isAgentTyping = false;
            agentResponseTimer.start();
        }
        
        function formatTime() {
            let d = new Date();
            let h = d.getHours() > 12 ? d.getHours() - 12 : d.getHours();
            let ampm = d.getHours() >= 12 ? "PM" : "AM";
            return h.toString() + ":" + d.getMinutes().toString().padStart(2, '0') + " " + ampm;
        }
    }

    // Simulates agent beginning to type
    Timer {
        id: agentResponseTimer
        interval: 1500
        repeat: false
        onRunningChanged: { if(running){} }
        onTriggered: {
            mnjnefTicketTrackerRoot.isAgentTyping = true;
            agentReplyTimer.start();
        }
    }
    
    // Simulates agent sending the message
    Timer {
        id: agentReplyTimer
        interval: 3000
        repeat: false
        onRunningChanged: { if(running){} }
        onTriggered: {
            mnjnefTicketTrackerRoot.isAgentTyping = false;
            
            let replies = [
                "I've updated the kernel flags on your node. Please restart your client and let me know if the crash persists.",
                "Understood. I'm pulling the logs from DXB-CORE-01 now to cross-reference.",
                "Could you provide the specific error code displayed right before the termination?",
                "That behavior is expected when running in Dev Mode. I will patch your permissions to bypass it."
            ];
            
            let randomReply = replies[Math.floor(Math.random() * replies.length)];
            
            chatModel.append({
                "senderType": "AGENT",
                "senderName": mnjnefTicketTrackerRoot.agentName,
                "message": randomReply,
                "timestamp": chatController.formatTime()
            });
        }
    }
}
