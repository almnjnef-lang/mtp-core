# 3. الكي الجراحي الدقيق للسطر 278 (القضاء على الخطأ نهائياً)
echo "🛠️ جاري الكي الجراحي لسطر 278 لحل مشكلة توقف السيرفر..."
cat << 'EOF' > /root/ultimate_fixer.py
import os

path = "/root/mnjnef_factory.py"
if os.path.exists(path):
    with open(path, "r", encoding="utf-8") as f:
        lines = f.readlines()
    
    # البحث عن السطر المسبب للمشكلة وتعديل ما قبله برمجياً
    for i in range(len(lines)):
        if "import urllib.parse as up" in lines[i]:
            # الرجوع للخلف للبحث عن كلمة try اليتيمة وتحويلها لـ if True لمنع الخطأ
            for j in range(i-1, max(-1, i-5), -1):
                if lines[j].strip() == "try:":
                    lines[j] = lines[j].replace("try:", "if True:")
                    break
                    
    with open(path, "w", encoding="utf-8") as f:
        f.writelines(lines)
    print("✅ تم القضاء على الخطأ البرمجي في السطر 278 للأبد!")
EOF
python3 /root/ultimate_fixer.py

