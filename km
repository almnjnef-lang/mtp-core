if __name__ == "__main__":
    print("[SYSTEM] Booting Almnjnef Account Defender...")
    
    # We set lockout to 5 seconds just for quick testing
    defender = AccountDefender(max_failed_attempts=10, lockout_duration_seconds=5)
    test_player = "Player_Zero"

    print("\n[TEST 1] Simulating Hacker guessing passwords (10 failed attempts)...")
    # Using a loop to simulate 10 rapid failed attempts
    for i in range(10):
        defender.process_login_attempt(test_player, is_successful=False)

    print("\n[TEST 2] Hacker tries again while locked (Attempt 11)...")
    # Even if they guess the correct password now, the system rejects them
    defender.process_login_attempt(test_player, is_successful=True) 

    print("\n[TEST 3] Waiting for the penalty time to expire (5 seconds)...")
    time.sleep(6)
    
    print("\n[TEST 4] Real user logs in with correct password after lock expires...")
    defender.process_login_attempt(test_player, is_successful=True)
    print("Login sequence complete.")
