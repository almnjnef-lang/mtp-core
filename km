import QtQuick
import QtQuick.Controls
import QtQuick.Layouts
import QtQuick.Window

ApplicationWindow {
    id: rootWindow
    width: 1280
    height: 720
    visible: true
    title: qsTr("Mnjnef Platform")
    color: mnjTheme.bgGlobal

    // ==========================================
    // GLOBAL THEME & CONSTANTS
    // ==========================================
    QtObject {
        id: mnjTheme
        // Clean, deep blue solid gradient background colors
        property color bgGlobal: "#0A0F1C"
        property color bgGradientTop: "#0B132B"
        property color bgGradientBottom: "#050814"
        
        // Panel & Inputs
        property color bgPanel: "#0D1424" // Solid dark panel, removed glass blur for performance and clean look
        property color bgInput: "#131C31"
        property color bgInputFocus: "#1A2642"
        
        // Accents
        property color accentCore: "#2563EB"
        property color accentHover: "#3B82F6"
        property color accentPressed: "#1D4ED8"
        
        // Text
        property color textHeader: "#FFFFFF"
        property color textBody: "#CBD5E1"
        property color textMuted: "#64748B"
        
        // Borders
        property color borderDefault: "#1E293B"
        property color borderFocus: "#3B82F6"
        property color borderError: "#EF4444"
        
        // States
        property color stateError: "#EF4444"
        property color stateSuccess: "#10B981"
        property color stateWarning: "#F59E0B"
        
        property string fontMain: "Segoe UI"
        property string fontMono: "Consolas"
    }

    // ==========================================
    // GLOBAL NAVIGATION CONTROLLER
    // ==========================================
    // The StackView is the engine that allows switching between the Login screen
    // and the Support modules (Support_1_Main.qml, etc.) without crashing.
    StackView {
        id: mainStack
        anchors.fill: parent
        initialItem: loginComponent

        // Custom transition for smooth page switching
        pushEnter: Transition {
            PropertyAnimation { property: "opacity"; from: 0; to: 1; duration: 300 }
            PropertyAnimation { property: "scale"; from: 0.95; to: 1; duration: 300; easing.type: Easing.OutQuad }
        }
        pushExit: Transition {
            PropertyAnimation { property: "opacity"; from: 1; to: 0; duration: 300 }
        }
        popEnter: Transition {
            PropertyAnimation { property: "opacity"; from: 0; to: 1; duration: 300 }
        }
        popExit: Transition {
            PropertyAnimation { property: "opacity"; from: 1; to: 0; duration: 300 }
            PropertyAnimation { property: "scale"; from: 1; to: 0.95; duration: 300; easing.type: Easing.OutQuad }
        }
    }

    // ==========================================
    // NOTIFICATION SYSTEM (TOASTS)
    // ==========================================
    Rectangle {
        id: toastNotification
        width: toastText.implicitWidth + 40
        height: 48
        radius: 8
        color: mnjTheme.stateError
        anchors.horizontalCenter: parent.horizontalCenter
        y: -60 // Hidden off-screen initially
        z: 100
        opacity: 0

        RowLayout {
            anchors.fill: parent
            anchors.margins: 12
            spacing: 8
            
            Text { text: "⚠️"; font.pixelSize: 16 }
            
            Text {
                id: toastText
                text: ""
                color: "#FFFFFF"
                font.pixelSize: 14
                font.bold: true
                font.family: mnjTheme.fontMain
            }
        }

        SequentialAnimation {
            id: toastAnim
            NumberAnimation { target: toastNotification; property: "y"; to: 40; duration: 300; easing.type: Easing.OutBack }
            NumberAnimation { target: toastNotification; property: "opacity"; to: 1.0; duration: 300 }
            PauseAnimation { duration: 3000 }
            NumberAnimation { target: toastNotification; property: "opacity"; to: 0.0; duration: 300 }
            NumberAnimation { target: toastNotification; property: "y"; to: -60; duration: 300; easing.type: Easing.InBack }
        }

        function showError(msg) {
            toastNotification.color = mnjTheme.stateError;
            toastText.text = msg;
            toastAnim.restart();
        }
        
        function showSuccess(msg) {
            toastNotification.color = mnjTheme.stateSuccess;
            toastText.text = msg;
            toastAnim.restart();
        }
    }

    // ==========================================
    // LOGIN SCREEN COMPONENT
    // ==========================================
    Component {
        id: loginComponent

        Item {
            anchors.fill: parent

            // 1. CLEAN BLUE BACKGROUND
            // Completely solid gradient, no noise, no circles, no distractions.
            Rectangle {
                anchors.fill: parent
                gradient: Gradient {
                    GradientStop { position: 0.0; color: mnjTheme.bgGradientTop }
                    GradientStop { position: 1.0; color: mnjTheme.bgGradientBottom }
                }
            }

            // 2. MAIN LOGIN PANEL
            Rectangle {
                id: loginPanel
                width: 440
                height: 600
                anchors.centerIn: parent
                color: mnjTheme.bgPanel
                radius: 20
                border.color: mnjTheme.borderDefault
                border.width: 1
                
                // Subtle shadow for depth without clutter
                layer.enabled: true

                ColumnLayout {
                    anchors.fill: parent
                    anchors.margins: 32
                    spacing: 24

                    // HEADER
                    ColumnLayout {
                        Layout.fillWidth: true
                        spacing: 8
                        Layout.alignment: Qt.AlignHCenter

                        Text {
                            text: "Mnjnef"
                            color: mnjTheme.textHeader
                            font.pixelSize: 42
                            font.bold: true
                            font.family: mnjTheme.fontMain
                            font.letterSpacing: 1.5
                            Layout.alignment: Qt.AlignHCenter
                        }

                        Text {
                            text: qsTr("Join a gaming community and create your own world in the Mnjnef platform")
                            color: mnjTheme.textMuted
                            font.pixelSize: 13
                            font.family: mnjTheme.fontMain
                            Layout.alignment: Qt.AlignHCenter
                            horizontalAlignment: Text.AlignHCenter
                            wrapMode: Text.WordWrap
                            Layout.maximumWidth: 320
                            lineHeight: 1.3
                        }
                    }

                    // INPUT FIELDS
                    ColumnLayout {
                        Layout.fillWidth: true
                        spacing: 16
                        Layout.topMargin: 10

                        // Custom Username Field
                        Rectangle {
                            Layout.fillWidth: true
                            Layout.preferredHeight: 54
                            radius: 10
                            color: usernameInput.activeFocus ? mnjTheme.bgInputFocus : mnjTheme.bgInput
                            border.color: usernameInput.activeFocus ? mnjTheme.borderFocus : mnjTheme.borderDefault
                            border.width: usernameInput.activeFocus ? 2 : 1
                            
                            Behavior on border.color { ColorAnimation { duration: 150 } }
                            Behavior on color { ColorAnimation { duration: 150 } }

                            TextInput {
                                id: usernameInput
                                anchors.fill: parent
                                anchors.leftMargin: 16
                                anchors.rightMargin: 16
                                color: mnjTheme.textHeader
                                font.pixelSize: 15
                                font.family: mnjTheme.fontMain
                                verticalAlignment: TextInput.AlignVCenter
                                selectByMouse: true
                                
                                Text {
                                    text: qsTr("Enter Username")
                                    color: mnjTheme.textMuted
                                    font.pixelSize: 15
                                    font.family: mnjTheme.fontMain
                                    visible: !usernameInput.text && !usernameInput.activeFocus
                                    anchors.verticalCenter: parent.verticalCenter
                                }
                            }
                        }

                        // Custom Email Field
                        Rectangle {
                            Layout.fillWidth: true
                            Layout.preferredHeight: 54
                            radius: 10
                            color: emailInput.activeFocus ? mnjTheme.bgInputFocus : mnjTheme.bgInput
                            border.color: emailInput.activeFocus ? mnjTheme.borderFocus : mnjTheme.borderDefault
                            border.width: emailInput.activeFocus ? 2 : 1
                            
                            Behavior on border.color { ColorAnimation { duration: 150 } }
                            Behavior on color { ColorAnimation { duration: 150 } }

                            TextInput {
                                id: emailInput
                                anchors.fill: parent
                                anchors.leftMargin: 16
                                anchors.rightMargin: 16
                                color: mnjTheme.textHeader
                                font.pixelSize: 15
                                font.family: mnjTheme.fontMain
                                verticalAlignment: TextInput.AlignVCenter
                                selectByMouse: true
                                
                                Text {
                                    text: qsTr("Enter Email")
                                    color: mnjTheme.textMuted
                                    font.pixelSize: 15
                                    font.family: mnjTheme.fontMain
                                    visible: !emailInput.text && !emailInput.activeFocus
                                    anchors.verticalCenter: parent.verticalCenter
                                }
                            }
                        }

                        // Custom Password Field
                        ColumnLayout {
                            Layout.fillWidth: true
                            spacing: 6

                            Rectangle {
                                Layout.fillWidth: true
                                Layout.preferredHeight: 54
                                radius: 10
                                color: passwordInput.activeFocus ? mnjTheme.bgInputFocus : mnjTheme.bgInput
                                border.color: passwordInput.activeFocus ? mnjTheme.borderFocus : mnjTheme.borderDefault
                                border.width: passwordInput.activeFocus ? 2 : 1
                                
                                Behavior on border.color { ColorAnimation { duration: 150 } }
                                Behavior on color { ColorAnimation { duration: 150 } }

                                RowLayout {
                                    anchors.fill: parent
                                    anchors.leftMargin: 16
                                    anchors.rightMargin: 16
                                    spacing: 8

                                    TextInput {
                                        id: passwordInput
                                        Layout.fillWidth: true
                                        Layout.fillHeight: true
                                        color: mnjTheme.textHeader
                                        font.pixelSize: 15
                                        font.family: mnjTheme.fontMain
                                        verticalAlignment: TextInput.AlignVCenter
                                        echoMode: visibilityIcon.isVisible ? TextInput.Normal : TextInput.Password
                                        selectByMouse: true
                                        
                                        onTextChanged: authController.checkPasswordStrength(text)

                                        Text {
                                            text: qsTr("Enter Password")
                                            color: mnjTheme.textMuted
                                            font.pixelSize: 15
                                            font.family: mnjTheme.fontMain
                                            visible: !passwordInput.text && !passwordInput.activeFocus
                                            anchors.verticalCenter: parent.verticalCenter
                                        }
                                    }

                                    // Visibility Toggle
                                    Text {
                                        id: visibilityIcon
                                        property bool isVisible: false
                                        text: isVisible ? "👁️" : "👁️‍🗨️"
                                        color: mnjTheme.textMuted
                                        font.pixelSize: 16
                                        Layout.alignment: Qt.AlignVCenter
                                        
                                        MouseArea {
                                            anchors.fill: parent
                                            anchors.margins: -10
                                            cursorShape: Qt.PointingHandCursor
                                            onClicked: visibilityIcon.isVisible = !visibilityIcon.isVisible
                                        }
                                    }
                                }
                            }
                            
                            // Password Strength Bar
                            RowLayout {
                                Layout.fillWidth: true
                                Layout.preferredHeight: 4
                                spacing: 4
                                visible: passwordInput.text.length > 0
                                
                                Repeater {
                                    model: 4
                                    Rectangle {
                                        Layout.fillWidth: true
                                        Layout.fillHeight: true
                                        radius: 2
                                        color: {
                                            if (authController.passStrength > index) {
                                                if (authController.passStrength <= 1) return mnjTheme.stateError;
                                                if (authController.passStrength === 2) return mnjTheme.stateWarning;
                                                return mnjTheme.stateSuccess;
                                            }
                                            return mnjTheme.borderDefault;
                                        }
                                        Behavior on color { ColorAnimation { duration: 200 } }
                                    }
                                }
                            }
                        }
                    }

                    // LOGIN BUTTON
                    Rectangle {
                        id: loginBtnRect
                        Layout.fillWidth: true
                        Layout.preferredHeight: 54
                        Layout.topMargin: 10
                        radius: 10
                        color: {
                            if (authController.isLoggingIn) return mnjTheme.borderDefault;
                            if (loginMouseArea.containsPress) return mnjTheme.accentPressed;
                            if (loginMouseArea.containsMouse) return mnjTheme.accentHover;
                            return mnjTheme.accentCore;
                        }
                        
                        Behavior on color { ColorAnimation { duration: 150 } }

                        RowLayout {
                            anchors.centerIn: parent
                            spacing: 12
                            
                            // Spinner
                            Item {
                                Layout.preferredWidth: 20
                                Layout.preferredHeight: 20
                                visible: authController.isLoggingIn
                                
                                Rectangle {
                                    anchors.fill: parent
                                    radius: 10
                                    color: "transparent"
                                    border.color: mnjTheme.textHeader
                                    border.width: 2
                                    opacity: 0.3
                                }
                                
                                Rectangle {
                                    anchors.fill: parent
                                    radius: 10
                                    color: "transparent"
                                    border.color: mnjTheme.textHeader
                                    border.width: 2
                                    clip: true
                                    
                                    RotationAnimation on rotation {
                                        loops: Animation.Infinite
                                        from: 0; to: 360; duration: 800
                                        running: authController.isLoggingIn
                                    }
                                }
                            }

                            Text {
                                text: authController.isLoggingIn ? qsTr("Authenticating...") : qsTr("Login")
                                color: mnjTheme.textHeader
                                font.pixelSize: 16
                                font.bold: true
                                font.family: mnjTheme.fontMain
                                font.letterSpacing: 1.0
                            }
                        }

                        MouseArea {
                            id: loginMouseArea
                            anchors.fill: parent
                            hoverEnabled: !authController.isLoggingIn
                            cursorShape: authController.isLoggingIn ? Qt.ForbiddenCursor : Qt.PointingHandCursor
                            onClicked: {
                                if (!authController.isLoggingIn) {
                                    authController.processLogin(usernameInput.text, emailInput.text, passwordInput.text);
                                }
                            }
                        }
                    }

                    Item { Layout.fillHeight: true } // Spacer

                    // FOOTER DIVIDER
                    Rectangle {
                        Layout.fillWidth: true
                        Layout.preferredHeight: 1
                        color: mnjTheme.borderDefault
                    }

                    // FOOTER: PRIVACY POLICY & SUPPORT
                    // Extremely clean layout, no translation button here.
                    RowLayout {
                        Layout.fillWidth: true
                        Layout.preferredHeight: 30

                        // Left: Privacy Policy
                        Text {
                            text: qsTr("Privacy Policy")
                            color: privacyBtnMouse.containsMouse ? mnjTheme.textHeader : mnjTheme.textMuted
                            font.pixelSize: 13
                            font.family: mnjTheme.fontMain
                            
                            Behavior on color { ColorAnimation { duration: 150 } }

                            MouseArea {
                                id: privacyBtnMouse
                                anchors.fill: parent
                                anchors.margins: -8
                                hoverEnabled: true
                                cursorShape: Qt.PointingHandCursor
                                onClicked: privacyPolicyPopup.open()
                            }
                        }

                        Item { Layout.fillWidth: true } // Pushes items to edges

                        // Right: Mnjnef Support
                        Text {
                            text: qsTr("Mnjnef Support")
                            color: supportBtnMouse.containsMouse ? mnjTheme.accentHover : mnjTheme.textMuted
                            font.pixelSize: 13
                            font.bold: true
                            font.family: mnjTheme.fontMain
                            
                            Behavior on color { ColorAnimation { duration: 150 } }

                            MouseArea {
                                id: supportBtnMouse
                                anchors.fill: parent
                                anchors.margins: -8
                                hoverEnabled: true
                                cursorShape: Qt.PointingHandCursor
                                onClicked: {
                                    // This pushes the first Support Module onto the screen!
                                    // Make sure "Support_1_Main.qml" exists in the same directory.
                                    mainStack.push("Support_1_Main.qml")
                                }
                            }
                        }
                    }
                }
            }

            // ==========================================
            // LOGIN LOGIC CONTROLLER
            // ==========================================
            QtObject {
                id: authController
                
                property bool isLoggingIn: false
                property int passStrength: 0
                
                function validateEmail(email) {
                    let re = /^[\w-\.]+@([\w-]+\.)+[\w-]{2,4}$/;
                    return re.test(email);
                }
                
                function checkPasswordStrength(pwd) {
                    let score = 0;
                    if (pwd.length > 5) score += 1;
                    if (pwd.length > 8) score += 1;
                    if (/[A-Z]/.test(pwd) && /[0-9]/.test(pwd)) score += 1;
                    if (/[^A-Za-z0-9]/.test(pwd)) score += 1;
                    passStrength = score;
                }

                function processLogin(uName, eMail, pwd) {
                    uName = uName.trim();
                    eMail = eMail.trim();
                    
                    if (uName === "") {
                        toastNotification.showError(qsTr("Username is required."));
                        return;
                    }
                    if (!validateEmail(eMail)) {
                        toastNotification.showError(qsTr("Invalid email format."));
                        return;
                    }
                    if (pwd === "") {
                        toastNotification.showError(qsTr("Password is required."));
                        return;
                    }
                    
                    isLoggingIn = true;
                    authDelay.start();
                }
            }

            Timer {
                id: authDelay
                interval: 2000
                repeat: false
                onTriggered: {
                    authController.isLoggingIn = false;
                    toastNotification.showSuccess(qsTr("Login Successful. Loading Dashboard..."));
                    // Here you would transition to your actual game/platform dashboard
                }
            }
        }
    }

    // ==========================================
    // PRIVACY POLICY POPUP DIALOG
    // ==========================================
    Popup {
        id: privacyPolicyPopup
        width: 600
        height: 500
        x: Math.round((parent.width - width) / 2)
        y: Math.round((parent.height - height) / 2)
        modal: true
        focus: true
        closePolicy: Popup.CloseOnEscape | Popup.CloseOnPressOutside
        
        background: Rectangle {
            color: mnjTheme.bgPanel
            radius: 16
            border.color: mnjTheme.borderDefault
            border.width: 1
        }
        
        // Darken the background behind popup
        Overlay.modal: Rectangle {
            color: "#B3000000"
        }

        ColumnLayout {
            anchors.fill: parent
            anchors.margins: 24
            spacing: 16

            // Header
            RowLayout {
                Layout.fillWidth: true
                
                Text {
                    text: qsTr("Privacy Policy")
                    color: mnjTheme.textHeader
                    font.pixelSize: 20
                    font.bold: true
                    font.family: mnjTheme.fontMain
                }
                
                Item { Layout.fillWidth: true }
                
                Rectangle {
                    Layout.preferredWidth: 32
                    Layout.preferredHeight: 32
                    radius: 8
                    color: closeMouse.containsMouse ? mnjTheme.borderDefault : "transparent"
                    
                    Text {
                        anchors.centerIn: parent
                        text: "✕"
                        color: mnjTheme.textMuted
                        font.pixelSize: 16
                    }
                    
                    MouseArea {
                        id: closeMouse
                        anchors.fill: parent
                        hoverEnabled: true
                        cursorShape: Qt.PointingHandCursor
                        onClicked: privacyPolicyPopup.close()
                    }
                }
            }

            Rectangle { Layout.fillWidth: true; Layout.preferredHeight: 1; color: mnjTheme.borderDefault }

            // Scrollable Content
            Flickable {
                Layout.fillWidth: true
                Layout.fillHeight: true
                contentWidth: width
                contentHeight: policyText.implicitHeight
                clip: true
                
                ScrollBar.vertical: ScrollBar { width: 6; policy: ScrollBar.AlwaysOn }

                Text {
                    id: policyText
                    width: parent.width - 16
                    color: mnjTheme.textBody
                    font.pixelSize: 13
                    font.family: mnjTheme.fontMain
                    wrapMode: Text.WordWrap
                    lineHeight: 1.5
                    text: "Last Updated: June 2026\n\n" +
                          "1. DATA COLLECTION\n" +
                          "Mnjnef operates globally and collects minimal telemetry required for network routing, anti-cheat enforcement, and platform stability. We log your hardware signatures exclusively to prevent tampering.\n\n" +
                          "2. USAGE OF INFORMATION\n" +
                          "Your email and username are used strictly for authentication and account recovery. Mnjnef Support agents will never ask for your password. System diagnostic logs submitted via Mnjnef Support are encrypted end-to-end.\n\n" +
                          "3. ANTI-TAMPER PROTOCOL\n" +
                          "Our proprietary Anti-Tamper Protocol continuously monitors RAM and runtime execution. By using the platform, you consent to memory heuristics scanning. Detected anomalies result in automated hardware bans.\n\n" +
                          "4. THIRD-PARTY SHARING\n" +
                          "We do not sell data. Data is only shared with localized server routing partners (e.g., DXB-CORE-01) for latency optimization.\n\n" +
                          "5. USER RIGHTS\n" +
                          "You reserve the right to request a complete purge of your account data via the Support Portal. Account deletion takes 30 days to process.\n\n" +
                          "If you require further assistance regarding data handling, please initiate a ticket through Mnjnef Support."
                }
            }

            // Accept Button
            Rectangle {
                Layout.fillWidth: true
                Layout.preferredHeight: 48
                radius: 8
                color: mnjTheme.accentCore
                
                Text {
                    anchors.centerIn: parent
                    text: qsTr("I Understand")
                    color: "#FFFFFF"
                    font.pixelSize: 14
                    font.bold: true
                    font.family: mnjTheme.fontMain
                }
                
                MouseArea {
                    anchors.fill: parent
                    cursorShape: Qt.PointingHandCursor
                    onClicked: privacyPolicyPopup.close()
                }
            }
        }
    }
}
