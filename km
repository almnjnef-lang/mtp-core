import QtQuick
import QtQuick.Controls
import QtQuick.Layouts

Item {
    id: mnjnefGuidelinesRoot
    anchors.fill: parent
    clip: true

    // ==========================================
    // SIGNALS & SYSTEM PROPERTIES
    // ==========================================
    signal guidelinesAccepted()
    signal guidelinesDeclined()
    
    property bool isFullyScrolled: false
    property int totalClauses: guidelinesModel.count
    property int acceptedClauses: 0
    property int readingCountdown: 10
    property bool isTimerActive: true

    // ==========================================
    // THEME & STYLING CORE
    // ==========================================
    QtObject {
        id: glTheme
        property color bgPrimary: "#030712"
        property color bgSurface: "#0f172a"
        property color bgElevated: "#1e293b"
        property color bgHighlight: "#334155"
        
        property color accentPrimary: "#1f6feb"
        property color accentHover: "#3b82f6"
        property color accentDisabled: "#0f2744"
        
        property color textHeader: "#ffffff"
        property color textBody: "#f8fafc"
        property color textMuted: "#94a3b8"
        property color textDisabled: "#475569"
        
        property color borderDefault: "#1e293b"
        property color borderActive: "#3b82f6"
        
        property color statusWarning: "#f59e0b"
        property color statusWarningBg: "#452500"
        property color statusSuccess: "#10b981"
        property color statusDanger: "#ef4444"
        
        property string fontMain: "Segoe UI"
        property string fontMono: "Consolas"
    }

    // ==========================================
    // GUIDELINES DATA MODEL
    // ==========================================
    ListModel {
        id: guidelinesModel
        
        ListElement {
            clauseId: "GL-001"
            title: "Accuracy of Information"
            description: "You must provide accurate, current, and complete information regarding your technical issue. Falsified network logs, modified screenshots, or deceptive bug reports will result in an immediate hardware ban."
            isRequired: true
            isAccepted: false
        }
        ListElement {
            clauseId: "GL-002"
            title: "Response Time Service Level Agreement (SLA)"
            description: "Mnjnef Premium Support operates on a queue system. Standard response time is between 12 to 24 hours. Submitting duplicate tickets for the same issue will push your priority to the bottom of the queue."
            isRequired: true
            isAccepted: false
        }
        ListElement {
            clauseId: "GL-003"
            title: "Zero Tolerance for Abuse"
            description: "Any use of profanity, threats, or harassment towards Mnjnef support staff will lead to immediate ticket closure and permanent suspension of your Mnjnef account without right to appeal."
            isRequired: true
            isAccepted: false
        }
        ListElement {
            clauseId: "GL-004"
            title: "Remote Telemetry & Diagnostic Data"
            description: "By submitting a technical ticket, you authorize Mnjnef Support tools to temporarily gather hardware telemetry, crash dumps, and system logs directly related to Mnjnef software."
            isRequired: true
            isAccepted: false
        }
        ListElement {
            clauseId: "GL-005"
            title: "Account Ownership Verification"
            description: "Support staff will never ask for your password. However, you must verify ownership via your registered email or two-factor authentication (2FA) device before sensitive account changes are made."
            isRequired: true
            isAccepted: false
        }
        ListElement {
            clauseId: "GL-006"
            title: "Third-Party Modifications"
            description: "We do not provide support for issues arising from unauthorized third-party modifications, custom scripts, or injected DLLs. Ensure your client is vanilla before submitting."
            isRequired: true
            isAccepted: false
        }
    }

    // ==========================================
    // BACKGROUND & AMBIENT EFFECTS
    // ==========================================
    Rectangle {
        anchors.fill: parent
        color: glTheme.bgPrimary
        
        // Ambient Grid
        Grid {
            anchors.fill: parent
            anchors.margins: 2
            rows: 20
            columns: 20
            spacing: 1
            
            Repeater {
                model: 400
                Rectangle {
                    width: (mnjnefGuidelinesRoot.width / 20) - 1
                    height: (mnjnefGuidelinesRoot.height / 20) - 1
                    color: "transparent"
                    border.color: glTheme.borderDefault
                    border.width: 1
                    opacity: 0.15
                }
            }
        }
        
        // Gradient Fade at Top and Bottom
        Rectangle {
            anchors.top: parent.top
            width: parent.width
            height: 40
            gradient: Gradient {
                GradientStop { position: 0.0; color: glTheme.bgPrimary }
                GradientStop { position: 1.0; color: "transparent" }
            }
            z: 10
        }
        Rectangle {
            anchors.bottom: footerPanel.top
            width: parent.width
            height: 40
            gradient: Gradient {
                GradientStop { position: 0.0; color: "transparent" }
                GradientStop { position: 1.0; color: glTheme.bgPrimary }
            }
            z: 10
        }
    }

    // ==========================================
    // MAIN LAYOUT
    // ==========================================
    ColumnLayout {
        anchors.fill: parent
        spacing: 0

        // ------------------------------------------
        // HEADER: TITLE & WARNING
        // ------------------------------------------
        Rectangle {
            Layout.fillWidth: true
            Layout.preferredHeight: 80
            color: glTheme.bgSurface
            border.color: glTheme.borderDefault
            border.width: 1
            z: 20

            RowLayout {
                anchors.fill: parent
                anchors.leftMargin: 24
                anchors.rightMargin: 24
                spacing: 16

                // Warning Icon Container
                Rectangle {
                    Layout.preferredWidth: 48
                    Layout.preferredHeight: 48
                    radius: 12
                    color: glTheme.statusWarningBg
                    border.color: glTheme.statusWarning
                    border.width: 1

                    Text {
                        anchors.centerIn: parent
                        text: "⚠️"
                        font.pixelSize: 24
                    }
                    
                    // Pulse Effect
                    Rectangle {
                        anchors.fill: parent
                        radius: 12
                        color: "transparent"
                        border.color: glTheme.statusWarning
                        border.width: 2
                        opacity: 0.0
                        
                        SequentialAnimation on opacity {
                            loops: Animation.Infinite
                            running: true
                            NumberAnimation { from: 0.0; to: 0.5; duration: 1000 }
                            NumberAnimation { from: 0.5; to: 0.0; duration: 1000 }
                        }
                    }
                }

                // Titles
                ColumnLayout {
                    Layout.fillWidth: true
                    spacing: 4

                    Text {
                        text: qsTr("MANDATORY SUPPORT GUIDELINES")
                        color: glTheme.textHeader
                        font.pixelSize: 18
                        font.bold: true
                        font.family: glTheme.fontMain
                        font.letterSpacing: 1.5
                    }

                    Text {
                        text: qsTr("Carefully read and accept all clauses before proceeding to the ticket portal.")
                        color: glTheme.textMuted
                        font.pixelSize: 13
                        font.family: glTheme.fontMain
                    }
                }
                
                // Read Progress
                ColumnLayout {
                    Layout.alignment: Qt.AlignVCenter | Qt.AlignRight
                    spacing: 4
                    
                    Text {
                        text: qsTr("AGREEMENT PROGRESS")
                        color: glTheme.textDisabled
                        font.pixelSize: 10
                        font.family: glTheme.fontMono
                        Layout.alignment: Qt.AlignRight
                    }
                    
                    RowLayout {
                        spacing: 8
                        Layout.alignment: Qt.AlignRight
                        
                        Text {
                            text: mnjnefGuidelinesRoot.acceptedClauses + " / " + mnjnefGuidelinesRoot.totalClauses
                            color: mnjnefGuidelinesRoot.acceptedClauses === mnjnefGuidelinesRoot.totalClauses ? glTheme.statusSuccess : glTheme.statusWarning
                            font.pixelSize: 18
                            font.bold: true
                            font.family: glTheme.fontMono
                        }
                    }
                }
            }
            
            // Bottom glowing border line
            Rectangle {
                anchors.bottom: parent.bottom
                width: parent.width
                height: 2
                color: glTheme.accentPrimary
                opacity: 0.4
            }
        }

        // ------------------------------------------
        // MIDDLE: SCROLLABLE CLAUSES
        // ------------------------------------------
        Item {
            Layout.fillWidth: true
            Layout.fillHeight: true

            Flickable {
                id: guidelinesFlickable
                anchors.fill: parent
                anchors.margins: 24
                contentWidth: width
                contentHeight: clauseColumn.implicitHeight + 40
                clip: true
                boundsBehavior: Flickable.StopAtBounds

                onContentYChanged: {
                    if (contentY >= contentHeight - height - 10) {
                        mnjnefGuidelinesRoot.isFullyScrolled = true;
                    }
                }

                ColumnLayout {
                    id: clauseColumn
                    width: parent.width
                    spacing: 16

                    Text {
                        text: qsTr("Terms of Support Engagement")
                        color: glTheme.textHeader
                        font.pixelSize: 16
                        font.bold: true
                        font.family: glTheme.fontMain
                        Layout.bottomMargin: 8
                    }

                    Repeater {
                        model: guidelinesModel
                        
                        // Custom Interactive Clause Component
                        Rectangle {
                            Layout.fillWidth: true
                            Layout.preferredHeight: clauseTextCol.implicitHeight + 32
                            color: isAccepted ? glTheme.bgElevated : glTheme.bgSurface
                            radius: 8
                            border.color: isAccepted ? glTheme.borderActive : glTheme.borderDefault
                            border.width: isAccepted ? 2 : 1
                            
                            Behavior on color { ColorAnimation { duration: 200 } }
                            Behavior on border.color { ColorAnimation { duration: 200 } }

                            RowLayout {
                                anchors.fill: parent
                                anchors.margins: 16
                                spacing: 16

                                // Status Indicator / Code
                                ColumnLayout {
                                    Layout.alignment: Qt.AlignTop
                                    Layout.preferredWidth: 60
                                    spacing: 4
                                    
                                    Text {
                                        text: clauseId
                                        color: isAccepted ? glTheme.accentPrimary : glTheme.textDisabled
                                        font.pixelSize: 12
                                        font.bold: true
                                        font.family: glTheme.fontMono
                                    }
                                    
                                    Rectangle {
                                        Layout.preferredWidth: 24
                                        Layout.preferredHeight: 4
                                        radius: 2
                                        color: isAccepted ? glTheme.statusSuccess : glTheme.statusWarning
                                    }
                                }

                                // Clause Content
                                ColumnLayout {
                                    id: clauseTextCol
                                    Layout.fillWidth: true
                                    spacing: 6
                                    
                                    Text {
                                        text: title
                                        color: isAccepted ? glTheme.textHeader : glTheme.textBody
                                        font.pixelSize: 15
                                        font.bold: true
                                        font.family: glTheme.fontMain
                                        Layout.fillWidth: true
                                        wrapMode: Text.WordWrap
                                    }
                                    
                                    Text {
                                        text: description
                                        color: isAccepted ? glTheme.textBody : glTheme.textMuted
                                        font.pixelSize: 13
                                        font.family: glTheme.fontMain
                                        Layout.fillWidth: true
                                        wrapMode: Text.WordWrap
                                        lineHeight: 1.4
                                    }
                                }

                                // Custom Checkbox Toggle
                                Rectangle {
                                    Layout.alignment: Qt.AlignVCenter | Qt.AlignRight
                                    Layout.preferredWidth: 32
                                    Layout.preferredHeight: 32
                                    radius: 16
                                    color: isAccepted ? glTheme.accentPrimary : "transparent"
                                    border.color: isAccepted ? glTheme.accentPrimary : glTheme.textDisabled
                                    border.width: 2
                                    
                                    Behavior on color { ColorAnimation { duration: 150 } }
                                    
                                    Text {
                                        anchors.centerIn: parent
                                        text: "✓"
                                        color: glTheme.textHeader
                                        font.pixelSize: 16
                                        font.bold: true
                                        opacity: isAccepted ? 1.0 : 0.0
                                        Behavior on opacity { NumberAnimation { duration: 150 } }
                                        y: isAccepted ? 0 : 10
                                        Behavior on y { NumberAnimation { duration: 200; easing.type: Easing.OutBack } }
                                    }
                                    
                                    MouseArea {
                                        anchors.fill: parent
                                        anchors.margins: -10 // Expand hit area
                                        hoverEnabled: true
                                        cursorShape: Qt.PointingHandCursor
                                        
                                        onEntered: {
                                            if (!isAccepted) parent.border.color = glTheme.textMuted
                                        }
                                        onExited: {
                                            if (!isAccepted) parent.border.color = glTheme.textDisabled
                                        }
                                        onClicked: {
                                            guidelinesModel.setProperty(index, "isAccepted", !isAccepted);
                                            recalculateAcceptance();
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Custom Advanced Scrollbar
            Rectangle {
                anchors.right: parent.right
                anchors.top: parent.top
                anchors.bottom: parent.bottom
                anchors.margins: 4
                width: 6
                radius: 3
                color: glTheme.bgSurface
                
                Rectangle {
                    width: parent.width
                    radius: 3
                    color: guidelinesFlickable.moving ? glTheme.accentPrimary : glTheme.textDisabled
                    height: Math.max(30, (guidelinesFlickable.height / guidelinesFlickable.contentHeight) * parent.height)
                    y: (guidelinesFlickable.contentY / (guidelinesFlickable.contentHeight - guidelinesFlickable.height)) * (parent.height - height)
                    
                    Behavior on color { ColorAnimation { duration: 150 } }
                }
            }
        }

        // ------------------------------------------
        // FOOTER: ACTION CONTROLS & TIMER
        // ------------------------------------------
        Rectangle {
            id: footerPanel
            Layout.fillWidth: true
            Layout.preferredHeight: 80
            color: glTheme.bgSurface
            border.color: glTheme.borderDefault
            border.width: 1
            z: 20

            RowLayout {
                anchors.fill: parent
                anchors.margins: 16
                spacing: 16

                // Decline Button
                Rectangle {
                    Layout.preferredWidth: 140
                    Layout.fillHeight: true
                    radius: 8
                    color: declineMouse.containsMouse ? glTheme.bgHighlight : "transparent"
                    border.color: declineMouse.containsMouse ? glTheme.textMuted : glTheme.borderDefault
                    border.width: 1
                    
                    Behavior on color { ColorAnimation { duration: 150 } }

                    Text {
                        anchors.centerIn: parent
                        text: qsTr("DECLINE")
                        color: glTheme.textMuted
                        font.pixelSize: 14
                        font.bold: true
                        font.family: glTheme.fontMain
                    }

                    MouseArea {
                        id: declineMouse
                        anchors.fill: parent
                        hoverEnabled: true
                        cursorShape: Qt.PointingHandCursor
                        onClicked: mnjnefGuidelinesRoot.guidelinesDeclined()
                    }
                }

                Item { Layout.fillWidth: true } // Spacer

                // Timer Visualizer
                RowLayout {
                    Layout.alignment: Qt.AlignVCenter
                    spacing: 8
                    visible: mnjnefGuidelinesRoot.isTimerActive
                    
                    Text {
                        text: qsTr("Reading Time Enforcement:")
                        color: glTheme.textDisabled
                        font.pixelSize: 12
                        font.family: glTheme.fontMain
                    }
                    
                    Text {
                        text: mnjnefGuidelinesRoot.readingCountdown + "s"
                        color: glTheme.statusWarning
                        font.pixelSize: 14
                        font.bold: true
                        font.family: glTheme.fontMono
                    }
                }

                // Accept Button
                Rectangle {
                    id: acceptBtn
                    Layout.preferredWidth: 220
                    Layout.fillHeight: true
                    radius: 8
                    
                    property bool canAccept: mnjnefGuidelinesRoot.acceptedClauses === mnjnefGuidelinesRoot.totalClauses && !mnjnefGuidelinesRoot.isTimerActive
                    
                    color: {
                        if (!canAccept) return glTheme.accentDisabled;
                        if (acceptMouse.containsPress) return glTheme.accentPrimary;
                        if (acceptMouse.containsMouse) return glTheme.accentHover;
                        return glTheme.accentPrimary;
                    }
                    
                    border.color: canAccept ? glTheme.borderActive : "transparent"
                    border.width: canAccept ? 1 : 0
                    
                    Behavior on color { ColorAnimation { duration: 200 } }

                    // Glow Effect when active
                    Rectangle {
                        anchors.fill: parent
                        radius: 8
                        color: "transparent"
                        border.color: glTheme.accentHover
                        border.width: 2
                        opacity: acceptBtn.canAccept ? 0.6 : 0.0
                        
                        SequentialAnimation on opacity {
                            loops: Animation.Infinite
                            running: acceptBtn.canAccept && !acceptMouse.containsMouse
                            NumberAnimation { from: 0.2; to: 0.8; duration: 1500 }
                            NumberAnimation { from: 0.8; to: 0.2; duration: 1500 }
                        }
                    }

                    RowLayout {
                        anchors.centerIn: parent
                        spacing: 8

                        Text {
                            text: "✓"
                            color: glTheme.textHeader
                            font.pixelSize: 16
                            font.bold: true
                            visible: acceptBtn.canAccept
                        }

                        Text {
                            text: {
                                if (mnjnefGuidelinesRoot.isTimerActive) return qsTr("PLEASE READ...");
                                if (mnjnefGuidelinesRoot.acceptedClauses < mnjnefGuidelinesRoot.totalClauses) return qsTr("ACCEPT ALL CLAUSES");
                                return qsTr("I AGREE & PROCEED");
                            }
                            color: acceptBtn.canAccept ? glTheme.textHeader : glTheme.textDisabled
                            font.pixelSize: 14
                            font.bold: true
                            font.family: glTheme.fontMain
                            font.letterSpacing: 1.0
                        }
                    }

                    MouseArea {
                        id: acceptMouse
                        anchors.fill: parent
                        hoverEnabled: acceptBtn.canAccept
                        cursorShape: acceptBtn.canAccept ? Qt.PointingHandCursor : Qt.ForbiddenCursor
                        
                        onClicked: {
                            if (acceptBtn.canAccept) {
                                mnjnefGuidelinesRoot.guidelinesAccepted()
                            }
                        }
                    }
                }
            }
        }
    }

    // ==========================================
    // LOGIC & CONTROLLERS
    // ==========================================
    
    function recalculateAcceptance() {
        let count = 0;
        for (let i = 0; i < guidelinesModel.count; i++) {
            if (guidelinesModel.get(i).isAccepted) count++;
        }
        mnjnefGuidelinesRoot.acceptedClauses = count;
    }

    Timer {
        id: mandatoryReadTimer
        interval: 1000
        repeat: true
        running: true
        
        onRunningChanged: {
            if (running) {
                // initialization if needed
            }
        }

        onTriggered: {
            if (mnjnefGuidelinesRoot.readingCountdown > 0) {
                mnjnefGuidelinesRoot.readingCountdown--;
            } else {
                mnjnefGuidelinesRoot.isTimerActive = false;
                stop();
            }
        }
    }
    
    // Auto-scroll simulation on load to hint there is content below
    Component.onCompleted: {
        startupAnimationTimer.start()
    }
    
    Timer {
        id: startupAnimationTimer
        interval: 500
        repeat: false
        onRunningChanged: { if(running){} }
        onTriggered: {
            guidelinesFlickable.contentY = 20;
            returnToTopAnim.start();
        }
    }
    
    NumberAnimation {
        id: returnToTopAnim
        target: guidelinesFlickable
        property: "contentY"
        to: 0
        duration: 400
        easing.type: Easing.OutQuad
    }
}
