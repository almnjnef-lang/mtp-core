class InformationScraper:
    """
    Ingests feeds, downloads HTML payloads, strips tracking noise,
    and returns sanitized data blocks ready for AI translation/rewriting.
    """
    def __init__(self):
        self.headers = {
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36",
            "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,*/*;q=0.8",
            "Accept-Language": "en-US,en;q=0.5"
        }

    def capture_feed_payload(self, category: str, target_feeds: List[str]) -> Optional[Tuple[str, str, str]]:
        """Selects an RSS node, parses entries, and verifies payload stability."""
        if not target_feeds:
            return None
            
        chosen_feed = random.choice(target_feeds)
        logger.info(f"Targeting syndication vector in [{category}]: {chosen_feed}")
        
        try:
            parsed_feed = feedparser.parse(chosen_feed)
            if not parsed_feed.entries:
                logger.warning(f"Syndication node is empty or malformed: {chosen_feed}")
                return None
                
            # Randomly pick from the top 3 latest entries to add variety
            entry_pool = parsed_feed.entries[:3]
            selected_entry = random.choice(entry_pool)
            target_url = selected_entry.link
            
            return target_url, selected_entry.title, getattr(selected_entry, 'description', '')
        except Exception as e:
            logger.error(f"Failed to digest syndication feed {chosen_feed}: {e}")
            return None

    def extract_deep_text(self, url: str, rss_description: str) -> Optional[str]:
        """Multi-stage HTML extraction with heuristic fallbacks."""
        logger.info(f"Initiating deep HTML extraction for: {url}")
        
        # Stage 1: Newspaper3k Premium Extraction
        try:
            article_model = Article(url, keep_article_html=False, browser_user_agent=self.headers['User-Agent'])
            article_model.download()
            article_model.parse()
            clean_text = article_model.text.strip()
            
            if len(clean_text) > 300:
                logger.debug("Stage 1 Extraction successful.")
                return clean_text
        except Exception as e:
            logger.debug(f"Stage 1 Extraction failed: {e}")
            
        # Stage 2: BeautifulSoup Custom Paragraph Extraction
        try:
            response = requests.get(url, headers=self.headers, timeout=MnjnefConfig.HTTP_TIMEOUT)
            if response.status_code == 200:
                soup = BeautifulSoup(response.text, "html.parser")
                
                # Remove script, style, header, footer, nav
                for element in soup(["script", "style", "header", "footer", "nav", "aside"]):
                    element.decompose()
                    
                paragraphs = soup.find_all("p")
                extracted_para = [p.get_text().strip() for p in paragraphs if len(p.get_text().strip()) > 40]
                compiled_text = "\n\n".join(extracted_para)
                
                if len(compiled_text) > 250:
                    logger.debug("Stage 2 Extraction successful.")
                    return compiled_text
        except Exception as e:
            logger.debug(f"Stage 2 Extraction failed: {e}")
            
        # Stage 3: RSS Description Fallback (Emergency)
        if rss_description:
            try:
                soup = BeautifulSoup(rss_description, "html.parser")
                sanitized_rss = soup.get_text().strip()
                if len(sanitized_rss) > 150:
                    logger.debug("Stage 3 Extraction successful (RSS Fallback).")
                    return sanitized_rss
            except Exception:
                pass
                
        logger.warning("All extraction stages failed to yield sufficient text.")
        return None


