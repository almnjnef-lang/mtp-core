        .meta {{ color: #6b7280; font-size: 0.95em; padding: 15px; background: #f9fafb; border-radius: 8px; border-left: 4px solid #3b82f6; margin-bottom: 40px; font-weight: 500; }}
        h2 {{ color: #1e40af; margin-top: 50px; font-size: 1.7em; font-weight: bold; }}
        p {{ font-size: 1.15em; color: #374151; margin-bottom: 25px; }}
        
        /* مواضيع ذات صلة - مربعات احترافية */
        .related-section {{ margin-top: 60px; padding-top: 40px; border-top: 4px solid #f3f4f6; }}
        .related-section h3 {{ font-size: 1.6em; color: #111827; margin-bottom: 20px; }}
