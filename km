                res = requests.get(url, timeout=15)
                if res.status_code == 200 and int(res.json().get('totalHits', 0)) > 0:
                    photo_url = random.choice(res.json()['hits'])['largeImageURL']
                    if cls._download_binary(photo_url, local_target_path):
                        logger.info("Success: Asset acquired via Pixabay.")
                        return f"/images/{filename}"
            except Exception as e:
                logger.debug(f"Provider 4 failed: {e}")

        # ---------------------------------------------------------
        # PROVIDER 5: Unsplash Source (Open Endpoint)
        # ---------------------------------------------------------
