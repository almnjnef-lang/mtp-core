import QtQuick
import QtQuick.Controls
import QtQuick.Layouts

Item {
    id: mnjnefTicketTrackerRoot
    anchors.fill: parent
    clip: true

    // ==========================================
    // SYSTEM SIGNALS & PROPERTIES
    // ==========================================
    signal returnToDashboard()
    signal actionRequested(string actionType)

    property string ticketId: "TKT-849201"
    property string ticketStatus: "IN_PROGRESS" // PENDING, IN_PROGRESS, RESOLVED, CLOSED
    property string ticketPriority: "HIGH"
    property int currentTimelineStep: 2 // 0: Submitted, 1: System Check, 2: Agent Assigned, 3: Resolved
    
    // Live Agent Properties
    property string agentName: "Operative_Vanguard"
    property string agentStatus: "ONLINE"
    property bool isAgentTyping: false
    
    // Telemetry Properties
    property string userPing: "12ms"
    property string serverNode: "DXB-CORE-01"
    property string activeUptime: "00:14:32"

    // ==========================================
    // THEME & STYLING CORE
    // ==========================================
    QtObject {
        id: trackTheme
        property color bgPrimary: "#02040a"
        property color bgPanel: "#0d1117"
        property color bgElevated: "#161b22"
        property color bgInput: "#010409"
        
