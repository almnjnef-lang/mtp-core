# إيقاف جميع العمليات المعلقة
pkill -f run_bot.sh
pkill -f the_king_commander.sh
pkill -f mnjnef_factory.py

cat << 'EOF' > /root/restore_engine.py
import os, re

print("🛠️ جاري ترميم الأسطر المكسورة في المحرك...")
path = "/root/mnjnef_factory.py"

if os.path.exists(path):
    with open(path, "r", encoding="utf-8") as f:
        code = f.read()

    # إعادة تفعيل أسطر except التي تم تعطيلها سابقاً بالخطأ
    code = re.sub(r'^(\s*)# 🔪 استئصال ملكي:\s*(except.*)', r'\1\2', code, flags=re.MULTILINE)
    
    # تأمين أسطر try اليتيمة في حال عدم وجود except
    code = re.sub(r'^(\s*)try:\s*\n(\s*import urllib\.parse as up)', r'\1try:\n\2\n\1except Exception:\n\1    pass', code, flags=re.MULTILINE)

    with open(path, "w", encoding="utf-8") as f:
        f.write(code)
    
    print("✅ تم ترميم الكود بنجاح. السيرفر جاهز للعمل.")
else:
    print("❌ لم يتم العثور على الملف.")
EOF

python3 /root/restore_engine.py

# إعادة تشغيل الروبوت الأساسي في الخلفية ليواصل النشر
cat << 'EOF' > /root/run_bot.sh
#!/bin/bash
while true; do
    python3 /root/mnjnef_factory.py >> /root/mnjnef_factory.log 2>&1
    sleep 5
done
EOF

chmod +x /root/run_bot.sh
nohup /root/run_bot.sh > /dev/null 2>&1 &

echo "🚀 تم إطلاق المحرك من جديد في الخلفية. يمكنك الآن إغلاق الكمبيوتر."
tail -f /root/mnjnef_factory.log
