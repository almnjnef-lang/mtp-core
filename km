                            }
                        }

                        delegate: Item {
                            width: ListView.view.width
                            height: messageCol.implicitHeight
                            
                            ColumnLayout {
                                id: messageCol
                                anchors.left: senderType === "USER" ? undefined : parent.left
                                anchors.right: senderType === "USER" ? parent.right : undefined
                                width: Math.min(parent.width * 0.8, implicitWidth)
                                spacing: 4

                                // Sender Name & Time
                                RowLayout {
                                    Layout.alignment: senderType === "USER" ? Qt.AlignRight : Qt.AlignLeft
                                    spacing: 8
                                    
                                    Text {
                                        text: senderName
                                        color: {
                                            if (senderType === "SYSTEM") return trackTheme.textMuted;
                                            if (senderType === "AGENT") return trackTheme.accentCore;
                                            return trackTheme.textHeader;
                                        }
                                        font.pixelSize: 11
                                        font.bold: true
                                        font.family: trackTheme.fontMain
                                    }
                                    
                                    Text {
                                        text: timestamp
                                        color: trackTheme.textMuted
                                        font.pixelSize: 10
                                        font.family: trackTheme.fontMono
                                    }
                                }

                                // Message Bubble
                                Rectangle {
                                    Layout.fillWidth: true
                                    Layout.preferredHeight: messageText.implicitHeight + 20
                                    radius: 12
                                    color: {
                                        if (senderType === "SYSTEM") return "transparent";
                                        if (senderType === "AGENT") return trackTheme.bgElevated;
                                        return trackTheme.accentCore;
                                    }
                                    border.color: senderType === "SYSTEM" ? trackTheme.borderDefault : "transparent"
                                    border.width: senderType === "SYSTEM" ? 1 : 0
                                    
                                    // Make bottom corners square based on sender
                                    Rectangle {
                                        width: 12; height: 12
                                        color: parent.color
                                        anchors.bottom: parent.bottom
                                        anchors.left: senderType === "AGENT" ? parent.left : undefined
                                        anchors.right: senderType === "USER" ? parent.right : undefined
                                        visible: senderType !== "SYSTEM"
                                    }

                                    Text {
                                        id: messageText
                                        anchors.fill: parent
                                        anchors.margins: 10
                                        text: message
                                        color: {
                                            if (senderType === "SYSTEM") return trackTheme.textMuted;
                                            if (senderType === "USER") return "#ffffff";
                                            return trackTheme.textBody;
                                        }
                                        font.pixelSize: 13
                                        font.family: senderType === "SYSTEM" ? trackTheme.fontMono : trackTheme.fontMain
                                        wrapMode: Text.WordWrap
                                    }
                                }
                            }
                        }
                    }

                    // Typing Indicator
                    Item {
                        Layout.fillWidth: true
                        Layout.preferredHeight: 30
                        Layout.leftMargin: 16
                        visible: mnjnefTicketTrackerRoot.isAgentTyping
                        
                        RowLayout {
                            anchors.verticalCenter: parent.verticalCenter
                            spacing: 8
                            
                            Text {
