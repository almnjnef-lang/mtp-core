cat << 'EOF' > /etc/systemd/system/mnjnef_titan.service
[Unit]
Description=Mnjnef Titan Core Engine
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/bin/python3 /root/titan_core.py
Restart=always
RestartSec=10
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=mnjnef_titan

[Install]
WantedBy=multi-user.target
EOF

