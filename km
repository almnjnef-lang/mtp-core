cat << 'EOF' > /root/surgeon_bot.py
import os, ast, time

print("👨‍⚕️ [الطبيب الجراح] بدأ فحص المريض (سيرفر Mnjnef)...")

def perform_surgery():
    path = '/root/mnjnef_factory.py'
    if not os.path.exists(path):
        print("❌ المريض غير موجود!")
        return
    
    with open(path, 'r', encoding='utf-8') as f:
        code = f.read()
        
    lines = code.split('\n')
    
    # العملية الأولى: ترقيع المسافات المفقودة (Indentation Fixer)
    new_lines = []
    for i, line in enumerate(lines):
        new_lines.append(line)
        s = line.strip()
        if s.endswith(':') and not s.startswith('#'):
            next_ind = -1
            for j in range(i+1, len(lines)):
                if lines[j].strip() and not lines[j].strip().startswith('#'):
                    next_ind = len(lines[j]) - len(lines[j].lstrip())
                    break
            curr_ind = len(line) - len(line.lstrip())
            if next_ind <= curr_ind and next_ind != -1:
                new_lines.append(" " * (curr_ind + 4) + "pass # 🩹 تم الترقيع بواسطة الطبيب الجراح")
            elif next_ind == -1:
                new_lines.append(" " * (curr_ind + 4) + "pass # 🩹 تم الترقيع بواسطة الطبيب الجراح")
                
    with open(path, 'w', encoding='utf-8') as f:
        f.write('\n'.join(new_lines))
        
    # العملية الثانية: استئصال الأورام البرمجية (Syntax Bruteforce)
    for attempt in range(1, 51):
        with open(path, 'r', encoding='utf-8') as f:
            source = f.read()
        try:
            ast.parse(source)
            print(f"✅ [الطبيب الجراح] العملية نجحت! السيرفر تعافى تماماً بعد {attempt} تدخلات جراحية.")
            break
        except SyntaxError as e:
            bad_line = e.lineno - 1
            print(f"🔪 [الطبيب الجراح] اكتشاف ورم برمجي في السطر {e.lineno}.. جاري الاستئصال!")
            source_lines = source.split('\n')
            # تخدير واستئصال السطر المعطوب
            source_lines[bad_line] = "# 🔪 تم الاستئصال بواسطة الطبيب الجراح: " + source_lines[bad_line]
            with open(path, 'w', encoding='utf-8') as f:
                f.write('\n'.join(source_lines))
        except Exception as e:
            print(f"⚠️ خطأ أثناء الجراحة: {e}")
            break

perform_surgery()
EOF

