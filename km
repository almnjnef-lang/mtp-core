# 1. إيقاف كل شيء قديم لتنظيف الذاكرة
pkill -f run_bot.sh
pkill -f the_king_commander.sh
pkill -f mnjnef_factory.py
pkill -f awakener_robot.sh

# 2. صناعة "الروبوت المُوقِظ" (The Awakener)
cat << 'EOF' > /root/awakener_robot.sh
#!/bin/bash
echo "⚡ [الروبوت المُوقِظ] بدأ العمل.. لا مجال للنوم بعد اليوم!"

# البحث عن مجلد الموقع بذكاء
SITE_DIR=$(find /root /var/www -maxdepth 3 -name "config.toml" -o -name "hugo.toml" | head -n 1 | xargs dirname)

while true; do
    # المهمة 1: إيقاظ القوات الخاصة إذا توقفت
    if ! pgrep -f "mnjnef_factory.py" > /dev/null; then
        echo "⚠️ [الروبوت المُوقِظ] القوات الخاصة نائمة! جاري الإيقاظ الإجباري..."
        nohup python3 /root/mnjnef_factory.py > /root/sf_1.log 2>&1 &
        nohup python3 /root/mnjnef_factory.py > /root/sf_2.log 2>&1 &
        nohup python3 /root/mnjnef_factory.py > /root/sf_3.log 2>&1 &
    fi

    # المهمة 2: تجميع المقالات ونشرها بقوة للجمهور (تحديث الواجهة)
    if [ -d "$SITE_DIR" ]; then
        cd "$SITE_DIR"
        hugo --gc --minify > /dev/null 2>&1
        cp -r public/* /var/www/html/ 2>/dev/null
        cp -r public/* /var/www/mnjnef.com/ 2>/dev/null
        echo "🌐 [الروبوت المُوقِظ] تم تحديث واجهة Mnjnef ونشر المقالات الجديدة!"
    fi

    # الانتظار 30 ثانية قبل الدورة التالية
    sleep 30
done
EOF

# 3. إعطاء الصلاحيات وإطلاق الروبوت الموقظ في الخلفية
chmod +x /root/awakener_robot.sh
nohup /root/awakener_robot.sh > /root/awakener.log 2>&1 &

echo "🎉 تمت المهمة! الروبوت المُوقِظ يعمل الآن في الخلفية ويقود جيوش النشر."
echo "جاري عرض تقارير الروبوت المُوقِظ المباشرة..."
tail -f /root/awakener.log
