Description=Mnjnef Direct HTML Engine
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/bin/python3 /root/direct_mistral_engine.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
SRV

