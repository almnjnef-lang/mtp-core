# 2. سد الفراغات التي تسبب (IndentationError)
cat << 'EOF' > /root/fill_gaps.py
import os

path = "/root/mnjnef_factory.py"
print("🔍 جاري سد الفراغات في السيرفر...")

with open(path, "r", encoding="utf-8") as f:
    lines = f.readlines()

new_lines = []
for i in range(len(lines)):
    line = lines[i]
    new_lines.append(line)
    stripped = line.strip()
    
    # إذا وجدنا except نبحث هل تحتها فراغ؟
    if stripped.startswith("except") and stripped.endswith(":"):
        current_indent = len(line) - len(line.lstrip())
        needs_pass = True
        
        for j in range(i+1, min(i+10, len(lines))):
            next_str = lines[j].strip()
            if not next_str or next_str.startswith("#"):
                continue
            next_ind = len(lines[j]) - len(lines[j].lstrip())
            if next_ind > current_indent:
                needs_pass = False # يوجد كود، لا نحتاج pass
            break
            
        if needs_pass:
            new_lines.append(" " * (current_indent + 4) + "pass\n")

with open(path, "w", encoding="utf-8") as f:
    f.writelines(new_lines)

print("✅ تم سد الفراغات! خطأ IndentationError اختفى نهائياً.")
EOF

python3 /root/fill_gaps.py

