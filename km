                        text: qsTr("RESOLUTION PROTOCOL SEQUENCE")
                        color: trackTheme.textHeader
                        font.pixelSize: 13
                        font.bold: true
                        font.family: trackTheme.fontMain
                    }

                    ListView {
                        Layout.fillWidth: true
                        Layout.fillHeight: true
                        model: timelineModel
                        interactive: false
                        spacing: 0
                        
                        delegate: Item {
                            width: ListView.view.width
                            height: 60
                            
                            // Connecting Line
                            Rectangle {
                                width: 2
                                height: parent.height
                                color: stepIndex < mnjnefTicketTrackerRoot.currentTimelineStep ? trackTheme.accentCore : trackTheme.borderDefault
                                x: 15
                                y: 30
                                visible: index < timelineModel.count - 1
                            }
                            
                            RowLayout {
                                anchors.fill: parent
                                spacing: 16
                                
                                // Node Indicator
                                Item {
                                    Layout.preferredWidth: 32
                                    Layout.preferredHeight: 32
                                    Layout.alignment: Qt.AlignTop
                                    
                                    Rectangle {
                                        anchors.centerIn: parent
                                        width: 24
                                        height: 24
                                        radius: 12
                                        color: trackTheme.bgElevated
                                        border.color: {
                                            if (stepIndex < mnjnefTicketTrackerRoot.currentTimelineStep) return trackTheme.stateSuccess;
                                            if (stepIndex === mnjnefTicketTrackerRoot.currentTimelineStep) return trackTheme.accentCore;
                                            return trackTheme.borderDefault;
                                        }
                                        border.width: stepIndex === mnjnefTicketTrackerRoot.currentTimelineStep ? 2 : 1
                                        
                                        Text {
                                            anchors.centerIn: parent
                                            text: stepIndex < mnjnefTicketTrackerRoot.currentTimelineStep ? "✓" : (stepIndex === mnjnefTicketTrackerRoot.currentTimelineStep ? "●" : "")
                                            color: stepIndex < mnjnefTicketTrackerRoot.currentTimelineStep ? trackTheme.stateSuccess : trackTheme.accentCore
                                            font.pixelSize: 12
                                            font.bold: true
                                        }
                                        
                                        // Pulse for active step
                                        Rectangle {
                                            anchors.fill: parent
                                            radius: 12
                                            color: "transparent"
                                            border.color: trackTheme.accentCore
                                            border.width: 2
                                            visible: stepIndex === mnjnefTicketTrackerRoot.currentTimelineStep
                                            
