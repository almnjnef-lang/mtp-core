pkill -f run_bot.sh
pkill -f mnjnef_factory.py

cat << 'EOF' > /root/smart_category_scanner.py
import os, glob, re, subprocess

print("🚀 جاري تفعيل نظام (الفرز الذكي الصارم) للموسوعة...")

# العقل الفاحص (يقرأ المقال ويحدد قسمه بدقة)
router_func = """
def get_strict_category(text):
    if not text: return 'Global_Discoveries'
    text = str(text).lower()
    if any(w in text for w in ['health', 'medicine', 'disease', 'weight', 'diet', 'covid', 'brain', 'body', 'symptom', 'doctor', 'cancer', 'obesity', 'menopause', 'fat', 'blood', 'virus', 'syndrome', 'clinical', 'hospital']): return 'Science_and_Health'
    if any(w in text for w in ['tech', 'software', 'apple', 'google', 'cyber', 'ai ', 'cloud', 'app ', 'digital', 'data', 'algorithm', 'device', 'quantum', 'computing', 'robot']): return 'Technology'
    if any(w in text for w in ['history', 'ancient', 'war', 'century', 'empire', 'historical', 'museum', 'archaeology', 'dynasty', 'civilization']): return 'World_History'
    if any(w in text for w in ['economy', 'business', 'market', 'stock', 'trade', 'finance', 'money', 'startup', 'import', 'export', 'tax', 'inflation', 'industry']): return 'Business_and_Economy'
    if any(w in text for w in ['space', 'nasa', 'mars', 'moon', 'galaxy', 'planet', 'astronomy', 'telescope', 'black hole', 'universe', 'orbit']): return 'Space_Exploration'
    if any(w in text for w in ['education', 'school', 'university', 'student', 'teacher', 'learning', 'study', 'academic', 'college']): return 'Global_Education'
    if any(w in text for w in ['art', 'culture', 'music', 'movie', 'film', 'painting', 'artist', 'festival', 'literature']): return 'Arts_and_Culture'
    if any(w in text for w in ['environment', 'climate', 'warming', 'green', 'pollution', 'earth', 'weather', 'sustainable', 'ecology']): return 'Environment'
    if any(w in text for w in ['sport', 'football', 'basketball', 'olympic', 'athlete', 'gym', 'workout', 'fitness', 'soccer', 'tournament']): return 'Physical_Sports'
    if any(w in text for w in ['travel', 'tourism', 'hotel', 'flight', 'destination', 'tourist', 'resort', 'vacation']): return 'Tourism_and_Travel'
    if any(w in text for w in ['animal', 'wildlife', 'nature', 'forest', 'ocean', 'species', 'bird', 'fish', 'botanical', 'mammal']): return 'Nature_and_Wildlife'
    return 'Global_Discoveries'
"""

# 1. زرع العقل الفاحص في الروبوت
bot_path = "/root/mnjnef_factory.py"
if os.path.exists(bot_path):
    with open(bot_path, "r", encoding="utf-8") as f:
        code = f.read()
    
    if "def get_strict_category" not in code:
        code = router_func + "\n" + code
        
    # إجبار الروبوت على تصنيف المقال بناءً على نصه النهائي بدلاً من التخمين
    if "category = get_strict_category" not in code:
        code = re.sub(r'(journalism_payload\s*=\s*.*?)\n', r'\1\n        category = get_strict_category(journalism_payload)\n', code)
        
    with open(bot_path, "w", encoding="utf-8") as f:
        f.write(code)
    print("✅ 1. تم زرع (العقل الفاحص) في الروبوت.. لن يخطئ في تصنيف أي مقال قادم!")

# 2. إصلاح المقالات القديمة المبعثرة
configs = glob.glob('/root/**/config.toml', recursive=True) + glob.glob('/root/**/hugo.toml', recursive=True) + glob.glob('/var/www/**/config.toml', recursive=True) + glob.glob('/var/www/**/hugo.toml', recursive=True)
if configs:
    site_dir = os.path.dirname(configs[0])
    posts_dir = os.path.join(site_dir, 'content', 'posts')
    
    exec(router_func) 
    
    fixed = 0
    for filepath in glob.glob(os.path.join(posts_dir, '*.md')):
        with open(filepath, 'r', encoding='utf-8') as f:
            content = f.read()
        
        parts = content.split('---', 2)
        if len(parts) >= 3:
            front = parts[1]
            body = parts[2]
            
            # فحص المقال وتحديد قسمه الجديد
            correct_cat = get_strict_category(body)
            
            # تبديل القسم القديم بالقسم الصحيح
            new_front = re.sub(r'categories:\s*\[.*?\]', f'categories: ["{correct_cat}"]', front)
            
            with open(filepath, 'w', encoding='utf-8') as f:
                f.write(f"---{new_front}---{body}")
            fixed += 1
            
    print(f"✅ 2. تم قراءة {fixed} مقال سابق، وإعادة توجيهها للأقسام الصحيحة بدقة.")
    
    # تحديث الموقع
    subprocess.run(["hugo", "--gc", "--minify"], cwd=site_dir, capture_output=True)
    for dest in ['/var/www/html', '/var/www/mnjnef', '/var/www/mnjnef.com']:
        if os.path.exists(dest):
            subprocess.run(f"cp -r {os.path.join(site_dir, 'public')}/* {dest}/ 2>/dev/null", shell=True)
    print("⚙️ 3. تم تحديث الواجهة وتطبيق التنظيف الشامل.")

print("🎉 اكتملت المهمة! جاري إطلاق المحرك...")
EOF

python3 /root/smart_category_scanner.py

nohup /root/run_bot.sh > /dev/null 2>&1 &
tail -f /root/mnjnef_factory.log
