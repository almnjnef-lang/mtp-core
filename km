                    except json.JSONDecodeError as je:
                        logger.error(f"Catastrophic JSON parsing failure: {je}. Raw output snippet: {raw_payload[:100]}")
                        
                elif response.status_code == 429:
                    sleep_duration = (MnjnefConfig.BACKOFF_FACTOR ** attempt) * 15
                    logger.warning(f"Rate Limit 429 Hit. Applying exponential backoff: {sleep_duration}s...")
                    time.sleep(sleep_duration)
                else:
                    logger.error(f"Mistral API returned status code {response.status_code}: {response.text}")
                    
            except requests.exceptions.RequestException as e:
                logger.error(f"Network fragmentation during AI transmission: {e}")
                
            time.sleep(5)
        return None


