# 🤖 8. MISTRAL AI ENGINE (STRICT NON-POLITICAL JOURNALIST)
# ==============================================================================
class AIEngine:
    def __init__(self, api_key: str):
        self.api_key = api_key
        self.headers = {
            "Content-Type": "application/json",
            "Authorization": f"Bearer {self.api_key}"
        }

    def _craft_prompt(self, category: str, text: str) -> str:
        cat_name = category.replace('_', ' ')
        return (
            f"You are the Pulitzer-winning Editor-in-Chief for 'Mnjnef', an elite global publication. "
            f"Rewrite this {cat_name} report into a completely original, engaging, and highly professional article in fluent English.\n\n"
            "STRICT RULES:\n"
            "1. NO POLITICS. If the text contains political content, reframe it strictly to its technological, scientific, or business impact.\n"
            "2. FIRST LINE MUST BE EXACTLY: 'TITLE: [Your Compelling Headline]'\n"
            "3. Below the title, output the full article body.\n"
            "4. DO NOT copy the original text. Paraphrase entirely using an authoritative tone.\n"
            "5. Organize with professional Markdown subheadings (##).\n"
            "6. NO conversational filler. ONLY the title and body.\n\n"
            f"--- ORIGINAL TEXT ---\n{text}\n--- END ORIGINAL TEXT ---"
        )

    def rewrite_content(self, category: str, text: str) -> Optional[Dict[str, str]]:
        prompt = self._craft_prompt(category, text)
        payload = {
            "model": MnjnefConfig.MODEL,
            "messages": [{"role": "user", "content": prompt}],
            "temperature": MnjnefConfig.AI_TEMPERATURE,
            "max_tokens": MnjnefConfig.MAX_AI_TOKENS
        }

        for attempt in range(MnjnefConfig.MAX_RETRIES):
            try:
                resp = requests.post(MnjnefConfig.API_URL, headers=self.headers, json=payload, timeout=120)
                if resp.status_code == 200:
                    raw_content = resp.json()['choices'][0]['message']['content'].strip()
                    return self._parse_ai_response(raw_content)
                elif resp.status_code == 429:
                    delay = MnjnefConfig.BASE_RETRY_DELAY * (attempt + 2) * 2
                    logger.warning(f"Rate limited (429). AI Core cooling for {delay}s...")
                    time.sleep(delay)
                    continue
                else:
                    logger.error(f"AI API Error {resp.status_code}: {resp.text}")
            except requests.exceptions.RequestException as e:
                logger.error(f"Network error to AI Core: {e}")
            
            time.sleep(MnjnefConfig.BASE_RETRY_DELAY * (2 ** attempt))
            
        logger.error("AI Generation failed after all retries.")
        return None

    def _parse_ai_response(self, raw_text: str) -> Dict[str, str]:
        lines = raw_text.split('\n')
        title = "Mnjnef Discoveries"
        body_lines = []
        
        for i, line in enumerate(lines):
            clean_line = line.strip()
            if clean_line.upper().startswith("TITLE:"):
                title = clean_line[6:].replace('"', '').strip()
            elif i == 0 and not clean_line.startswith('#') and len(clean_line) < MnjnefConfig.MAX_TITLE_LENGTH:
                title = clean_line.replace('"', '').strip()
            else:
                body_lines.append(line)
                
        body = '\n'.join(body_lines).strip()
        if title.startswith("#"):
            title = title.replace("#", "").strip()
            
        return {"title": title, "body": body}

