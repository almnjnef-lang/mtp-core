    <title>{clean_title} - Mnjnef Encyclopedia</title>
    <style>
        body {{ font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; line-height: 1.8; color: #111827; background: #ffffff; margin: 0; }}
        header {{ padding: 20px; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; background: #ffffff; z-index: 100; border-bottom: 1px solid #e5e7eb; }}
        .logo {{ font-size: 1.5em; font-weight: 800; color: #1e3a8a; text-decoration: none; letter-spacing: -0.5px; }}
        .home-btn {{ background: #f3f4f6; color: #4b5563; padding: 8px 16px; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 0.9em; border: 1px solid #e5e7eb; }}
        .container {{ max-width: 800px; margin: 40px auto; padding: 0 20px; }}
        h1 {{ font-size: 2.6em; line-height: 1.2; margin-bottom: 20px; color: #111827; font-weight: 800; }}
        .meta {{ color: #6b7280; font-size: 0.95em; padding-bottom: 30px; border-bottom: 1px solid #f3f4f6; margin-bottom: 30px; }}
        h2 {{ color: #1e40af; margin-top: 40px; font-size: 1.6em; font-weight: bold; }}
        p {{ font-size: 1.15em; color: #374151; margin-bottom: 25px; }}
        
        .tags-container {{ display: flex; flex-wrap: wrap; gap: 10px; margin-top: 50px; padding-top: 30px; border-top: 1px solid #f3f4f6; }}
        .tag-pill {{ background: #f9fafb; border: 1px solid #e5e7eb; color: #4b5563; padding: 8px 15px; border-radius: 20px; text-decoration: none; font-size: 0.9em; font-weight: 500; transition: 0.2s; }}
        .tag-pill:hover {{ background: #eff6ff; border-color: #bfdbfe; color: #1d4ed8; }}
        
        footer {{ text-align: center; padding: 40px; color: #9ca3af; margin-top: 40px; font-size: 0.9em; border-top: 1px solid #f3f4f6; }}
        @media(max-width: 600px) {{ h1 {{ font-size: 2.1em; }} }}
    </style>
</head>
<body>
    <header><a href="/" class="logo">Mnjnef Encyclopedia</a><a href="/" class="home-btn">Library Home</a></header>
