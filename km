                Layout.fillHeight: true
                color: trackTheme.bgPanel
                radius: 12
                border.color: trackTheme.borderDefault
                border.width: 1
                clip: true

                ColumnLayout {
                    anchors.fill: parent
                    anchors.margins: 20
                    spacing: 16

