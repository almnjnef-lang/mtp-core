import time
from collections import defaultdict

# ==========================================
# ALMNJNEF NETWORK FIREWALL & RATE LIMITER
# ==========================================
# This microservice protects the centralized API 
# from DDoS attacks, buffer overflows, and packet spamming.

class NetworkFirewall:
    def __init__(self, max_packets_per_second=10, max_packet_size=2048):
        self.max_packets = max_packets_per_second
        self.max_size = max_packet_size
        self.packet_records = defaultdict(list)
        self.blacklisted_ips = set()

    def analyze_packet(self, ip_address, packet_size):
        """
        Analyzes incoming packets. 
        Returns True if allowed, False if blocked.
        """
        current_time = time.time()

        # 1. Check if IP is already in the blacklist
        if ip_address in self.blacklisted_ips:
            return False

        # 2. Clean up old packet records (older than 1 second window)
        self.packet_records[ip_address] = [
            timestamp for timestamp in self.packet_records[ip_address] 
            if current_time - timestamp < 1.0
        ]

        # 3. Add the new packet timestamp
        self.packet_records[ip_address].append(current_time)

        # 4. Check against the threshold (Rate Limiting)
        if len(self.packet_records[ip_address]) > self.max_packets:
            print(f"[FIREWALL WARNING] IP {ip_address} exceeded packet limit! Blacklisting...")
            self.blacklisted_ips.add(ip_address)
            return False

        # 5. Prevent oversized anomalous packets (Buffer Overflow protection)
        if packet_size > self.max_size:
            print(f"[FIREWALL ALERT] Dropped oversized packet ({packet_size} bytes) from {ip_address}.")
            return False

        return True

