    // SYSTEM SIGNALS & STATE PROPERTIES
    // ==========================================
    property string activeUser: "Commander"
    property string currentTimeString: "00:00:00"
    property real networkPing: 12.5
    property int activeTickets: 2
    property bool isSystemOnline: true

    // ==========================================
    // HIGH-CONTRAST THEME CORE
    // ==========================================
