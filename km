# 🧠 6. SEO & TEXT ANALYSIS ENGINE
# ==============================================================================
class SEOEngine:
    STOP_WORDS: Set[str] = {
        'the', 'is', 'in', 'and', 'to', 'a', 'of', 'for', 'on', 'with', 'as', 
        'by', 'at', 'an', 'be', 'this', 'that', 'from', 'it', 'are', 'was', 
        'or', 'will', 'has', 'have', 'not', 'but', 'its', 'they', 'their',
        'who', 'what', 'when', 'where', 'why', 'how', 'which', 'about', 'more',
        'could', 'would', 'should', 'these', 'those', 'then', 'than', 'been'
    }
    
    @classmethod
    def generate_slug(cls, title: str) -> str:
        slug = title.lower()
        slug = re.sub(r'[^a-z0-9\s-]', '', slug)
        slug = re.sub(r'[-\s]+', '-', slug).strip('-')
        return slug[:80] if slug else f"mnjnef-article-{int(time.time())}"
        
    @classmethod
    def extract_keywords(cls, text: str, max_keywords: int = 6) -> List[str]:
        words = re.findall(r'\b[a-zA-Z]{5,}\b', text.lower())
        word_counts = {}
        for w in words:
            if w not in cls.STOP_WORDS:
                word_counts[w] = word_counts.get(w, 0) + 1
        
        sorted_words = sorted(word_counts.items(), key=lambda x: x[1], reverse=True)
        return [word for word, count in sorted_words[:max_keywords]]

