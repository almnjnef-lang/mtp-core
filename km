# 2. تعميم الصفحة لجميع روابط الموقع
cp /var/www/html/index.html /var/www/mnjnef.com/index.html

# 3. إجبار السيرفر على تحديث الواجهة فوراً برمجياً
sed -i '/save_db(\[\])/a build_homepage()' /root/titan_seo_engine.py

# 4. تثبيت الصلاحيات بشكل قطعي وإعادة تشغيل السيرفرات
chown -R www-data:www-data /var/www/html /var/www/mnjnef.com
chmod -R 755 /var/www/html /var/www/mnjnef.com
systemctl restart nginx
systemctl restart mnjnef_direct

echo "✅ تم تدمير 403! افتح موقعك الآن وسترى النتيجة بعينك."
