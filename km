import QtQuick
import QtQuick.Controls
import QtQuick.Layouts
import QtQuick.Window

ApplicationWindow {
    id: mnjnefRootWindow
    width: 1280
    height: 720
    visible: true
    title: "Mnjnef Platform - Authentication"
    
    // Base fallback color
    color: "#050B14" 

    // ==========================================
    // GLOBAL THEME (PREMIUM GAMING BLUE)
    // ==========================================
    QtObject {
        id: gamingTheme
        // Deep immersive blue backgrounds
        property color bgApp: "#070E1D"          // Deepest navy blue
        property color bgCard: "#0D1936"         // Card background (Dark Blue)
        property color bgInput: "#0A1329"        // Inset input field blue
        property color bgHover: "#15264D"        // Hover state blue
        
        // Borders
        property color borderSubtle: "#1C356B"   // Soft blue border
        property color borderFocus: "#00E5FF"    // Neon Cyan for active focus
        
        // Text
        property color textPrimary: "#FFFFFF"    // Pure white
        property color textSecondary: "#94A3B8"  // Blue-gray for secondary text
        property color textMuted: "#475569"      // Muted dark blue-gray
        
        // Accents
        property color accentPrimary: "#0070D1"  // PlayStation-esque solid blue
        property color accentHighlight: "#00E5FF"// Steam-esque bright cyan
        property color error: "#FF3366"          // Vibrant red-pink for errors
        
        property string fontMain: "Segoe UI"
        property string fontMono: "Consolas"
    }

    // ==========================================
    // CENTRAL ROUTING ENGINE (STACKVIEW)
    // ==========================================
    StackView {
        id: mainRouter
        anchors.fill: parent
        initialItem: loginComponent

        // Premium snappy transitions
        pushEnter: Transition {
            PropertyAnimation { property: "opacity"; from: 0.0; to: 1.0; duration: 250 }
            PropertyAnimation { property: "scale"; from: 0.95; to: 1.0; duration: 250; easing.type: Easing.OutQuart }
        }
        pushExit: Transition {
            PropertyAnimation { property: "opacity"; from: 1.0; to: 0.0; duration: 200 }
        }
        popEnter: Transition {
            PropertyAnimation { property: "opacity"; from: 0.0; to: 1.0; duration: 250 }
        }
        popExit: Transition {
            PropertyAnimation { property: "opacity"; from: 1.0; to: 0.0; duration: 200 }
            PropertyAnimation { property: "scale"; from: 1.0; to: 0.95; duration: 250; easing.type: Easing.OutQuart }
        }
    }

    // ==========================================
    // LOGIN COMPONENT
    // ==========================================
    Component {
        id: loginComponent

        Item {
            anchors.fill: parent

            // 1. PREMIUM BLUE GRADIENT BACKGROUND
            Rectangle {
                anchors.fill: parent
                gradient: Gradient {
                    GradientStop { position: 0.0; color: "#060D20" } // Top: Near Black Blue
                    GradientStop { position: 0.5; color: "#0B1B42" } // Middle: Deep Royal Blue
                    GradientStop { position: 1.0; color: "#040914" } // Bottom: Void Blue
                }
            }
            
            // Subtle ambient light effect in the background
            Rectangle {
                width: parent.width * 0.8
                height: parent.width * 0.8
                radius: width / 2
                anchors.centerIn: parent
                color: gamingTheme.accentPrimary
                opacity: 0.05
                // antialiasing ensures smooth edges without extra modules
                antialiasing: true 
            }

            // 2. MAIN LOGIN PANEL
            Rectangle {
                id: loginPanel
                width: 460
                height: 580
                anchors.centerIn: parent
                color: gamingTheme.bgCard
                radius: 16
                border.color: gamingTheme.borderSubtle
                border.width: 1
                
                // Inner glow simulation for premium feel
                Rectangle {
                    anchors.fill: parent
                    anchors.margins: 1
                    radius: 15
                    color: "transparent"
                    border.color: "#1Affffff"
                    border.width: 1
                }

                ColumnLayout {
                    anchors.fill: parent
                    anchors.margins: 40
                    spacing: 24

                    // HEADER
                    ColumnLayout {
                        Layout.fillWidth: true
                        spacing: 8
                        Layout.alignment: Qt.AlignHCenter

                        Text {
                            text: "MNJNEF"
                            color: gamingTheme.textPrimary
                            font.pixelSize: 36
                            font.bold: true
                            font.family: gamingTheme.fontMain
                            font.letterSpacing: 6.0
                            Layout.alignment: Qt.AlignHCenter
                            
                            // Subtle text glow
                            layer.enabled: true
                        }

                        Text {
                            text: "Global Digital Gaming Platform"
                            color: gamingTheme.accentHighlight
                            font.pixelSize: 13
                            font.bold: true
                            font.family: gamingTheme.fontMain
                            Layout.alignment: Qt.AlignHCenter
                            font.letterSpacing: 1.0
                        }
                    }

                    // INPUT FIELDS
                    ColumnLayout {
                        Layout.fillWidth: true
                        spacing: 18
                        Layout.topMargin: 20

                        // Username Input
                        Rectangle {
                            Layout.fillWidth: true
                            Layout.preferredHeight: 52
                            radius: 8
                            color: gamingTheme.bgInput
                            border.color: usernameInput.activeFocus ? gamingTheme.borderFocus : gamingTheme.borderSubtle
                            border.width: usernameInput.activeFocus ? 2 : 1
                            
                            Behavior on border.color { ColorAnimation { duration: 150 } }

                            TextInput {
                                id: usernameInput
                                anchors.fill: parent
                                anchors.margins: 16
                                color: gamingTheme.textPrimary
                                font.pixelSize: 15
                                font.family: gamingTheme.fontMain
                                verticalAlignment: TextInput.AlignVCenter
                                selectByMouse: true
                                
                                Text {
                                    text: "Mnjnef ID / Username"
                                    color: gamingTheme.textSecondary
                                    font.pixelSize: 15
                                    font.family: gamingTheme.fontMain
                                    visible: !usernameInput.text && !usernameInput.activeFocus
                                    anchors.verticalCenter: parent.verticalCenter
                                }
                            }
                        }

                        // Password Input
                        Rectangle {
                            Layout.fillWidth: true
                            Layout.preferredHeight: 52
                            radius: 8
                            color: gamingTheme.bgInput
                            border.color: passwordInput.activeFocus ? gamingTheme.borderFocus : gamingTheme.borderSubtle
                            border.width: passwordInput.activeFocus ? 2 : 1
                            
                            Behavior on border.color { ColorAnimation { duration: 150 } }

                            RowLayout {
                                anchors.fill: parent
                                anchors.margins: 16
                                spacing: 8

                                TextInput {
                                    id: passwordInput
                                    Layout.fillWidth: true
                                    Layout.fillHeight: true
                                    color: gamingTheme.textPrimary
                                    font.pixelSize: 15
                                    font.family: gamingTheme.fontMain
                                    verticalAlignment: TextInput.AlignVCenter
                                    echoMode: visibilityIcon.isVisible ? TextInput.Normal : TextInput.Password
                                    selectByMouse: true
                                    
                                    Text {
                                        text: "Platform Password"
                                        color: gamingTheme.textSecondary
                                        font.pixelSize: 15
                                        font.family: gamingTheme.fontMain
                                        visible: !passwordInput.text && !passwordInput.activeFocus
                                        anchors.verticalCenter: parent.verticalCenter
                                    }
                                }

                                Text {
                                    id: visibilityIcon
                                    property bool isVisible: false
                                    text: isVisible ? "👁️" : "👁️‍🗨️"
                                    color: gamingTheme.textSecondary
                                    font.pixelSize: 14
                                    Layout.alignment: Qt.AlignVCenter
                                    
                                    MouseArea {
                                        anchors.fill: parent
                                        anchors.margins: -10
                                        cursorShape: Qt.PointingHandCursor
                                        onClicked: visibilityIcon.isVisible = !visibilityIcon.isVisible
                                    }
                                }
                            }
                        }
                    }

                    // LOGIN BUTTON
                    Rectangle {
                        id: loginBtn
                        Layout.fillWidth: true
                        Layout.preferredHeight: 52
                        Layout.topMargin: 10
                        radius: 8
                        
                        color: {
                            if (authController.isLoggingIn) return gamingTheme.bgHover;
                            if (loginMouse.containsPress) return "#005BB5";
                            if (loginMouse.containsMouse) return "#0084F5";
                            return gamingTheme.accentPrimary;
                        }
                        
                        border.color: loginMouse.containsMouse && !authController.isLoggingIn ? gamingTheme.accentHighlight : "transparent"
                        border.width: loginMouse.containsMouse && !authController.isLoggingIn ? 1 : 0
                        
                        Behavior on color { ColorAnimation { duration: 150 } }

                        Text {
                            anchors.centerIn: parent
                            text: authController.isLoggingIn ? "CONNECTING TO NETWORK..." : "SECURE LOGIN"
                            color: gamingTheme.textPrimary
                            font.pixelSize: 15
                            font.bold: true
                            font.family: gamingTheme.fontMain
                            font.letterSpacing: 1.5
                        }

                        MouseArea {
                            id: loginMouse
                            anchors.fill: parent
                            hoverEnabled: !authController.isLoggingIn
                            cursorShape: hoverEnabled ? Qt.PointingHandCursor : Qt.ForbiddenCursor
                            onClicked: {
                                if (!authController.isLoggingIn) {
                                    authController.isLoggingIn = true;
                                    authTimer.start();
                                }
                            }
                        }
                    }

                    Item { Layout.fillHeight: true } // Pushes footer down

                    // FOOTER: SUPPORT ROUTING
                    Rectangle {
                        Layout.fillWidth: true
                        Layout.preferredHeight: 1
                        color: gamingTheme.borderSubtle
                    }

                    RowLayout {
                        Layout.fillWidth: true
                        Layout.preferredHeight: 30

                        Text {
                            text: "v5.7.1 Core Active"
                            color: gamingTheme.textMuted
                            font.pixelSize: 11
                            font.family: gamingTheme.fontMono
                        }

                        Item { Layout.fillWidth: true }

                        // Support Routing Button
                        Text {
                            text: "Mnjnef Support"
                            color: supportMouse.containsMouse ? gamingTheme.accentHighlight : gamingTheme.textSecondary
                            font.pixelSize: 13
                            font.bold: true
                            font.family: gamingTheme.fontMain
                            
                            Behavior on color { ColorAnimation { duration: 150 } }

                            MouseArea {
                                id: supportMouse
                                anchors.fill: parent
                                anchors.margins: -8
                                hoverEnabled: true
                                cursorShape: Qt.PointingHandCursor
                                onClicked: {
                                    console.log("[ROUTING] Accessing Mnjnef Support Portal");
                                    mainRouter.push("Support_1_Main.qml");
                                }
                            }
                        }
                    }
                }
            }

            // Controllers
            QtObject {
                id: authController
                property bool isLoggingIn: false
            }

            Timer {
                id: authTimer
                interval: 1500
                repeat: false
                onTriggered: {
                    authController.isLoggingIn = false;
                    console.log("[AUTH] Simulating successful login sequence.");
                }
            }
        }
    }
}
