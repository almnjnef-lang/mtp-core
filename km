# 🏗️ 10. HUGO & NGINX AUTOMATION
# ==============================================================================
class HugoDeployer:
    def __init__(self):
        os.makedirs(MnjnefConfig.POSTS_DIR, exist_ok=True)

    def write_markdown(self, record: ArticleRecord, body: str, image_url: str) -> bool:
        slug = SEOEngine.generate_slug(record.title)
        filepath = os.path.join(MnjnefConfig.POSTS_DIR, f"{slug}.md")
        
        if os.path.exists(filepath):
            filepath = os.path.join(MnjnefConfig.POSTS_DIR, f"{slug}-{int(time.time())}.md")

        hugo_date = datetime.now().astimezone().isoformat()
        safe_title = record.title.replace('"', "'").replace("\n", " ")
        clean_cat = record.category.replace('_', ' ')
        tags_list = [t.strip() for t in record.seo_tags.split(',')]
        tags_str = '", "'.join(tags_list)
        
        frontmatter = [
            "---",
            f"title: \"{safe_title}\"",
            f"date: {hugo_date}",
            "draft: false",
            f"author: \"Mnjnef Editorial\"",
            f"categories: [\"{clean_cat}\"]",
            f"tags: [\"{tags_str}\"]",
            "cover:",
            f"  image: \"{image_url}\"",
            "  alt: \"Mnjnef Featured Image\"",
            "  relative: false",
            "---",
            "",
            body
        ]
        
        try:
            with open(filepath, "w", encoding="utf-8") as f:
                f.write("\n".join(frontmatter))
            return True
        except IOError as e:
            logger.error(f"Failed to write Markdown: {e}")
            return False

    def build_and_deploy(self) -> None:
        if not MnjnefConfig.AUTO_DEPLOY: return
        try:
            cmd = (
                f"cd {MnjnefConfig.BASE_DIR} && "
                f"hugo --minify > /dev/null 2>&1 && "
                f"rm -rf {MnjnefConfig.HTML_DIR}* && "
                f"cp -r public/* {MnjnefConfig.HTML_DIR} && "
                f"chmod -R 755 {MnjnefConfig.HTML_DIR}"
            )
            os.system(cmd)
            logger.info("🚀 Mnjnef Site Deployed Successfully.")
        except Exception as e:
            logger.error(f"Deployment crash: {e}")

