# 3. تحصين عقل الروبوت وإصلاح خطأ الانهيار
bot_path = "/root/mnjnef_factory.py"
if os.path.exists(bot_path):
    with open(bot_path, "r", encoding="utf-8") as f:
        bot_code = f.read()
    
    # إصلاح خطأ التاريخ الذي تسبب في انهيار الروبوت
    if 'self.description = "AI Bypass"' in bot_code:
        bot_code = bot_code.replace('self.description = "AI Bypass"', 'self.description = "AI Bypass"\\n                        self.published = "Thu, 11 Jun 2026 00:00:00 GMT"')
    
    # إجبار التوقيت على أقصى سرعة 45 إلى 90 ثانية دائماً
    bot_code = re.sub(r'random\.randint\(\s*\d+,\s*\d+\s*\)', 'random.randint(45, 90)', bot_code)
    
    with open(bot_path, "w", encoding="utf-8") as f:
        f.write(bot_code)
    print("✅ 3. تم ترقيع خطأ الانهيار وتسريع المحرك (45-90 ثانية).")
EOF

