cat << 'EOF' > /root/strict_editor_fix.py
import os, re, glob, subprocess

print("🛡️ جاري تفعيل الفلتر الصارم وإصلاح المحرك...")

bot_path = "/root/mnjnef_factory.py"
if os.path.exists(bot_path):
    with open(bot_path, "r", encoding="utf-8") as f:
        code = f.read()

    # 1. عملية جراحية لإزالة الخطأ البرمجي (SyntaxError) من جذوره
    code = re.sub(r'^[ \t]*try:\n(?:[ \t]*.*\n)*?[ \t]*except.*:\n[ \t]*pass\n?', '', code, flags=re.MULTILINE)
    code = re.sub(r'^[ \t]*import urllib\.parse as up\n(?:[ \t]*.*\n)*?[ \t]*except.*:\n[ \t]*pass\n?', '', code, flags=re.MULTILINE)
    code = re.sub(r'^[ \t]*except.*:\n[ \t]*pass\n?', '', code, flags=re.MULTILINE)

    # زرع الكود السليم بسطر واحد مضغوط لتجنب أي أخطاء في المسافات
    safe_bypass = "    try:\n        import urllib.parse as up; ext = up.parse_qs(up.urlparse(chosen_feed).query).get('q', [''])[0].replace('+', ' ')\n        if ext and not getattr(parsed_feed, 'entries', []):\n            class D: title, link, description, published = ext, 'https://mnjnef.com', 'AI Bypass', 'Thu, 11 Jun 2026 00:00:00 GMT'\n            parsed_feed.entries = [D()]\n    except: pass"
    code = re.sub(r'^([ \t]*)parsed_feed\s*=\s*feedparser\.parse\(chosen_feed\)', r'\1parsed_feed = feedparser.parse(chosen_feed)\n' + safe_bypass, code, flags=re.MULTILINE)

    # 2. تفعيل "الفلتر الصارم" لمنع الأخبار القديمة والكاذبة
    old_inst = "Instruction: Write a highly detailed, massive, and structured encyclopedia article. Do not write a short news snippet. Use sections."
    new_inst = "Instruction: You are an elite encyclopedia editor in the year 2026. STRICT RULES: 1. ABORT AND REJECT any outdated news (like old COVID-19 pandemic stats), fake news, rumors, or expired temporal events. 2. Write ONLY highly detailed, factual, and timeless evergreen articles about the core science, history, or technology. 3. Maintain absolute professional neutrality."
    
    if old_inst in code:
        code = code.replace(old_inst, new_inst)
    else:
        code = re.sub(r'Instruction:.*?Use sections\.', new_inst, code)

    with open(bot_path, "w", encoding="utf-8") as f:
        f.write(code)
    print("✅ 1. تم إصلاح المحرك وتفعيل (العقل الصارم) ضد الأخبار القديمة والكاذبة.")

# 3. جافاسكريبت هجومي لإخفاء الأقسام العلوية في المقالات
configs = glob.glob('/root/**/config.toml', recursive=True) + glob.glob('/root/**/hugo.toml', recursive=True) + glob.glob('/var/www/**/config.toml', recursive=True) + glob.glob('/var/www/**/hugo.toml', recursive=True)
if configs:
    site_dir = os.path.dirname(configs[0])
    layouts_dir = os.path.join(site_dir, 'layouts', 'partials')
    head_file = os.path.join(layouts_dir, 'extend_head.html')
    
    kill_menu_js = """
<script>
document.addEventListener("DOMContentLoaded", function() {
    // التحقق من أننا داخل مقال
    if (window.location.pathname.length > 5 && !window.location.pathname.includes('privacy')) {
        // هجوم شامل على جميع كلاسات القوائم العلوية
        var menus = document.querySelectorAll('.menu, #menu, .nav, .navigation, header ul, .main-menu');
        menus.forEach(function(m) {
            // إخفاء أي قائمة لا تحتوي على زر سياسة الخصوصية
            if (!m.innerHTML.includes('Privacy') && !m.innerHTML.includes('privacy')) {
                m.style.display = 'none';
                m.style.visibility = 'hidden';
            } else {
                // إذا كانت تحتوي على الخصوصية، نخفي الأقسام ونترك الخصوصية
                var items = m.querySelectorAll('li, a');
                items.forEach(function(item) {
                    if (!item.innerHTML.includes('Privacy') && !item.href.includes('privacy')) {
                        item.style.display = 'none';
                    }
                });
            }
        });
    }
});
</script>
"""
    existing_head = ""
    if os.path.exists(head_file):
        with open(head_file, 'r', encoding='utf-8') as f:
            existing_head = f.read()
            # منع التكرار
            existing_head = re.sub(r'<script>.*?هجوم شامل.*?</script>', '', existing_head, flags=re.DOTALL)
            
    with open(head_file, 'w', encoding='utf-8') as f:
        f.write(existing_head.strip() + "\n" + kill_menu_js)

    subprocess.run(["hugo", "--gc", "--minify"], cwd=site_dir, capture_output=True)
    for dest in ['/var/www/html', '/var/www/mnjnef', '/var/www/mnjnef.com']:
        if os.path.exists(dest):
            subprocess.run(f"cp -r {os.path.join(site_dir, 'public')}/* {dest}/ 2>/dev/null", shell=True)
    print("✅ 2. تم زرع الكود الهجومي لقص الأقسام العلوية من المقالات.")

print("🎉 اكتملت المهمة! جاري إطلاق المحرك...")
EOF

python3 /root/strict_editor_fix.py

