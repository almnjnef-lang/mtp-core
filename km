class FreeImageBank:
    """Multi-layered engine for fetching 100% copyright-free images."""
    
    @staticmethod
    def fetch_image(category: str, title: str) -> Tuple[str, str]:
        """Returns (image_url, source_name)."""
        query = category.replace("_", " ")
        
        # Layer 1: Pexels API (Ultra Premium) if key is provided
        if MnjnefConfig.PEXELS_API_KEY and MnjnefConfig.PEXELS_API_KEY != "ضع_مفتاحك_السري_هنا":
            try:
                url = f"https://api.pexels.com/v1/search?query={query}&per_page=15"
                headers = {"Authorization": MnjnefConfig.PEXELS_API_KEY}
                resp = requests.get(url, headers=headers, timeout=10)
                if resp.status_code == 200:
                    data = resp.json()
                    if data.get('photos'):
                        photo = random.choice(data['photos'])
                        logger.info("Premium image secured via Pexels.")
                        return photo['src']['large'], "Pexels"
            except Exception as e:
                logger.warning(f"Pexels failed, cascading to fallback: {e}")
                
        # Layer 2: Unsplash Source API (High Quality Auto-Routing)
        try:
            unsplash_url = f"https://source.unsplash.com/1200x800/?{query.replace(' ', ',')}"
            resp = requests.head(unsplash_url, allow_redirects=True, timeout=5)
            if resp.status_code == 200:
                logger.info("Image secured via Unsplash Source.")
                return resp.url, "Unsplash"
        except Exception:
            pass

        # Layer 3: LoremFlickr (Reliable Fallback)
        safe_query = category.replace("_", "")
        logger.info("Image secured via LoremFlickr Fallback.")
        return f"https://loremflickr.com/1200/800/{safe_query},news/all", "LoremFlickr"

