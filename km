# 1. حذف جميع ملفات المقالات القديمة والمشوهة
rm -rf /root/mnjnef_site/content/posts/*

# 2. حذف أي صور قديمة عشوائية أو مكسورة
rm -rf /root/mnjnef_site/static/images/*

# 3. إعادة بناء الموقع فوراً وتحديث المجلد الرئيسي لكي تختفي من المتصفح
cd /root/mnjnef_site
hugo --minify
rm -rf /var/www/html/*
cp -r public/* /var/www/html/
chmod -R 755 /var/www/html/
