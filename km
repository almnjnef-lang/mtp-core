name: Auto News Bot
on:
  schedule:
    - cron: '*/5 * * * *' # Auto-run exactly every 5 minutes
  workflow_dispatch:

permissions:
  contents: write

jobs:
  update_news:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      
      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'
          
      - name: Run News Scraper
        run: python auto_news.py
        
      - name: Commit and Push
        run: |
          git config --global user.name "Mnjnef Bot"
          git config --global user.email "bot@mnjnef.com"
          git add content/posts/
          git commit -m "Auto-published new global articles" || echo "No new articles"
          git push
