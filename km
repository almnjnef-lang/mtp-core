import os, glob, subprocess

print("🚀 جاري تطبيق الإصلاحات الذهبية للموسوعة والقبول في AdSense...")

# البحث عن مجلد الموقع
configs = glob.glob('/root/**/config.toml', recursive=True) + glob.glob('/root/**/hugo.toml', recursive=True) + glob.glob('/var/www/**/config.toml', recursive=True) + glob.glob('/var/www/**/hugo.toml', recursive=True)
if not configs:
    print("❌ لم يتم العثور على الموقع")
    exit()
conf = configs[0]
site_dir = os.path.dirname(conf)

# 1. حل خطأ 404 بإنشاء "مقالات تأسيسية" لتفعيل الروابط
posts_dir = os.path.join(site_dir, 'content', 'posts')
os.makedirs(posts_dir, exist_ok=True)
cats = ['Technology', 'Science_and_Health', 'Global_Education', 'World_History', 'Business_and_Economy', 'Arts_and_Culture', 'Space_Exploration', 'Environment', 'Daily_Solutions', 'Global_Discoveries']
for c in cats:
    dummy_file = os.path.join(posts_dir, f'seed_{c.lower()}.md')
    if not os.path.exists(dummy_file):
        with open(dummy_file, 'w', encoding='utf-8') as f:
            name = c.replace("_", " ")
            f.write(f"---\ntitle: 'Explore {name}'\ndate: 2024-01-01\ncategories: ['{c}']\ndraft: false\n---\nWelcome to the {name} category. The Mnjnef Artificial Intelligence Engine is currently gathering and writing massive encyclopedia articles for this section. Please check back soon!\n")
print("✅ 1. تم حل مشكلة (404) نهائياً بتفعيل جميع الأقسام الـ 10.")

# 2. إنشاء صفحة سياسة الخصوصية (Privacy Policy)
content_dir = os.path.join(site_dir, 'content')
pp_file = os.path.join(content_dir, 'privacy-policy.md')
with open(pp_file, 'w', encoding='utf-8') as f:
    f.write("---\ntitle: 'Privacy Policy'\ndate: 2024-01-01\nlayout: 'single'\n---\n## Privacy Policy for Mnjnef\n\nAt Mnjnef, accessible from mnjnef.com, one of our main priorities is the privacy of our visitors. This Privacy Policy document contains types of information that is collected and recorded by Mnjnef and how we use it.\n\n### Google DoubleClick DART Cookie\nGoogle is one of a third-party vendor on our site. It also uses cookies, known as DART cookies, to serve ads to our site visitors based upon their visit to our site and other sites on the internet. However, visitors may choose to decline the use of DART cookies by visiting the Google ad and content network Privacy Policy.\n\n### AdSense Policy\nWe partner with Google AdSense to deliver high-quality content. We comply with all Google policies regarding user data and advertising.\n")
print("✅ 2. تم إنشاء صفحة سياسة الخصوصية الرسمية المتوافقة مع أدسنس.")

# 3. وضع سياسة الخصوصية في القائمة العلوية
with open(conf, 'r', encoding='utf-8') as f:
    config_data = f.read()
if 'url = "/privacy-policy/"' not in config_data:
    pp_menu = '\n  [[menu.main]]\n    identifier = "privacy"\n    name = "Privacy Policy"\n    url = "/privacy-policy/"\n    weight = 1\n'
    config_data = config_data.replace('[menu]', '[menu]' + pp_menu)
    with open(conf, 'w', encoding='utf-8') as f:
        f.write(config_data)

# 4. تفعيل الواجهة الذكية (الأقسام تنزل للأسفل داخل المقالات + تمييز زر الخصوصية)
layouts_dir = os.path.join(site_dir, 'layouts', 'partials')
os.makedirs(layouts_dir, exist_ok=True)
footer_file = os.path.join(layouts_dir, 'extend_footer.html')
smart_ui = '''
<script>
document.addEventListener("DOMContentLoaded", function() {
    var isHome = (window.location.pathname === '/' || window.location.pathname === '/index.html');
    if (!isHome) {
        var menu = document.querySelector('#menu');
        var main = document.querySelector('main');
        if (menu && main) {
            var wrapper = document.createElement('div');
            wrapper.innerHTML = '<h3 style="text-align:center; margin-top:50px; margin-bottom:20px; font-family:sans-serif; font-size: 1.5em; color: #111;">Explore Mnjnef Encyclopedia</h3>';
            wrapper.style.marginTop = '40px';
            wrapper.style.paddingTop = '30px';
            wrapper.style.borderTop = '2px solid #eaeaea';
            wrapper.appendChild(menu);
            main.appendChild(wrapper);
        }
    }
});
</script>
<style>
/* تمييز مربع سياسة الخصوصية باللون الأسود الفخم */
#menu a[href*="privacy"] {
    background-color: #111111 !important;
    color: #ffffff !important;
    border: 1px solid #111111 !important;
}
#menu a[href*="privacy"]:hover {
    background-color: #333333 !important;
}
</style>
'''
with open(footer_file, 'a', encoding='utf-8') as f:
    if 'Explore Mnjnef Encyclopedia' not in open(footer_file).read() if os.path.exists(footer_file) else True:
        f.write(smart_ui)
print("✅ 3. تم تفعيل نظام الواجهة الذكي (الأقسام في الأعلى بالرئيسية، وفي الأسفل داخل المقال).")

# 5. بناء الموقع وإجبار السيرفر على التحديث
subprocess.run(["hugo", "--gc", "--minify"], cwd=site_dir, capture_output=True)
for dest in ['/var/www/html', '/var/www/mnjnef', '/var/www/mnjnef.com']:
    if os.path.exists(dest):
        subprocess.run(f"cp -r {os.path.join(site_dir, 'public')}/* {dest}/ 2>/dev/null", shell=True)
print("⚙️ 4. تم إجبار السيرفر على تحديث الواجهة للمستخدمين!")

print("🎉 اكتملت المهمة! انطلاق الوحش الآن...")
EOF

