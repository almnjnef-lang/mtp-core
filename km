import os, glob, re, subprocess

print("🚀 جاري المسح الجذري للواجهة وفرض التحديث بالقوة...")

# 1. مسح القائمة العربية من الجذور وزرع الإنجليزية
configs = glob.glob('/root/**/config.toml', recursive=True) + glob.glob('/root/**/hugo.toml', recursive=True) + glob.glob('/var/www/**/config.toml', recursive=True) + glob.glob('/var/www/**/hugo.toml', recursive=True)
if configs:
    conf = configs[0]
    site_dir = os.path.dirname(conf)
    
    with open(conf, 'r', encoding='utf-8') as f:
        content = f.read()
    
    # بتر القائمة القديمة من جذورها بشكل آمن تماماً
    lines = content.split('\n')
    new_lines = []
    for line in lines:
        if line.strip() == '[menu]' or line.strip().startswith('[[menu'):
            break # يتوقف هنا ويمسح كل ما تحته
        new_lines.append(line)
        
    english_menus = """
[menu]
  [[menu.main]]
    identifier = "tech"
    name = "Technology"
    url = "/categories/technology/"
    weight = 10
  [[menu.main]]
    identifier = "science"
    name = "Science & Health"
    url = "/categories/science_and_health/"
    weight = 20
  [[menu.main]]
    identifier = "education"
    name = "Global Education"
    url = "/categories/global_education/"
    weight = 30
  [[menu.main]]
    identifier = "history"
    name = "World History"
    url = "/categories/world_history/"
    weight = 40
  [[menu.main]]
    identifier = "business"
    name = "Business & Economy"
    url = "/categories/business_and_economy/"
    weight = 50
  [[menu.main]]
    identifier = "arts"
    name = "Arts & Culture"
    url = "/categories/arts_and_culture/"
    weight = 60
  [[menu.main]]
    identifier = "space"
    name = "Space Exploration"
    url = "/categories/space_exploration/"
    weight = 70
  [[menu.main]]
    identifier = "environment"
    name = "Environment"
    url = "/categories/environment/"
    weight = 80
  [[menu.main]]
    identifier = "daily"
    name = "Daily Solutions"
    url = "/categories/daily_solutions/"
    weight = 90
  [[menu.main]]
    identifier = "discoveries"
    name = "Global Discoveries"
    url = "/categories/global_discoveries/"
    weight = 100
"""
    with open(conf, 'w', encoding='utf-8') as f:
        f.write('\n'.join(new_lines) + "\n\n" + english_menus)
    print("✅ تم تدمير القائمة العربية بالكامل وزرع 10 أقسام إنجليزية.")

    # فرض البناء ونقل الملفات للمتصفح
    subprocess.run(["hugo", "--gc", "--minify"], cwd=site_dir, capture_output=True)
    public_dir = os.path.join(site_dir, "public")
    for dest in ['/var/www/html', '/var/www/mnjnef', '/var/www/mnjnef.com']:
        if os.path.exists(dest) and dest != public_dir:
            subprocess.run(f"cp -r {public_dir}/* {dest}/ 2>/dev/null", shell=True)
    print("⚙️ تم إجبار السيرفر على تحديث الواجهة للمستخدمين!")

# 2. ترقية عقل الروبوت (تخطي حظر جوجل والتأليف المباشر)
bot_path = "/root/mnjnef_factory.py"
try:
    with open(bot_path, "r", encoding="utf-8") as f:
        bot_code = f.read()
    
    mock_logic = """
        import urllib.parse as up
        try:
            qs = up.parse_qs(up.urlparse(chosen_feed).query)
            extracted_topic = qs.get('q', [''])[0].replace('+', ' ')
            if extracted_topic and not parsed_feed.entries:
                class DummyEntry:
                    def __init__(self, t):
                        self.title = t
                        self.link = "https://mnjnef.com/dummy"
                        self.description = "AI Bypass"
                parsed_feed.entries = [DummyEntry(extracted_topic)]
                logger.info(f"💡 تم تجاوز حظر جوجل (Source Empty)! سيتم تأليف مقال موسوعي عن: {extracted_topic}")
        except:
            pass
"""
    if "DummyEntry" not in bot_code:
        bot_code = re.sub(
            r'(parsed_feed\s*=\s*feedparser\.parse\(chosen_feed\))',
            r'\1' + mock_logic,
            bot_code,
            count=1
        )
        with open(bot_path, "w", encoding="utf-8") as f:
            f.write(bot_code)
        print("✅ تم ترقية الروبوت! لن يعيقه شيء وسيكتب مقالات من العناوين مباشرة.")
except Exception as e:
    pass

print("🎉 اكتملت المهمة! انطلاق الوحش الآن...")
EOF

