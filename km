        ListElement { alertTime: "08:15 AM"; alertLevel: "WARN"; alertText: "Elevated latency detected in SEA routing nodes." }
        ListElement { alertTime: "01:00 AM"; alertLevel: "SUCCESS"; alertText: "Patch v5.7.1 deployed successfully globally." }
    }

    // ==========================================
    // AMBIENT BACKGROUND SYSTEM
    // ==========================================
    Rectangle {
        anchors.fill: parent
        color: contactTheme.bgPrimary

        // Starfield / Data Dust
        Canvas {
            id: starfieldCanvas
            anchors.fill: parent
            opacity: 0.4
            
            property var stars: []
            
            onPaint: {
                var ctx = getContext("2d");
                ctx.clearRect(0, 0, width, height);
                ctx.fillStyle = contactTheme.textMuted;
                
                for(var i=0; i<stars.length; i++) {
                    var s = stars[i];
                    ctx.globalAlpha = s.alpha;
                    ctx.beginPath();
                    ctx.arc(s.x, s.y, s.size, 0, 2*Math.PI);
                    ctx.fill();
                }
            }
            
            Component.onCompleted: {
                for(var i=0; i<150; i++) {
                    stars.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        size: Math.random() * 1.5,
                        alpha: Math.random(),
                        speed: Math.random() * 0.05 + 0.01
                    });
                }
            }
            
            Timer {
                interval: 50; running: true; repeat: true
                onTriggered: {
                    for(var i=0; i<starfieldCanvas.stars.length; i++) {
                        var s = starfieldCanvas.stars[i];
                        s.alpha += s.speed;
                        if(s.alpha > 1.0 || s.alpha < 0.1) s.speed = -s.speed;
                    }
                    starfieldCanvas.requestPaint();
                }
            }
        }

        // Global Grid Overlay
        Canvas {
            anchors.fill: parent
            opacity: 0.05
            onPaint: {
                var ctx = getContext("2d");
                ctx.strokeStyle = contactTheme.accentPrimary;
                ctx.lineWidth = 1;
                var step = 50;
                ctx.beginPath();
                for(var x=0; x<width; x+=step) { ctx.moveTo(x, 0); ctx.lineTo(x, height); }
                for(var y=0; y<height; y+=step) { ctx.moveTo(0, y); ctx.lineTo(width, y); }
                ctx.stroke();
            }
        }
    }

    // ==========================================
    // MAIN LAYOUT
    // ==========================================
    ColumnLayout {
