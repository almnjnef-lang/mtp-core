                }
            }
        }
    }

    // ==========================================
    // LOGIC & TIMERS
    // ==========================================
    Timer {
        id: telemetryUpdateTimer
        interval: 2500
        repeat: true
        running: true
        onRunningChanged: { if(running){} }
        onTriggered: {
            // Simulate live network load
            var variation = (Math.random() * 4) - 2;
            var newLoad = mnjnefContactUsRoot.globalNetworkLoad + variation;
            if(newLoad > 95) newLoad = 95;
            if(newLoad < 20) newLoad = 20;
            mnjnefContactUsRoot.globalNetworkLoad = newLoad;
            
            // Randomly update agents online
            if(Math.random() > 0.7) {
                mnjnefContactUsRoot.activeAgents += (Math.random() > 0.5 ? 1 : -1);
                if(mnjnefContactUsRoot.activeAgents < 5) mnjnefContactUsRoot.activeAgents = 5;
            }
        }
    }

    Timer {
        id: connectionSimulationTimer
        interval: 1500
        repeat: false
        onRunningChanged: { if(running){} }
        onTriggered: {
            mnjnefContactUsRoot.isConnecting = false;
            // Emit signal to parent/MasterEngine to transition to Support_1_Main or OTPAuth
            mnjnefContactUsRoot.initiateSupportSequence();
        }
    }
}
