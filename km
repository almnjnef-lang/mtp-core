pkill -f run_bot.sh
pkill -f mnjnef_factory.py

cat << 'EOF' > /root/clean_ui_and_bot.py
import os, glob, subprocess

print("🧹 جاري إزالة حرف M المزعج وإصلاح عطل الروبوت...")

# 1. إزالة حرف M من خلفية الموقع بالقوة
configs = glob.glob('/root/**/config.toml', recursive=True) + glob.glob('/root/**/hugo.toml', recursive=True) + glob.glob('/var/www/**/config.toml', recursive=True) + glob.glob('/var/www/**/hugo.toml', recursive=True)
if configs:
    site_dir = os.path.dirname(configs[0])
    head_file = os.path.join(site_dir, 'layouts', 'partials', 'extend_head.html')
    os.makedirs(os.path.dirname(head_file), exist_ok=True)
    
    existing_head = ""
    if os.path.exists(head_file):
        with open(head_file, 'r', encoding='utf-8') as f:
            existing_head = f.read()
    
    # كود CSS قاطع لإخفاء أي علامة مائية في الخلفية
    kill_m_css = "\n<style>body::before { display: none !important; content: none !important; background: none !important; }</style>\n"
    
    if "body::before { display: none" not in existing_head:
        with open(head_file, 'w', encoding='utf-8') as f:
            f.write(existing_head + kill_m_css)
    
    # إعادة بناء الموقع ليعكس النقاء الجديد
    subprocess.run(["hugo", "--gc", "--minify"], cwd=site_dir, capture_output=True)
    for dest in ['/var/www/html', '/var/www/mnjnef', '/var/www/mnjnef.com']:
        if os.path.exists(dest):
            subprocess.run(f"cp -r {os.path.join(site_dir, 'public')}/* {dest}/ 2>/dev/null", shell=True)
    print("✅ تم تدمير حرف M نهائياً.. واجهة الموقع الآن بيضاء ونقية 100%.")

# 2. إصلاح خطأ SyntaxError في الروبوت الذي ظهر في شاشتك
bot_path = "/root/mnjnef_factory.py"
if os.path.exists(bot_path):
    with open(bot_path, "r", encoding="utf-8") as f:
        lines = f.readlines()
    
    new_lines = []
    in_broken_try = False
    for line in lines:
        if 'import urllib.parse as up' in line:
            # مسح سطر try اليتيم الذي يسبق الخطأ
            if new_lines and new_lines[-1].strip() == 'try:':
                new_lines.pop()
            in_broken_try = True
            continue
        
        if in_broken_try:
            # تخطي جميع الأسطر المكسورة حتى نخرج من المنطقة المعطوبة
            if any(x in line for x in ['class D:', 'parsed_feed.entries', 'except:', 'ext =', 'if ext']):
                continue
            else:
                in_broken_try = False
        
        if not in_broken_try:
            new_lines.append(line)
            
    with open(bot_path, "w", encoding="utf-8") as f:
        f.writelines(new_lines)
    print("✅ تم إجراء عملية جراحية للروبوت وإصلاح خطأ (SyntaxError) نهائياً.")

EOF

python3 /root/clean_ui_and_bot.py

nohup /root/run_bot.sh > /dev/null 2>&1 &
tail -f /root/mnjnef_factory.log
