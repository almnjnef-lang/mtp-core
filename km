            icon: "📡"
            desc: "Monitor ongoing resolutions and communicate with assigned support agents."
            targetFile: "Support_9_TicketTracker.qml"
            isPrimary: false
        }
        ListElement { 
            actionId: "LIVE_CHAT"
            title: "Live Operative Chat"
            icon: "💬"
            desc: "Connect directly with Tier 2 technical architects for real-time assistance."
            targetFile: "Support_9_TicketTracker.qml"
