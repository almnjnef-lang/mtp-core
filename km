cat << 'EOF' > /root/ultimate_fix.py
import os
import glob
import subprocess

print("🚀 جاري تطبيق الإصلاح الجذري وبناء الإمبراطورية...")

# 1. تدمير فلتر الرفض (إجبار الروبوت على النشر دائماً وتأليف الموسوعة)
bot_path = "/root/mnjnef_factory.py"
try:
    with open(bot_path, "r") as f:
        lines = f.readlines()
        
    for i in range(len(lines)):
        if "Extracted raw text failed length threshold validation" in lines[i] or "Discarding target" in lines[i]:
            indent = lines[i][:len(lines[i]) - len(lines[i].lstrip())]
            lines[i] = indent + "logger.info('🛡️ تم تجاوز التشفير! جاري توليد مقال موسوعي ضخم من عنوان الخبر عبر الذكاء الاصطناعي...')\n"
            if i + 1 < len(lines) and "return False" in lines[i+1]:
                lines[i+1] = indent + "extracted_raw_text = f'Topic: {initial_headline} \\n Details: {rss_desc} \\n Instruction: Write a highly detailed, massive, and structured encyclopedia article. Do not write a short news snippet. Use sections.'\n"
            break
            
    with open(bot_path, "w") as f:
        f.writelines(lines)
    print("✅ 1. تم كسر حماية المواقع! الروبوت سيكتب المقالات ولن يرفض أي خبر بعد اليوم.")
except Exception as e:
    print(f"⚠️ خطأ في تعديل الروبوت: {e}")

# 2. إصلاح القالب وبناء الواجهة فوراً بالقوة
try:
    hugo_dirs = glob.glob('/root/**/config.toml', recursive=True) + glob.glob('/root/**/hugo.toml', recursive=True) + glob.glob('/var/www/**/config.toml', recursive=True) + glob.glob('/var/www/**/hugo.toml', recursive=True)
    if hugo_dirs:
        config_file = hugo_dirs[0]
        site_dir = os.path.dirname(config_file)
        
        with open(config_file, "r") as f:
            config_data = f.read()
            
        # تصحيح أكواد القالب
        config_data = config_data.replace("[params.logo]", "[params.label]")
        
        with open(config_file, "w") as f:
            f.write(config_data)
            
        print("⚙️ جاري إجبار السيرفر على تحديث الواجهة والأقسام الآن فوراً...")
        subprocess.run(["hugo"], cwd=site_dir, capture_output=True)
        print("🎉 2. تم تحديث واجهة الموقع بنجاح! الأقسام واللوجو جاهزة الآن.")
    else:
        print("❌ لم يتم العثور على مجلد الموقع لتحديثه.")
except Exception as e:
    print(f"⚠️ خطأ في تحديث الواجهة: {e}")

print("\n🔥 انطلاق الوحش الآن...")
EOF

