# 4. بناء المحرك المباشر (Direct HTML Generator)
cat << 'EOF' > /root/direct_mistral_engine.py
import os, time, random, json, re, sys
import urllib.request
import urllib.error
from urllib.parse import quote
from datetime import datetime

API_KEY = "HKxK4S2UrTBt8ja93wkndgltN1W3UaHD"

CATS = {
    "Education_and_Academia": ["Modern Pedagogy", "Distance Learning", "Neuroplasticity", "Special Education", "Educational Technology"],
    "Psychology_and_Solutions": ["Behavioral Economics", "Emotional Intelligence", "Stress Management", "Cognitive Behavioral Therapy"],
    "Problem_Solving": ["Time Management Hacks", "Effective Communication", "Critical Thinking Skills", "Financial Literacy"],
    "Technology_and_Science": ["Quantum Computing", "AI Ethics", "Cybersecurity", "Astrophysics"],
    "Culture_and_Arts": ["Renaissance Art", "Cultural Anthropology", "Classical Architecture"],
    "Tourism_and_Travel": ["Sustainable Ecotourism", "Cultural Heritage Sites", "Luxury Travel Trends"],
    "Culinary_Arts": ["Molecular Gastronomy", "Traditional Fermentation", "Plant-Based Cuisine"],
    "Nature_Environment": ["Forest Conservation", "Climate Change Solutions", "Oceanography"],
    "Sports_Science": ["Biomechanics in Sports", "Sports Nutrition", "Endurance Training"],
    "Business_Finance": ["Macroeconomics", "Supply Chain Management", "Investment Strategies"]
}

def generate_article():
    print("\n" + "="*50, flush=True)
    weighted_cats = ["Education_and_Academia"] * 5 + ["Problem_Solving"] * 3 + list(CATS.keys())
    cat = random.choice(weighted_cats)
    topic = random.choice(CATS[cat])

    try:
        print(f"🌍 1. Fetching topic: '{topic}'...", flush=True)
        search_url = f"https://en.wikipedia.org/w/api.php?action=query&list=search&srsearch={quote(topic)}&utf8=&format=json"
        req = urllib.request.Request(search_url, headers={'User-Agent': 'Mozilla/5.0'})
        res = json.loads(urllib.request.urlopen(req).read().decode())
        
        if not res.get('query', {}).get('search'): return
        actual_title = res['query']['search'][0]['title']

        ext_url = f"https://en.wikipedia.org/w/api.php?action=query&prop=extracts&exlimit=1&titles={quote(actual_title)}&explaintext=1&format=json"
        req2 = urllib.request.Request(ext_url, headers={'User-Agent': 'Mozilla/5.0'})
        context = list(json.loads(urllib.request.urlopen(req2).read().decode())['query']['pages'].values())[0].get('extract', '')[:1500]

        prompt = f"ACT AS: Chief Editor of Mnjnef Encyclopedia. Write a MASSIVE, deep educational article about '{actual_title}'. RULES: No politics. English only. Format with HTML tags (<h2>, <p>, <ul>). STRICTLY NO '#' SYMBOLS. End with '<h2>📚 Related Topics</h2>' and 3 related concepts in a list. Context: {context}"

        print("🧠 2. Sending prompt to Mistral AI...", flush=True)
        url = "https://api.mistral.ai/v1/chat/completions"
        headers = {"Content-Type": "application/json", "Authorization": f"Bearer {API_KEY}"}
        data = json.dumps({"model": "mistral-large-latest", "messages": [{"role": "user", "content": prompt}], "temperature": 0.25}).encode('utf-8')

        req_ai = urllib.request.Request(url, data=data, headers=headers)
        response = urllib.request.urlopen(req_ai)
        text = json.loads(response.read().decode())['choices'][0]['message']['content']
        
        print("✅ 3. Content Generated!", flush=True)

        text = re.sub(r'#+\s*|```html|```', '', text)
        clean_title = re.sub(r'[#*@]', '', actual_title).strip()
        date_str = datetime.now().strftime('%Y-%m-%d %H:%M')

        # التصميم الفخم للمقال بلغة HTML مباشرة
        html_content = f"""
        <!DOCTYPE html>
        <html lang="en">
        <head>
            <meta charset="UTF-8">
            <meta name="viewport" content="width=device-width, initial-scale=1.0">
            <title>{clean_title} - Mnjnef Encyclopedia</title>
            <style>
                body {{ font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; line-height: 1.8; color: #333; background-color: #f8f9fa; margin: 0; padding: 0; }}
                header {{ background-color: #1a365d; color: white; padding: 20px; text-align: center; border-bottom: 5px solid #e2e8f0; }}
                .container {{ max-width: 900px; margin: 40px auto; background: white; padding: 40px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }}
                h1 {{ color: #2d3748; font-size: 2.5em; margin-bottom: 10px; border-bottom: 2px solid #edf2f7; padding-bottom: 10px; }}
                h2 {{ color: #2b6cb0; margin-top: 30px; }}
                p {{ font-size: 1.1em; margin-bottom: 20px; }}
                ul {{ margin-bottom: 20px; font-size: 1.1em; }}
                li {{ margin-bottom: 10px; }}
                .meta-info {{ color: #718096; font-size: 0.9em; margin-bottom: 30px; }}
                .translator {{ background: #ebf8ff; padding: 15px; border-left: 5px solid #3182ce; border-radius: 4px; margin-bottom: 30px; }}
                footer {{ text-align: center; margin-top: 50px; padding: 20px; color: #a0aec0; border-top: 1px solid #edf2f7; }}
            </style>
        </head>
        <body>
            <header>
                <h2>Mnjnef Global Educational Encyclopedia</h2>
            </header>
            <div class="container">
                <h1>{clean_title}</h1>
                <div class="meta-info">Published on: {date_str} | Category: {cat.replace('_', ' ')}</div>
                
                <div class="translator">
                    <strong>🌐 Translate this Encyclopedia Article:</strong>
                    <div id="google_translate_element"></div>
                </div>
                
                <div class="article-body">
                    {text}
                </div>
                
                <footer>
                    <p>&copy; {datetime.now().year} Mnjnef Global Enterprise. Empowering global education.</p>
                </footer>
            </div>
            
            <script type="text/javascript">
                function googleTranslateElementInit() {{
                    new google.translate.TranslateElement({{pageLanguage: 'en', layout: google.translate.TranslateElement.InlineLayout.SIMPLE}}, 'google_translate_element');
                }}
            </script>
            <script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
        </body>
        </html>
        """

        # زرع المقال مباشرة في السيرفر ليعمل كصفحة رئيسية
        with open("/var/www/html/index.html", "w", encoding="utf-8") as f: f.write(html_content)
        with open("/var/www/mnjnef.com/index.html", "w", encoding="utf-8") as f: f.write(html_content)
        
        # أرشفة المقال
        file_name = clean_title.replace(" ", "_").lower() + f"_{int(time.time())}.html"
        with open(f"/var/www/html/articles/{file_name}", "w", encoding="utf-8") as f: f.write(html_content)
        
        # تصحيح الصلاحيات نهائياً
        os.system("chown -R www-data:www-data /var/www/html /var/www/mnjnef.com")
        
        print(f"✅ [PUBLISHED DIRECTLY] '{clean_title}' is LIVE on your homepage!", flush=True)

    except Exception as e:
        print(f"❌ ERROR: {e}", flush=True)

generate_article()

while True:
    delay = random.uniform(22.0, 30.0)
    print(f"⏳ Waiting {delay:.1f} seconds for the next massive article...", flush=True)
    time.sleep(delay)
    generate_article()
EOF

# 5. تشغيل المحرك المباشر
cat << 'SRV' > /etc/systemd/system/mnjnef_direct.service
