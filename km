import os, time, random, json, re, sys
import urllib.request
from urllib.parse import quote
from datetime import datetime, timedelta

API_KEY = "HKxK4S2UrTBt8ja93wkndgltN1W3UaHD"
DB_PATH = "/var/www/html/database.json"

CATS = {
    "Education_and_Academia": ["Modern Pedagogy", "Distance Learning", "Neuroplasticity", "Special Education", "Educational Technology"],
    "Psychology_and_Solutions": ["Behavioral Economics", "Emotional Intelligence", "Stress Management", "Cognitive Behavioral Therapy"],
    "Problem_Solving": ["Time Management Hacks", "Effective Communication", "Critical Thinking Skills", "Financial Literacy"],
    "Technology_and_Science": ["Quantum Computing", "Cybersecurity", "Astrophysics"],
    "Business_Finance": ["Macroeconomics", "Supply Chain Management", "Investment Strategies"]
}

def get_fake_date():
    start = datetime(2018, 1, 1)
    end = datetime.now()
    return (start + timedelta(days=random.randrange((end - start).days))).strftime('%B %d, %Y')

def load_db():
    if os.path.exists(DB_PATH):
        try:
            with open(DB_PATH, "r") as f: return json.load(f)
        except: return []
    return []

def save_db(data):
    with open(DB_PATH, "w") as f: json.dump(data[:150], f)
    os.system("cp /var/www/html/database.json /var/www/mnjnef.com/database.json 2>/dev/null")

def build_homepage():
    db = load_db()
    articles_html = ""
    
    # تصميم المستطيلات الاحترافية للصفحة الرئيسية
    for art in db:
        articles_html += f"""
        <a href="{art['url']}" class="article-box">
            <div class="box-content">
                <span class="category-tag">{art['category']}</span>
                <h2>{art['title']}</h2>
                <div class="meta">Published: {art['date']} | Independent Research</div>
            </div>
            <div class="read-arrow">➔</div>
        </a>
        """
        
    html = f"""<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mnjnef Open Library - Global Knowledge</title>
    <style>
        body {{ font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f0f4f8; margin: 0; color: #2d3748; }}
        header {{ background: #1a365d; color: white; padding: 40px 20px; text-align: center; border-bottom: 4px solid #3182ce; }}
        header h1 {{ margin: 0; font-size: 2.5em; letter-spacing: 1px; }}
        .container {{ max-width: 900px; margin: 40px auto; padding: 0 20px; }}
        
        /* تصميم المستطيلات (List Layout) */
        .article-box {{ display: flex; align-items: center; justify-content: space-between; background: white; margin-bottom: 20px; padding: 25px; border-radius: 10px; text-decoration: none; color: inherit; border-left: 5px solid #3182ce; box-shadow: 0 4px 6px rgba(0,0,0,0.05); transition: all 0.2s ease; }}
        .article-box:hover {{ transform: translateX(10px); box-shadow: 0 8px 15px rgba(0,0,0,0.1); border-left-color: #2b6cb0; background: #fcfcfc; }}
        .category-tag {{ display: inline-block; background: #ebf8ff; color: #2b6cb0; padding: 4px 12px; border-radius: 20px; font-size: 0.85em; font-weight: bold; margin-bottom: 10px; }}
        .article-box h2 {{ margin: 0 0 10px 0; font-size: 1.5em; color: #1a202c; }}
        .meta {{ font-size: 0.9em; color: #718096; }}
        .read-arrow {{ font-size: 1.5em; color: #cbd5e0; font-weight: bold; transition: 0.2s; }}
        .article-box:hover .read-arrow {{ color: #3182ce; }}
        
        footer {{ text-align: center; padding: 30px; margin-top: 50px; color: #a0aec0; }}
        @media(max-width: 600px) {{ .article-box {{ flex-direction: column; align-items: flex-start; }} .read-arrow {{ display: none; }} }}
    </style>
</head>
<body>
    <header><h1>Mnjnef Open Library</h1><p>Verified Academic & Educational Archives</p></header>
    <div class="container">{articles_html if articles_html else '<p style="text-align:center;">Synchronizing database... please refresh in 30 seconds.</p>'}</div>
    <footer>&copy; Mnjnef Open Knowledge Platform.</footer>
</body></html>"""

    with open("/var/www/html/index.html", "w") as f: f.write(html)
    os.system("cp /var/www/html/index.html /var/www/mnjnef.com/index.html 2>/dev/null")

def generate_article():
    cat = random.choice(list(CATS.keys()))
    topic = random.choice(CATS[cat])

    try:
        req = urllib.request.Request(f"https://en.wikipedia.org/w/api.php?action=query&list=search&srsearch={quote(topic)}&utf8=&format=json", headers={'User-Agent': 'Mozilla/5.0'})
        res = json.loads(urllib.request.urlopen(req).read().decode())
        if not res.get('query', {}).get('search'): return
        actual_title = res['query']['search'][0]['title']

        req2 = urllib.request.Request(f"https://en.wikipedia.org/w/api.php?action=query&prop=extracts&exlimit=1&titles={quote(actual_title)}&explaintext=1&format=json", headers={'User-Agent': 'Mozilla/5.0'})
        context = list(json.loads(urllib.request.urlopen(req2).read().decode())['query']['pages'].values())[0].get('extract', '')[:1200]

        # أمر صارم جداً للذكاء الاصطناعي بمنع الترجمة ومنع مواضيع ذات صلة الوهمية
        prompt = f"ACT AS: Senior Educational Board. Write a MASSIVE, deep academic article about '{actual_title}'. RULES: English only. Format with HTML tags (<h2>, <p>). STRICTLY NO '#' SYMBOLS. DO NOT add 'Related Topics' or 'Conclusion' sections at the end. Context: {context}"

        req_ai = urllib.request.Request("https://api.mistral.ai/v1/chat/completions", data=json.dumps({"model": "mistral-large-latest", "messages": [{"role": "user", "content": prompt}], "temperature": 0.2}).encode('utf-8'), headers={"Content-Type": "application/json", "Authorization": f"Bearer {API_KEY}"})
        text = json.loads(urllib.request.urlopen(req_ai).read().decode())['choices'][0]['message']['content']
        text = re.sub(r'#+\s*|```html|```', '', text)
        clean_title = re.sub(r'[#*@]', '', actual_title).strip()
        seo_date = get_fake_date()
        
        file_name = re.sub(r'[^a-z0-9_]', '', clean_title.replace(" ", "_").lower()) + f"_{int(time.time())}.html"
        article_url = f"/articles/{file_name}"

        # 💡 نظام "مواضيع ذات صلة" الحقيقي والمبرمج بالسيرفر (روابط حقيقية 100%)
        db = load_db()
        related_html = ""
        if len(db) > 0:
            random.shuffle(db)
            related_html = "<div class='related-box'><h2>📚 Discover More</h2><div class='related-list'>"
            for r_art in db[:4]: # سحب 4 مقالات حقيقية
                related_html += f"<a href='{r_art['url']}' class='related-item'><h4>{r_art['title']}</h4><span>{r_art['category']}</span></a>"
            related_html += "</div></div>"

        # تصميم المقال الفخم بدون أي ترجمة
        html_content = f"""<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{clean_title} - Mnjnef Open Library</title>
    <style>
        body {{ font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; line-height: 1.8; color: #333; background: #f8f9fa; margin: 0; }}
        header {{ background: #1a365d; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 5px rgba(0,0,0,0.1);}}
        header .logo {{ color: white; text-decoration: none; font-size: 1.4em; font-weight: bold; }}
        header .home-btn {{ background: white; color: #1a365d; padding: 8px 15px; border-radius: 20px; text-decoration: none; font-weight: bold; font-size: 0.9em; }}
        .container {{ max-width: 850px; margin: 40px auto; background: white; padding: 50px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); }}
        h1 {{ font-size: 2.5em; color: #1a202c; border-bottom: 2px solid #edf2f7; padding-bottom: 10px; line-height: 1.2;}}
        h2 {{ color: #2b6cb0; margin-top: 40px; }}
        .meta-info {{ background: #f7fafc; padding: 15px; border-radius: 8px; border-left: 4px solid #3182ce; margin-bottom: 40px; font-size: 0.95em; color: #718096; }}
        
        /* تنسيق مواضيع ذات صلة الحقيقية */
        .related-box {{ margin-top: 50px; border-top: 3px solid #e2e8f0; padding-top: 30px; }}
        .related-box h2 {{ margin-bottom: 20px; color: #2d3748; }}
        .related-list {{ display: flex; flex-direction: column; gap: 15px; }}
        .related-item {{ background: #f8f9fa; border: 1px solid #e2e8f0; padding: 20px; border-radius: 8px; text-decoration: none; color: inherit; border-left: 4px solid #3182ce; transition: 0.2s; }}
        .related-item:hover {{ background: #ebf8ff; transform: translateX(5px); border-color: #3182ce; }}
        .related-item h4 {{ margin: 0 0 5px 0; font-size: 1.2em; color: #1a365d; }}
        .related-item span {{ font-size: 0.85em; color: #718096; }}
        
        @media(max-width: 600px) {{ .container {{ padding: 25px; margin: 15px; }} h1 {{ font-size: 2em; }} }}
    </style>
</head>
<body>
    <header><a href="/" class="logo">Mnjnef</a><a href="/" class="home-btn">🏠 Home</a></header>
    <div class="container">
        <h1>{clean_title}</h1>
        <div class="meta-info">📅 {seo_date} | 📂 {cat.replace('_', ' ')}</div>
        <div class="article-body">{text}</div>
        {related_html}
    </div>
</body></html>"""

        with open(f"/var/www/html{article_url}", "w") as f: f.write(html_content)
        
        db.insert(0, {"title": clean_title, "url": article_url, "category": cat.replace('_', ' '), "date": seo_date})
        save_db(db)
        build_homepage()
        
        os.system("chown -R www-data:www-data /var/www/html /var/www/mnjnef.com")
        print(f"✅ Published: {clean_title}", flush=True)

    except Exception as e:
        print(f"Error: {e}")

# مسح شامل وتهيئة للمرة الأولى
save_db([])
generate_article()

# دورة النشر المستمرة
while True:
    time.sleep(random.uniform(25.0, 45.0))
    generate_article()
