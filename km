                            return {
                                "title": str(parsed_json['seo_headline']).replace('"', '').replace('*', '').strip(),
                                "image_prompt": str(parsed_json['visual_ai_prompt']).strip(),
                                "body": str(parsed_json['journalism_body']).strip()
                            }
