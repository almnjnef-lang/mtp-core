        ListElement { stepIndex: 2; title: "Agent Assigned"; desc: "Routing to specialized operative"; timestamp: "10:45 AM" }
        ListElement { stepIndex: 3; title: "Resolution"; desc: "Awaiting final diagnostics"; timestamp: "--:--" }
    }

    ListModel {
        id: chatModel
        ListElement { senderType: "SYSTEM"; senderName: "MNJNEF_CORE"; message: "Ticket established. Encrypted communication channel opened."; timestamp: "10:42 AM" }
        ListElement { senderType: "SYSTEM"; senderName: "MNJNEF_CORE"; message: "Telemetry packet received. Analyzing dump logs..."; timestamp: "10:43 AM" }
        ListElement { senderType: "USER"; senderName: "You"; message: "My platform instance crashes upon compiling the new renderer module."; timestamp: "10:44 AM" }
        ListElement { senderType: "SYSTEM"; senderName: "ROUTING"; message: "Connecting to Tier 2 Engineering Support..."; timestamp: "10:45 AM" }
        ListElement { senderType: "AGENT"; senderName: "Operative_Vanguard"; message: "Greetings. I'm reviewing your crash dump right now. It looks like a memory allocation fault in the GPU buffer."; timestamp: "10:46 AM" }
    }

    ListModel {
        id: detailsModel
        ListElement { label: "Category"; value: "Technical Issue" }
        ListElement { label: "Priority"; value: "HIGH" }
        ListElement { label: "Environment"; value: "Win64 / DX12" }
        ListElement { label: "Session ID"; value: "MNJ-88A9B2" }
        ListElement { label: "Attachments"; value: "2 Files (4.2 MB)" }
    }

    // ==========================================
    // BACKGROUND AMBIENCE
    // ==========================================
    Rectangle {
        anchors.fill: parent
        color: trackTheme.bgPrimary
        
        // Dynamic Grid
        Canvas {
            id: gridCanvas
            anchors.fill: parent
            opacity: 0.1
            
            onPaint: {
                var ctx = getContext("2d");
                ctx.clearRect(0, 0, width, height);
                ctx.strokeStyle = trackTheme.accentCore;
                ctx.lineWidth = 1;
                
                var gridSize = 40;
                ctx.beginPath();
                for (var x = 0; x < width; x += gridSize) {
                    ctx.moveTo(x, 0);
                    ctx.lineTo(x, height);
                }
                for (var y = 0; y < height; y += gridSize) {
                    ctx.moveTo(0, y);
                    ctx.lineTo(width, y);
                }
                ctx.stroke();
            }
        }
        
        // Radial Gradient Center
        Rectangle {
            anchors.fill: parent
            gradient: Gradient {
                GradientStop { position: 0.0; color: "transparent" }
                GradientStop { position: 1.0; color: "#aa02040a" }
            }
            z: 1
        }
    }

    // ==========================================
    // MAIN DASHBOARD LAYOUT (TWO COLUMNS)
    // ==========================================
    RowLayout {
        anchors.fill: parent
        anchors.margins: 24
        spacing: 24
        z: 10

        // ------------------------------------------
        // LEFT COLUMN: TICKET INFO & TIMELINE
        // ------------------------------------------
        ColumnLayout {
            Layout.preferredWidth: 400
            Layout.fillHeight: true
            spacing: 16

            // Header Card
            Rectangle {
                Layout.fillWidth: true
                Layout.preferredHeight: 90
                color: trackTheme.bgPanel
                radius: 12
                border.color: trackTheme.borderDefault
                border.width: 1

                RowLayout {
                    anchors.fill: parent
                    anchors.margins: 16
                    spacing: 16

                    Rectangle {
                        Layout.preferredWidth: 50
                        Layout.preferredHeight: 50
                        radius: 10
                        color: trackTheme.bgElevated
                        border.color: trackTheme.accentCore
                        border.width: 1
                        
                        Text {
                            anchors.centerIn: parent
                            text: "📡"
                            font.pixelSize: 24
                        }
                    }

                    ColumnLayout {
                        Layout.fillWidth: true
                        spacing: 2
                        
                        Text {
                            text: qsTr("TRACKING TERMINAL")
                            color: trackTheme.textMuted
                            font.pixelSize: 11
                            font.bold: true
                            font.family: trackTheme.fontMono
                        }
                        
                        Text {
                            text: mnjnefTicketTrackerRoot.ticketId
                            color: trackTheme.textHeader
                            font.pixelSize: 22
                            font.bold: true
                            font.family: trackTheme.fontMain
                        }
                    }
                    
                    // Live Status Badge
                    Rectangle {
                        Layout.preferredWidth: 90
                        Layout.preferredHeight: 28
                        radius: 14
                        color: "#1a" + trackTheme.stateWarning.substring(1)
                        border.color: trackTheme.stateWarning
                        border.width: 1
                        Layout.alignment: Qt.AlignVCenter
                        
                        RowLayout {
                            anchors.centerIn: parent
                            spacing: 6
                            
                            Rectangle {
                                width: 8
                                height: 8
                                radius: 4
                                color: trackTheme.stateWarning
                                
                                SequentialAnimation on opacity {
                                    loops: Animation.Infinite
                                    running: true
                                    NumberAnimation { from: 1.0; to: 0.2; duration: 800 }
                                    NumberAnimation { from: 0.2; to: 1.0; duration: 800 }
                                }
                            }
                            
                            Text {
                                text: qsTr("ACTIVE")
                                color: trackTheme.stateWarning
                                font.pixelSize: 11
                                font.bold: true
                                font.family: trackTheme.fontMono
                            }
                        }
                    }
                }
            }

            // Ticket Details Grid
            Rectangle {
                Layout.fillWidth: true
                Layout.preferredHeight: 180
                color: trackTheme.bgPanel
                radius: 12
                border.color: trackTheme.borderDefault
                border.width: 1

                ColumnLayout {
                    anchors.fill: parent
                    anchors.margins: 16
                    spacing: 12
                    
                    Text {
                        text: qsTr("PAYLOAD METADATA")
                        color: trackTheme.textHeader
                        font.pixelSize: 13
                        font.bold: true
                        font.family: trackTheme.fontMain
                    }
                    
                    Rectangle {
                        Layout.fillWidth: true
                        Layout.preferredHeight: 1
                        color: trackTheme.borderDefault
                    }
                    
                    GridView {
                        Layout.fillWidth: true
                        Layout.fillHeight: true
                        cellWidth: width / 2
                        cellHeight: 40
                        model: detailsModel
                        interactive: false
                        
                        delegate: Item {
                            width: GridView.view.cellWidth
                            height: GridView.view.cellHeight
                            
