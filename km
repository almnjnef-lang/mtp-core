import smtplib
import random
import time
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart

# ==========================================
# ALMNJNEF PASSWORD RECOVERY & OTP ENGINE
# ==========================================
# This microservice handles secure OTP generation, 
# email dispatching, and verification for password resets.

class PasswordRecoveryWarden:
    def __init__(self, otp_expiry_seconds=600):
        # Default OTP expiry is 10 minutes (600 seconds)
        self.expiry_time = otp_expiry_seconds
        
        # Dictionary to store active OTPs: { "email": {"otp": "123456", "timestamp": 169...} }
        self.active_otps = {}

        # Email Configuration (Must be replaced with actual Almnjnef Support email credentials)
        self.smtp_server = "smtp.gmail.com"
        self.smtp_port = 587
        self.sender_email = "support@almnjnef.com" # REPLACE WITH REAL EMAIL
        self.sender_password = "your_app_password_here" # REPLACE WITH REAL APP PASSWORD

    def generate_and_send_otp(self, user_email):
        """Generates a 6-digit OTP and simulates sending it via email."""
        # 1. Generate a secure 6-digit number
        otp_code = str(random.randint(100000, 999999))
        current_time = time.time()

        # 2. Store it in memory
        self.active_otps[user_email] = {
            "otp": otp_code,
            "timestamp": current_time
        }

        print(f"[RECOVERY SYSTEM] Generated OTP for {user_email}. Valid for {self.expiry_time//60} minutes.")
        
        # 3. Send Email (Simulated for testing, logic is ready for production)
        try:
            print(f"[EMAIL DISPATCHER] Sending email to {user_email}...")
            print("-" * 40)
            print(f"Subject: Almnjnef Password Reset Code")
            print(f"Body: Hello,\nYour password reset code is: {otp_code}\nDo not share this with anyone.")
            print("-" * 40)
            print("[EMAIL DISPATCHER] Email sent successfully!")
            
            # UNCOMMENT AND CONFIGURE BELOW TO SEND REAL EMAILS:
            """
            msg = MIMEMultipart()
            msg['From'] = self.sender_email
            msg['To'] = user_email
            msg['Subject'] = "Almnjnef - Password Reset Code"
            body = f"Your password reset code is: {otp_code}\nThis code is valid for 10 minutes."
            msg.attach(MIMEText(body, 'plain'))
            
            server = smtplib.SMTP(self.smtp_server, self.smtp_port)
            server.starttls()
            server.login(self.sender_email, self.sender_password)
            server.send_message(msg)
            server.quit()
            """
            return True
        except Exception as e:
            print(f"[EMAIL ERROR] Failed to send email: {e}")
            return False

    def verify_otp(self, user_email, provided_otp):
        """Validates the OTP provided by the user."""
        current_time = time.time()

        # 1. Check if an OTP was actually requested
        if user_email not in self.active_otps:
            print(f"[RECOVERY ALERT] No active reset request found for {user_email}.")
            return False

        record = self.active_otps[user_email]

        # 2. Check Expiry
        if current_time - record["timestamp"] > self.expiry_time:
            print(f"[RECOVERY ALERT] OTP for {user_email} has EXPIRED.")
            del self.active_otps[user_email] # Clean up
            return False

        # 3. Check Match
        if record["otp"] == provided_otp:
            print(f"[RECOVERY SUCCESS] OTP matched for {user_email}. Access granted to reset password.")
            del self.active_otps[user_email] # Remove OTP after successful use
            return True
        else:
            print(f"[RECOVERY ALERT] INVALID OTP provided for {user_email}.")
            return False

